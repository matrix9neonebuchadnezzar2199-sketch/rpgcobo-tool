//	getPolygonMeshでボクセルを読めるように。voxファイル単位のみ
//	ptdとかでもvoxが使えるように！
function getPolygonMesh( res, doclone=true){
	if( typeof( res) == SS_STRING){
		local s = res;
		res = getResource( s);
		if( !res) throw Exception( "getPolygonMesh res not found:%S", s);
	}
	local mesh = res.userdata;
	if( !mesh){
		if( res.name.endsWith( ".vox")){
			local vc = res.getContent();
			local vp = vc.partsAt( 0), vd8 = vp["vd8"];
			local vmd = VoxelMeshBuilder.createVoxelMeshData( vd8, null, 0, 63, [vd8.w/2, vd8.h/2, vd8.d/2]);
			mesh = vmd.createPolygonMesh( vc.pal);
		}else{
			local loader = PolygonMeshLoader( res);
			loader.load();
			mesh = loader.mesh;
			loader.clear();
		}
	}
	res.flush();
	res.userdata = mesh;
	local pm = doclone?(clone mesh):mesh;
	return pm;
}

//	map_voxの定義からテスト用のブロック定義を生成。map_voxのプレビュー描画用に必要
//	
function testBlockConf( val){
	local type = val.type;	//	val内のtype,clsはすべて同一という条件。
	local blkdef = defblkvarmap[type];
	local v = { ...blkdef.def, ...val};
	if( v["vp0"] && !chkvcvp( v.vp0)){
		v.vp0 = clone blkdef.def.vp0;
	}
	v.vcvp <- makevcvp( v);
	v.pal <- makepalmod( v);
	local ret = { cls=blkdef.cls, variations=[v]};
	return ret;
}


//	conf_postloadにフックを追加
module.hookAction( "conf_postload", setupVoxelConfig, 99);
