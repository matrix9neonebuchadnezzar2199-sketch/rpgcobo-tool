import VirtualKeyCode;
import AnimationPart;
import CollisionGroupID;
import BlockFlagID;

local v_0 = Vector3D(), v_1 = Vector3D(), v_2 = Vector3D(), v_3 = Vector3D(), m_1 = Matrix(), r_1 = Rect3D(), q_1 = Quaternion(), q_2 = Quaternion();

AnimationLayer.id <- null;
AnimationLayer.part <- null;

////////////////////////////////////////////////////////////////////////////////
//	
//	アニメーションは全ての体形で共通の名前：フレームのテーブルを用意する。
//	武器動作は、前、中1、中2、後(st, m1, m2, en)で、前のみ再生や中から再生、後を止めるなどの操作が可能。
//	m1,m2は省略可で、省略した場合はm1=st, m2=enとなる。
//	また、トリッキーな動きとして逆再生も可能。st-enが逆になる。
//	anime( id, ST_EN)のように再生する。ST_EN, ST, MD, MD_EN, EN, EN_ST, MD_ST, EN_MD, 
//	

function unitdir( d){
	if( d < 0.0){ d += Math.PI2 * Math.floor( -d / Math.PI2 + 1.0); }
	return d % Math.PI2;
}

//	d1 - d2
function deltadir( d1, d2){
	return Math.mod2( d2-d1, -Math.PI, Math.PI);
}

//	ベクトルp0からp1に向かうdirを計算
function aimdir( p0, p1){
	local v = v_0( p1).sub( p0).scale( 1, 0, 1).normalize();
	return Math.acos( v.z)*((v.x>=0.0)?1.0:-1.0);
}

function aimrot( vec){
	local v = v_0( vec).normalize(), vy = -v.y;
	v.scale( 1, 0, 1).normalize();
	return Quaternion.fromHPB( Math.acos( v.z)*((v.x>=0.0)?1.0:-1.0), Math.asin( vy), 0.0);
}


