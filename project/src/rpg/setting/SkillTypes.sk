local atkformprop = {
	pid="atkform", lbl="$T.lbl_atkform", type=SCRIPT, defval="", hide=hide_nodamage, //deflbl=deflbl_dmgform( "atk"),
	get = @( prop, data, e){
		local val = data[prop.pid];
		if( length( val)) return val;
		return deflbl_dmgform2( e.data, "atk");
	}
	set = @( prop, data, val, e){
		val = val.trim();
		local defval = deflbl_dmgform2( e.data, "atk");
		data[prop.pid] <- (val!="" && val!=defval) ? val : "";
	}
};
