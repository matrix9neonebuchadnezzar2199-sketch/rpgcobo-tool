//	効果予測値を返す。0.0は効果なし。1.0で100%の効果。2.0とかだと弱点を突いている。
//	※弱点、反射、吸収などの測定も行うべき。泥臭いコードになりそうだが。。。

//	攻撃用の効果測定メソッド
function forecastAttack( skill, src, dst){
	if( dst.HP <= 0 || dst.isDead()) return 0.0;	//	死亡者には攻撃無効。石化などの死亡扱いコンディションでも。
	return 1.0;
}

//	回復用の効果測定メソッド。併せてコンディションの付与・解除もチェック。
//	fordead=1: 死者にも使用可能, 2: 死者のみに使用可能, 0: 生存者のみ
function forecastHeal( skill, src, dst){
	if( dst.isDead()){
		//	死亡状態では、その状態を解除できるスキルのみが有効。※これだと死、石がついてて石だけ回復出来る。まあいいか
		return dst.canRemoveAnyCondition( skill["remconds"]) ? 1.0 : 0.0;
	}else
	if( skill.flags & (1<<FLAG_NOOP_ALIVE)){	//	死者にのみ有効なスキル。復活魔法ぐらい。
		return 0.0;
	}
	local pid = DamageTypePID[skill["dmgtype"]];
	local r = dst.getPointRate( pid);
	if( pid && r < 100) return 1.0;		//	回復パラメータが最大じゃなければOK
	if( dst.canRemoveAnyCondition( skill["remconds"])) return 1.0;
	return 0.0;
}

//	バフ用効果測定メソッド。複数のグッドコンディションを相手に付ける。
//	死んでる相手には無効。
function forecastBuff( skill, src, dst){
	if( dst.HP <= 0 || dst.isDead()) return 0.0;
	if( dst.canPutAnyCondition( skill["putconds"])) return 1.0;
	return 0.0;
}

//	デバフ用効果測定メソッド。複数のバッドコンディションを一度につけることができるが、耐性は一番強いものをベースに計算される。
//	もしくは個別に計算？
function forecastDebuff( skill, src, dst){
	if( dst.HP <= 0 || dst.isDead()) return 0.0;
	if( dst.canPutAnyCondition( skill["putconds"])) return 1.0;
	return 0.0;
}

//////////////////////////////////////////////////////////////////////////////////////////////
//	メニュー使用スキル用メソッド

//	メニューで回復系スキルを発動した時のメソッド。
//	・キャラ選択画面が表示されていることが前提の演出。
//	・演出は音とパーティクルのみ
function menuHealSkillFunc( skill, src, dsts){
	//	計算のためにSkillCommand、Damageを生成。
	local cmd = SkillCommand( src, skill, dsts);
	local success = false;
	foreach( dst in dsts){
		if( !dst) continue;
		if( forecastHeal( skill, src, dst) <= 0.0) continue;	//	死者に回復とかを弾く
		success = true;
		local dmg = Damage( cmd, dst);
		dmg.calcDamage();
		//	オプション挟むならここ
		dmg.finishDamage();
		dst.addPoint( dmg.pid, -dmg.val);	//	回復実行。
		foreach( condid in bitdblist( skill["remconds"], "cond")){	//	コンディション解除
			dst.removeCondition( condid);
		}
		//	演出。sleepはいらないかな？
		local p = ::rootview.findChild( "dialog_selchara.%S.mdl" % dst.dataid);	//	dialog_selchara=キャラ選択ダイアログ
		p?.hitSkill( skill);
	}
	if( success && skill["hitact"]["hitsnd"]){
		local snd = ::conf._resource.snd[skill["hitact"]["hitsnd"]];
		::playSound( skill["hitact"]["hitsnd"], {gain=snd.gain*0.3});
	}
	return success;
}

//	メニューでバフ系スキルを発動した時のメソッド
//	
function menuBuffSkillFunc( skill, src, dsts){
	local success = false;
	foreach( dst in dsts){
		if( forecastBuff( skill, src, dst) <= 0.0) continue;	//	死者に回復とかを弾く
		success = true;
		foreach( condid in bitdblist( skill["putconds"], "cond")){	//	コンディション付与
			dst.putCondition( condid);
		}
		//	演出。sleepはいらないかな？
	}
	return success;
}

//	メニューでマクロを発動した時のメソッド。
//	・キャラ選択が無い場合はdst=null
//	・マクロ実行中はスレッドはブロック。
function menuMacroSkillFunc( skill, src, dsts){
	local wvar = clone RPGEventRunner.iniwvar;
	local m = ::rpgstage.startMacro( skill.macroid_menu, false, wvar);
	while( m["mode"] == 2){
		suspend();
	}
	//	実行が成功した場合はWに成功を入れる。この場合に消費処理をする。
	//	※このマクロでマップ移動なんかをする場合にこの後の処理が中断されてしまう。。。
	local success = !!wvar["W"];
	return success;
}




////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////
//	
//	ここからスキルタイプ定義
//	

RPGSystem.skilltype .. {
	key = "unusable",
	lbl = "$T.skilltype_unusable",

	battlefunc = null
	menufunc = null
	forecast = @() 0.0

	props = [
		occasionprop_none,
	]
}

//	何もしないは、構えモーションのまま次のターンまで待機する。※アクティブバトルの場合は次の入力時点で解除。
//	その間スキルは付き続けるので、オプションと組み合わせて様々な状態を作り出すことができる。
//	防御、カウンター、魔封剣、かばう、、、かばう対象を指定したいときにはRPGCharaBaseにフィールドを追加するしかないかなー
//	眠り、混乱、麻痺などの行動制約が付いた場合にスキルは解除される。スタンでも同じく。
//	バトル時のみ使用可能。
//	
RPGSystem.skilltype .. {
	key = "noop",
	lbl = "$T.skilltype_noop",

	battlefunc = SkillCommand.noopSkillFunc
	menufunc = null
	forecast = @() 1.0	//	効果を予測することはできない。。。

	props = [
		occasionprop_battle,	//	非表示
		cmdtgtprop,
		//
		efxhead,
		aimaniprop,
		useactprop,
		acttestprop,
	]
}

//	敵に対して攻撃するスキル。
//	バトル時のみ使用可能。
//	
RPGSystem.skilltype .. {
	key = "attack"
	lbl = "$T.skilltype_attack"
	
	battlefunc = SkillCommand.commonSkillFunc
	menufunc = null
	forecast = forecastAttack

	props = [
		occasionprop_battle,	//	非表示
		cmdtgtprop_enemy,
		dmgtypeprop,
		dmgformprop,
		atkformprop,
		dmgrateprop,
		spdrateprop,
		hitrateprop,
		atknumprop,
		elembitsprop,
		flagsprop,
		//
		efxhead,
		aimaniprop,
		useactprop,
		atkactprop,
		hitactprop,
		endactprop,
		acttestprop,
	]
}

//	回復スキル
//	バトル時、メニュー時どちらでも使用可能(選択)
//	
RPGSystem.skilltype .. {
	key = "heal"
	lbl = "$T.skilltype_heal"
	
	battlefunc = SkillCommand.commonSkillFunc
	menufunc = menuHealSkillFunc
	forecast = forecastHeal

	props = [
		occasionprop,
		cmdtgtprop_party,
		dmgtypeprop_heal,
		dmgformprop,
		atkformprop,
		spdrateprop,
		remcondsprop,
		flagsprop,
		//
		efxhead,
		aimaniprop,
		useactprop,
		atkactprop,
		hitactprop,
		endactprop,
		acttestprop,
	]
}

//	バフスキル。良効果の付与。ダメージ系のプロパティは無し
//	味方に対しての状態付与で、確率計算式がある。
//	バトル時、メニュー時どちらでも使用可能(選択)
//	
RPGSystem.skilltype .. {
	key = "buff"
	lbl = "$T.skilltype_buff"

	battlefunc = SkillCommand.buffSkillFunc
	menufunc = menuBuffSkillFunc
	forecast = forecastBuff

	props = [
		occasionprop,
		cmdtgtprop_party,
		spdrateprop,
		putcondsprop,
		flagsprop,
		//	成功率、付与レベル
		//	
		efxhead,
		aimaniprop,
		useactprop,
		hitactprop,
		acttestprop,
	]
}

//	デバフスキル。悪効果の付与
//	確率計算用の状態グループと、確率調整、確率計算式がある。
//	バトル時のみ使用可能。
//	
RPGSystem.skilltype .. {
	key = "debuff"
	lbl = "$T.skilltype_debuff"

	battlefunc = SkillCommand.debuffSkillFunc
	menufunc = null
	forecast = forecastDebuff

	props = [
		occasionprop_battle,
		cmdtgtprop_enemy,
		{...dmgformprop, hide=false},	//	ダメージは無いけど表示
		{...hitrateprop, hide=false},
		spdrateprop,
		putcondsprop,
		flagsprop,
		//	成功率、付与レベル
		//	
		efxhead,
		aimaniprop,
		useactprop,
		hitactprop,
		endactprop,
		acttestprop,
	]
}

//	強化攻撃スキル。他のスキル又はデフォルトスキルに対して別オプションで実行する。
//	※cmdtgtは指定しないでもゲーム上から取ることもできるな
RPGSystem.skilltype .. {
	key = "enhance"
	lbl = "$T.skilltype_enhance"
	
	battlefunc = SkillCommand.enhanceSkillFunc
	menufunc = null
	forecast = forecastAttack

	props = [
		occasionprop_battle,	//	非表示
		{ pid="skillid", lbl="$T.lbl_nextskill", type=DATAID, datatype = ["skill"], nullable=true, defval=null, },
		cmdtgtprop_enemy,
		spdrateprop,
		//
		efxhead,
		aimaniprop,
		useactprop,
		acttestprop,
	]
}

//	マクロ実行
//	バトルで使用するマクロ、メニューで使用するマクロを別々に設定可能。
//	バトル時、メニュー時どちらでも使用可能（自動判別）。
//	
RPGSystem.skilltype .. {
	key = "macro"
	lbl = "$T.skilltype_macro"
	
	battlefunc = SkillCommand.macroSkillFunc
	menufunc = menuMacroSkillFunc	//	
	forecast = @() 1.0	//	効果を予測することはできない。。。

	props = [
		occasionprop_none,	//	↓のマクロ設定でoccasionが設定される。
		cmdtgtprop,
		{ pid="macroid_battle", lbl="$T.lbl_macroid_battle", type=DATAID, datatype = ["macro"], nullable=true, defval=null,
			set = @( prop, data, val){
				data[prop.pid] <- val; if( val) data.occasion|=1; else data.occasion&=~1;
			}
		},
		{ pid="macroid_menu", lbl="$T.lbl_macroid_menu", type=DATAID, datatype = ["macro"], nullable=true, defval=null,
			set = @( prop, data, val){
				data[prop.pid] <- val; if( val) data.occasion|=2; else data.occasion&=~2;
			}
		},
		spdrateprop,
		{ pid="warg", lbl="$T.lbl_macroarg: W", type=VARIABLE, varbits=2|4|8|16, constbits=1|2|4, datatype="all", nullable=1, defval=null },
		//	
		efxhead,
		aimaniprop,
		useactprop,
		endactprop,
		acttestprop,
	]
}
