//	ダメージタイプがNO_DAMAGE又は未定義の時にはプロパティを非表示にする
local hide_nodamage( pl){
	local dmgtype = pl.getParam( "dmgtype");
	return !dmgtype;
}

local deflbl_dmgform( fid){
	return @( pl){
		local i = pl.getParam( "dmgform");
		local form = ::conf.type["dmgform"][i]["formula"];
		if( form){
			try{
				local str = "return {%S}" % form;
				local f = compilestring( str)()[fid];
				if( typeof( f) == SS_CLOSURE){
					local r = f.getSourceStringRange();
					return str.substring( r[0], r[1]);
				}
			}catch( ex){
				printexception( ex);
			}
		}
	}
}

local deflbl_dmgform2( data, fid){
	local i = data["dmgform"];
	local form = ::conf.type["dmgform"][i]["formula"];
	if( form){
		try{
			local str = "return {%S}" % form;
			local f = compilestring( str)()[fid];
			if( typeof( f) == SS_CLOSURE){
				local r = f.getSourceStringRange();
				return str.substring( r[0], r[1]).trim();
			}
		}catch( ex){
			printexception( ex);
		}
	}
}

////////////////////////////////////////////////////////////////////////////////////////////////
//
//	演出スクリプトソース
//	ソース直書き＋プロパティでいく！
//	

local scpheadprop = { pid="HB", lbl="$T.lbl_script", type=HEADER, cnt="header.ui", expanded=false };
local scpprop = {
	pid="scp", lbl="$T.lbl_script", type=SCRIPT, multiline=8, cnt="cnt5.ui"
	get = @( prop, data){
		local v = data[prop.pid];
		if( !v) v = ::skillscriptmap[data["id"]];
		return v;
	},
	set = @( prop, data, val){
		val = val.trim();
		local defval = ::skillscriptmap[data["id"]];
		data[prop.pid] <- (val != defval)?val : null;
	}
};

//	useact, atkact, hitact, endact のデフォルトスクリプト。idが対応している
//	
::skillscriptmap <- {
//	共通
noop = "",
custom = "",
//	発動スクリプト
////////// 通常発動 /////////// 
use_normal = 
`if( ispic){
	efx( eefx);
	wait( EFX);
}else{
}`,
////////// 魔法発動 /////////// 
use_charge =
`anime( useani);
snd( usesnd);
efx( useefx);
wait( EFX);
`,
////////// 暗転魔法発動 /////////// 
use_darkcharge =
`::rpgstage.screenfx.screenEffectOn( {"expscale":0.3,"sfxid":"expscale","time":600});
wait( 300);
anime( useani);
snd( usesnd);
efx( useefx);
wait( EFX);
`,
//	アタックスクリプト
////////// 通常攻撃 /////////// 
atk_normal =
`if( ispic) return wait( 100);
anime( atkani);
wait( atkdelay);
efx( atkefx);
snd( atksnd);
`,
////////// 発射攻撃 /////////// 
atk_shoot =
`anime( atkani);
wait( 250);
efx( atkefx);
snd( atksnd);
shoot( {id=ammofx,time=ammotime, dst=dst3d, dis=true});
wait( ammotime);
`,
//	ヒットスクリプト
////////// 通常ヒット /////////// 
hit_normal = 
`if( this["cri"]) criticalHit();
efx( hitefx);
snd( hitsnd);
wait( hitdelay);
anime( hitani);
wait( EFX);
`,
//	終了スクリプト
end_dark = 
`::rpgstage.screenfx.screenEffectOff( {sfxbits=1, time=600});
wait( 600);
`,

};

//	なし
local nonescp = {
	id="noop",
	lbl = "$T.lbl_none",
	props = [ ],
	defval = { scp=null, }
};

//	カスタム。パラメータ無しで好きに組み立てる
local customscp = {
	id="custom",
	lbl = "$T.lbl_custom",
	props = [ scpprop, ],
	defval = { scp=null, }
};

