//	スキルアクション⇒スキルタイプ
//	
//	何もしない
//	攻撃スキル
//	回復スキル
//	バフスキル
//	デバフスキル
//	マクロスキル
//	
//	隊列変更スキル　※指定不能

//	アクション定義を返す。name,pid等は入ってないので...でつなげること
local makeactionprop( scps){
	return {
		type=PROPERTYLIST,
		propdef=@(){
			local propdef = {
				name="aiuro", width=520, 
				props = @( v){
					local ss = scps.find( @( s) s.id==v.id);
					local a = [
						{ pid="id", lbl="$T.lbl_actionid", type=LIST, list=@() scps.map( @( v)({ lbl=v.lbl, val=v.id })), refresh=1, cnt="cnt8.ui"
							set = @( prop, data, val){
								local ss = scps.find( @( v) v.id==val);
								Table.clear( data); data ... ss.defval; data.id <- ss.id;
							}
						},
						...ss.props,
					];
					return a;
				},
				tostring = @( v){
					local pdef = scps.find( @( x) x.id==v.id);
					return sprintf( "%S %S", pdef["lbl"], (fget( pdef, "tostring", pdef, v) || ""));
				}
			};
			return propdef;
		},
		defval={ id=scps[0].id, ...scps[0].defval},
	};
}



