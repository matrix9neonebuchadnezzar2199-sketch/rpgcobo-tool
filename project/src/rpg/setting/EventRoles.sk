::lightflickerlist <- [
	{ lbl="$T.lbl_none", val=0 },
];

//	ライト
//	
RPGSystem.eventrole .. {
	menutype = "event"
	key = "light"
	name = "$T.lbl_light"
	icon = "\uf02a"
	editmanuaction = true

	// width = 520
	
	props = @( cmd)[
		nameprop,
		reqs0prop,		//	スポーン条件。
		//	以下ライト
		{ pid="lcol", lbl="$T.lbl_color", type=RGBA, defval=0xffffcc66 }
		{ pid="lr", lbl="$T.lbl_size", type=SCALAR, range=(0.1,99.9), q=10, defval=10.0 }
		{ pid="lhpb", lbl="$T.lbl_direction", type=VEC2, range=(-180,180), defval=(0,-60) }
		{ pid="lspot", lbl="$T.lbl_litspot", type=VEC2, range=((0,180),(0,100)), defval=(180,10), ui="r", rlbl0="#" }
		{ pid="flicker", lbl="$T.lbl_filcker", type=LIST, list=::lightflickerlist, defval=0 }
	];
	
	defdata = {
		mdlid = "CE000",
		spawndist = 1,
		reqs0 = null,
		lcol = 0xffffcc66, lr = 10.0, lhpb = [0,60], lspot = [180,10], flicker = 0,
	}
	
	defpage = [
		{
			trigger = 6				//	spawn
			wvarmap = { W="data" }	//	dataはdata自身。
			pararun = true,
			cmdblock = [
				{ cmd="cmd_light", op=0, fadetime=0, _var={lcol="\tW.lcol",lr="\tW.lr",lhpb="\tW.lhpb",lspot="\tW.lspot",flicker="\tW.flicker"}, }
			]
		},
	]
}


//	カスタムイベント。専用の編集パネルを表示する
RPGSystem.eventrole .. {
	key = "custom"
	name = "$T.lbl_customevent"
	icon = "\ue01e"
	editmanuaction = true
	
	baseprops = [
		nameprop,
		spawndistprop,
		{
			pid="mdlid", lbl="$T.lbl_model", type=RESID_PREVIEW, restype=["chara_etc","chara_vox","efx","map_asset"], cnt="cnt3.ui",
			filter=@( i, d){
				switch( i[0]){
				case 'F': case 'M': return d["eventuse"];
				}
				return true;
			}
			set= @( prop, data, val){
				data.mdlid <- val;
				if( val=="CE000"){
					data.mdl <- { r=[0.0,0.5,0.0,0.5,0.5,0.5] };
				}else{
					delete data.mdl;
				}
			}
		}
	]
	
	pageprops = @( cmd)[
		{ pid="memo", lbl="$T.lbl_pagememo", type=STRING }
		moveactionprop, ...RPGSystem.moveaction[cmd["moveaction"]]["props"],
		triggerprop,
		{ pid="pararun", lbl="$T.lbl_pararun", type=BOOL}
		reqsprop,
	]
	
	//	展開用
	defdata = {
		mdlid="CV000",
		spawndist = 1,
		page = [
			{ memo="", moveaction="stop", movespd=4, standani={id="stand"}, trigger=1, pararun=false, reqs=null, cmdblock = [], }
		]
	}
}


//	カメラマーカー
//	
RPGSystem.markerdef .. {
	key = "camera"
	name = {"ja":"カメラ","en":"Camera"}
	icon = "\ue3af"
	desc = ""
	
	props = [
		nameprop,
		{ pid="fovy", lbl="$T.lbl_fovy", type=SCALAR, range=(10,80), defval=40 },
		{ pid="viewport", lbl="$T.lbl_viewport", type=SCALAR, range=(0.1,100.0), q=10, defval=4.0 },
		{ pid="hpb", lbl="$T.lbl_rotation", type=VEC3, range=(-180,180), ui="bar", lbls=["$T.lbl_hpb_h","$T.lbl_hpb_p","$T.lbl_hpb_b"], defval=(0,45,0) },
		{ pid="yoffs", lbl="$T.lbl_offset", type=SCALAR, range=(-5.0,5.0), q=10, defval=1.5 },
	]
	
	edit = @( data){
		local e = ::skstudio.editor;
		local cd0 = e.canvas.camwork.getCameraData(), cd1 = RPGCameraworkMarker( data);
		e.canvas.moveCameraData( cd1, 1.77777778);
		local newcam = PropertyEditPopup.run( null, this, data);
		e.canvas.moveCameraData( cd0);
		return newcam;
	}

	setprop = @( prop, data, val){
		local e = ::skstudio.editor;
		e.canvas.moveCameraData( RPGCameraworkMarker( data), 1.77777778);
	}
}

