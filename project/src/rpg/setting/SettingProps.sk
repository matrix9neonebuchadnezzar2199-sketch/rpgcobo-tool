////////////////////////////////////////////////////////////////////////////////
//	ステージ設定
//	以下のプロパティはステージの保存時に保存される。また、mapedit=trueの場合はマップエディタで初期設定を設定可能。
//	これらの状態変更は、イベントコマンド「ステージ設定の変更」で行う。BGM変更みたいなのは個別にコマンドがある

local rendersetlist(){
	local a = [];
	foreach( v in ::RenderSettings.data){
		if( v.renderpass == 2) a .. { lbl=v.name, id=v.id, icon="\ue430", val=v.id }	//	deferredのみ
	}
	return a;
}

local stageprops = RPGSystem.stageprops;

stageprops .. { mapedit=true, pid="encntrate", lbl="$T.lbl_encntrate", type=SCALAR, ui="bar", range=(0.0,100.0), q=10, barrange=(0.0,100.0,1.0), defval=0.0 };

stageprops .. {
	mapedit=true,
	pid="rsetid",
	lbl="$T.menu_view_rendersetting",
	type=LIST,
	list = rendersetlist,
	defval="pbr_df",
};

local bgtypelist = [
	{ lbl="$T.lbl_skybox", val="skybox", icon="\ue3c4", }
	{ lbl="$T.sfxbit_0", val="col", icon="\ueb36", }
	{ lbl="$T.lbl_gradation", val="grad", icon="\ue3e9", }
	{ lbl="$T.lbl_texture", val="tex", icon="\ue3d3"}
];

local bgpropdef(){
	return {
		name = "$T.lbl_bgimage"
		props = @( v){
			local a = [
				{ pid="type", lbl="$T.lbl_type", type=LIST, list = bgtypelist, refresh = true},
			];
			switch( v["type"]){
			case "col":
				a .. { pid="col", lbl="$T.sfxbit_0", type=RGB, defval=(v["col"]||0x000000ff), };
				break;
			case "grad":
				a .. { pid="grad", lbl="$T.lbl_gradation", type=3312, defval={color=[0x000033ff, 0x0000ffff]} };
				break;
			case "tex":
				a .. { pid="tex", lbl="$T.lbl_texture", type=PATH, defval="", };
				a .. { pid="uv", lbl="$T.lbl_uv", type=LIST, defval="", };	//	Cylinder, Equirectangular, Cube
				break;
			}
			return a;
		}
		setprop = @( prop, data, val){
			local ed = ::skstudio.editor;
			if( ed instanceof MapEditor){
				ed.canvas.setBackground( data);
			}
		}
		tostring = @( v){
			local ts = bgtypelist.find( @( x) x.val==v.type)["lbl"];
			switch( v.type){
			case "col":
				local cs = "%06x" % (v["col"]>>>8);
				ts = rtf( `$ts: [#$cs]■`);
				break;
			case "grad":
				local g = v["grad"]["color"]||[0xff0000ff];
				local cs0 = "%06x" % (g[0]>>>8);
				local cs1 = "%06x" % (g.last()>>>8);
				ts = rtf( `$ts: [#$cs0]■[#$cs1]■`);
				break;
			}
			return ts;
		}
	};
}

//	黒、スカイボックス、-、色指定、　テクスチャ指定
stageprops .. {
	mapedit=true,
	pid="bg",
	lbl="$T.lbl_bgimage",
	type=PROPERTYLIST,
	defval={ type="skybox", },
	propdef = bgpropdef
};

/*
		{ pid="spd", lbl="$T.lbl_speed", type=VEC2, range=(0.0,1.0), q=100, defval=[0.05,0.05], ui="bar"},
		{ pid="cloudcol", lbl="$T.lbl_color", type=RGB, defval=0x999999ff},
		{ pid="scale", lbl="$T.lbl_scale", type=SCALAR, range=(1,1000), q=1, defval=150, ui="bar"},
		{ pid="dens", lbl="$T.lbl_density", type=SCALAR, range=(0.01,0.99), q=100, defval=0.36, ui="bar"},
		{ pid="smooth", lbl="$T.lbl_smooth", type=SCALAR, range=(0.00,0.99), q=100, defval=0.09, ui="bar"},
*/
::weatherlist <- [
	{ id="none", type=null, },
	{ id="rain1", type="rain", spd=2.0, raincol=0xcce7ffff, dropw=0.02, droph=0.04, dropangle=0.0, dropdens=10, darken=40 },
	{ id="rain2", type="rain", spd=3.0, raincol=0xcce7ffff, dropw=0.02, droph=0.08, dropangle=0.25, dropdens=25, darken=70 },
	{ id="mist1", type="mist", spd=[0.22,0.1], dens=40, scale=50, xscale=3.0, modspd=0.1, mistcol=0xcce7ffff },
	{ id="mist2", type="mist", spd=[1.2,-0.6], dens=48, scale=60, xscale=4.5, modspd=0.9, mistcol=0xCBC78Fff },
	{ id="cloud1", type="cloud", spd=[0.05,0.05], cloudcol=0x999999ff, scale=150, dens=0.36, smooth=0.09 },
	{ id="snow1", type="snow", spd=2.0, snowcol=0xffffffff, scale=150, dens=0.36, },
];

local weatherpropdef(){
	local idmap = {}, idlist = [];
	foreach( i, v in ::weatherlist){
		if( v.type) idmap[v.id] <- v;
		idlist .. { lbl="$T.weather_"..v.id, icon="\uf1ad", val=v.id, }
	}
	return {
		name = "$T.setting_weather"
		props = @( v){
			local a = [
				{ pid="id", lbl="$T.lbl_type", type=LIST, list=idlist, refresh=true,
					set = @( prop, data, val){
						Table.clear( data) ... idmap[val];
					}
				},
			];
			local cls = SK3DWeathers[v["type"]], props = cls["props"];
			a ... props;
			return a;
		}
		setprop = @( prop, data, val){
			local ed = ::skstudio.editor;
			if( ed instanceof MapEditor){
				ed.canvas.refreshLinkedWeather( data);
			}
		}
		tostring = @( v) v["id"] ? sprintf( "$T.weather_%S", v["id"]) : "$T.lbl_none"
	};
}

