settingprops .. {
	part = "startup"
	pid = "inimembers"
	lbl = "$T.setting_inimembers"

	type = DATAIDS
	datalist = @() array( ::conf.setting.maxmembers).map(
		@( _, i){
			return {
				head = ""..i,
				datatype = ["player"],
			}
		}
	)
	defval = ["P000"]
};

settingprops .. {
	part = "startup"
	pid = "inimoney"
	lbl = "$T.mymoney"

	type = SCALAR
	range = (0, 1000000)

	defval = 100
};

settingprops .. {
	part = "startup"
	pid = "titlemap"
	lbl = "$T.setting_titlemap"
	type = DATAID
	datatype = ["map"]
	
	defval = "M001"
};


settingprops .. {
	part = "startup"
	pid = "inimap"
	lbl = "$T.setting_inimap"
	type = CUSTOMBUTTON

	tostring = @( v){
		local dirs = ["↑","→","↓","←",];
		local map = ::conf.map[v["mapid"]], pos = v.pos;
		local lbl = sprintf( "%S: %S (%S %S %S %S)", v["mapid"], map["name"] || "$T.lbl_invalidid", pos[0], pos[1], pos[2], dirs[pos[3]]);
		return lbl;
	}

	//	コンテキストメニュー表示してマップ編集に移動
	edit = @( val){
		if( MenuPopup.run( [{ lbl="$T.setting_inimap_open", icon="\ue89e" }])){
			::skstudio.openEditor( "/.x/map/%S" % val.mapid);
			//	位置まで移動したらもっと親切
		}
	}
};

