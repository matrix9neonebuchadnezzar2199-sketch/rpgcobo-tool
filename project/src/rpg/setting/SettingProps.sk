local destprop = { pid="dest", lbl = "$T.cmd_mapmove_dest", type=PORTAL, cnt="cnt6v.ui" };
local exitmappropdef = {
	name = "$T.setting_exitmap"
	props = @( v){
		local a = [
			{ pid="enabled", lbl="$T.lbl_enabled", type=BOOL, refresh=true,
				get = @( prop, data) !!data["dest"],
				set = @( prop, data, val){
					data.dest <- val ? (clone ::conf.setting.inimap) : null;
				}
			},
		];
		if( v["dest"]) a .. destprop
		return a;
	}
	tostring = @( v){
		if( !v["dest"]){
			return "$T.lbl_notset";
		}else{
			return getPropertyText( destprop, v);
		}
	}
}

stageprops .. {
	mapedit=true, pid="exitmap", lbl="脱出先マップ", type=PROPERTYLIST,
	propdef = exitmappropdef,
	defval = {dest=null},
}

stageprops .. {
	pid = "mapexitable",
	lbl = "$T.setting_mapexitable",
	type = BOOL,
	defval = true,
};

