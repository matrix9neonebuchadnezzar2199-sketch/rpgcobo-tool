////////////////////////////////////////////////////////////////////////////////
//	register accessors

RPGSystem.varaccs .. GlobalVarAccessor();
RPGSystem.varaccs .. SystemVarAccessor();
RPGSystem.varaccs .. QueryVarAccessor({
	name: "$T.qvar_item",
	dbname = "item",
	getfunc = @( dataid) ::rpgstat.countItems( dataid, true),	//	装備品も合わせたカウント
});
RPGSystem.varaccs .. QueryVarAccessor({
	name: "$T.qvar_enemy",
	dbname = "enemy",
	getfunc = @( dataid){
		local v = ::rpgstat.globals.collection[dataid];
		return v ? v.num : 0;
	},
});
RPGSystem.varaccs .. ButtonVarAccessor();
