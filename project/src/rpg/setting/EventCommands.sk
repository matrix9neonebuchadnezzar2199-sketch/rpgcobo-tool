local sfxoplist = [
	{ lbl="$T.lbl_show", val=0 },
	{ lbl="$T.lbl_delete", val=1 },
];

local sfxbitlist = [
	{ lbl="$T.sfxbit_0", val=0 },	//	icon="\ue40a", 
	{ lbl="$T.sfxbit_1", val=1 },	//	icon="\ue3a3", 
	{ lbl="$T.sfxbit_2", val=2 },	//	icon="\ue62d", 
]

//	cmd_screenfxon : 画面効果の表示
//	
eventcmd .. {
	category = 5
	key = "cmd_screenfxon"
	name = "$T.cmd_screenfxon"
	icon = "\ue43a"
	color = color5
	
	props = @( cmd){
		local a = [
			{ pid="sfxid", lbl="$T.lbl_effect", type=LIST, list=@() ScreenEffect.sfxlist.map( @( v)({ lbl=v.name, val=v.id, icon=v.icon })), refresh=true,
				set = @( prop, data, val){
					data[prop.pid] = val;
					local sfx = ScreenEffect.sfxmap[val];
					foreach( prop in sfx.props){
						if( "defval" in prop) data[prop.pid] <- prop.defval;
					}
				}
			}
		];
		if( !cmd["op"]){
			local sfx = ScreenEffect.sfxmap[cmd["sfxid"]];
			local sfxprops = sfx["props"];
			foreach( sp in sfxprops) a .. sp;
		}
		return a;
	}
	
	cmdinfo = @( cmd){
		local cmddef = RPGSystem.eventcmd[cmd.cmd], info;
		local props = fget( cmddef, "props", cmddef, cmd);
		local sfx = ScreenEffect.sfxmap[cmd["sfxid"]];
		info = "%S $T.lbl_time:%d" % (sfx.name, cmd.time);
		return {
			info = info,
		}
	}
	
	defval = { sfxid="flash0", time=400, color=0xffffffff, num=1 }
	
	exec = @( runner, cmd){
		runner.screenEffectOn( cmd);
	}
}


//	cmd_screenfxoff : 画面効果の消去
