//	cmd_mapasset : マップアセットの配置
//	配置番号、マップアセットの配置は専用UIを用意する！マクロの時には無理。今のところはマクロの事は考えない。
//	
eventcmd .. {
	category = 4
	key = "cmd_mapasset"
	name = "$T.cmd_mapasset"
	icon = "\ue8a7"
	color = color4

	width = 600
	
	props = [
		{ pid="idx", lbl="$T.lbl_place $T.lbl_index", type=SCALAR, range=[0,99], variable=1 },
		{ pid="asset", lbl="$T.lbl_placeasset", type=PLACEASSET, variable=1, cnt="cnt6.ui"}
		{ pid="parma", lbl="$T.lbl_placeparma", type=BOOL, variable=1 },
	]
	
	defval = @(){
		local ce = ::skstudio.editor["modaledit"];
		local pos = clone ce.data.pos;	//	現在編集中のイベントの配置位置。
		pos[3] = 0;	//	dirは0しとく
		return { asset={ resid="MA000", pos=clone pos, blend=1}, idx=0, parma=false }
	}

	cmdinfo = @( cmd){
		local cmddef = RPGSystem.eventcmd[cmd.cmd];
		local ii = propstr( props, cmd, "idx");
		local asd = ::conf._resource.map_asset[cmd.asset.resid];
		local info = sprintf( "%S ⇒ %S:%S", ii, cmd.asset.resid, lang( asd["name"]||"???"));
		return {
			info = info,
		}
	}

	edit = @( cv, cmd){
		local cmddef = ::RPGSystem.eventcmd[cmd.cmd];
		local props = fget( cmddef, "props", cmddef, cmd);
		::skstudio.freezeEditorView( true);
		local newcmd = PropertyEditPopupV.run( cv, cmddef, cmd);
		::skstudio.freezeEditorView( false);
		return newcmd;
	}
	
	exec = @( runner, cmd){
		runner.placeMapAsset( cmd);
	}
}

//	cmd_remasset : マップアセットの消去
//	
eventcmd .. {
	category = 4
	key = "cmd_remasset"
	name = "$T.cmd_remasset"
	icon = "\uf022"
	color = color4

	props = [
		{ pid="idx", lbl="$T.lbl_place $T.lbl_index", type=SCALAR, range=[0,99], variable=1 },
	]

	defval = @(){
		return { idx=0 }
	}

	cmdinfo = @( cmd){
		local props = fget( this, "props", this, cmd);
		return {
			info = propstr( props, cmd, "idx"),
		}
	}

	exec = @( runner, cmd){
		runner.removeMapAsset( cmd);
	}
}

local encountg( mapid){
	local e = ::skstudio.editor;
	return ( mapid == e["mapid"]) ? e.data["encount"] : ::conf.map[mapid]["encount"];
}

//	cmd_battle1 : バトル(グループ指定)
//	
eventcmd .. {
	category = 4
	key = "cmd_battle1"
	name = "$T.cmd_battle1"
	icon = "\uea2c"
	color = color4
	
	props = @( cmd){
		local e = ::skstudio.editor;
		local gidprop;
		if( cmd["_var"]["mapid"]){
			gidprop = { pid="gid", lbl="$T.lbl_group", type=SCALAR, range=(1,255), variable=true };
		}else{
			local ga = (encountg( cmd.mapid) || []).map( @( v, i){
				return { lbl=enemyGroupString( v["enemies"]), val=v.gid};
			});
			gidprop = { pid="gid", lbl="$T.lbl_group", type=LIST, list = ga, variable=true };
		}
		return [
			{ pid="mapid", lbl="$T.lbl_map", type=DATAID, datatype=["map"], variable=true }
			gidprop
			{ pid="bgmid", lbl="$T.lbl_bgm", type=RESID, restype = ["bgm"], nullable=true },
			{ pid="keeprset", lbl="$T.lbl_keeprset", type=BOOL},
			losefuncprop
		]
	}
	
	defval = @(){
		local mapid = defmapid();
		return { mapid=mapid, gid=1, losefunc=0, bgmid=null, keeprset=false }
	}
	
	cmdinfo = @( cmd){
		if( cmd["_var"]["mapid"]){
			return {
				info = sprintf( "%S - %S  ", varstr( cmd._var.mapid), cmd._var["gid"] ? varstr( cmd._var.gid) : cmd.gid);
			}
		}else{
			local map = ::conf.map[cmd.mapid];
			local ga = encountg( cmd.mapid);
			local enc = ga?.find( @( v) v.gid==cmd.gid);
			return {
				info = sprintf( "%S - %S  ", map["name"], enemyGroupString( enc["enemies"]));
			}
		}
	}

	exec = @( runner, cmd){
		runner.enterBattle( cmd);
	}
}

//	cmd_battle2 : バトル(詳細設定)
//	
eventcmd .. {
	category = 4
	key = "cmd_battle2"
	name = "$T.cmd_battle2"
	icon = "\uea2c"
	color = color4
	
	props = @( cmd){
		local e = ::skstudio.editor;
		return [
			{ pid="mapid", lbl="$T.lbl_battlemap", type=DATAID, datatype = ["map"] },
			{ pid="enemies", lbl="$T.lbl_enemies", type=ENEMYGROUP, cnt="cnt6.ui", notrk=1},
			{ pid="escape", lbl="$T.lbl_escapable", type=BOOL, defval = true, },
			{ pid="bgmid", lbl="$T.lbl_bgm", type=RESID, restype = ["bgm"] },
			{ pid="keeprset", lbl="$T.lbl_keeprset", type=BOOL},
			losefuncprop
		]
	}
	
	defval = @(){
		local mapid = "M800";
		return { mapid=mapid, losefunc=0, bgmid=null, keeprset=false, enemies=[{id="E000",x=0.0,z=0.0}],}
	}
	
	cmdinfo = @( cmd){
		local sb = (#StringBuffer()).clear();
		foreach( i,v in cmd["enemies"]){
			if( i) sb .. ", "
			local e = ::conf.enemy[v["id"]];
			sb .. (e?e.name : v["id"]);
		}
		return {info=string( sb),};
	}

	exec = @( runner, cmd){
		runner.enterBattle( cmd);
	}
}



