//	cmd_camwork : カメラワークの切り替え
//	type : 0=対象カメラ, 1=固定カメラ 
//	
local cameramarkers(){
	local marker = ::skstudio.editor["data"]["marker"];
	if( !marker) return null;
	local list = [];
	foreach( i, v in marker) if( v["type"]=="camera") list .. { lbl=v.name, val=i, };
	return list;
}

local camrestoreprop = { pid="restore", lbl="$T.lbl_restoreonend", type=LIST, list=[
	{ lbl:"$T.lbl_no", val=0, },
	{ lbl:"$T.lbl_yes", val=1, },
	{ lbl:"$T.lbl_transition", val=2, },
], variable=1};

local camvalmap = {
	[0] = { type=0, target=0, trans=0, restore=0 },
	[1] = { type=1, target=0, trans=0, zoom=0, pos=(0,0,0), hpb=(0,0,0), restore=0 },
	[2] = { type=2, mkid=null, trans=0, zoom=0, pos=(0,0,0), hpb=(0,0,0), restore=0 },
}

eventcmd .. {
	category = 5
	key = "cmd_camwork"
	name = "$T.cmd_camwork"
	icon = "\ue41e"
	color = color5

	defval = { type=1, target=1, dzoom=0, dpos=(0,0,0), dhpb=(0,0,0), restore=0, fade=0, easing=0, wait=true }

	props = @( cmd){
		local mklist = cameramarkers();
		local a = [{ pid="type", lbl="$T.lbl_type", type=LIST, refresh=true, list=[
				{ lbl="$T.lbl_reset", val=0, },
				{ lbl="$T.camwork_normal", val=1, },
				{ lbl="$T.camwork_fixed", val=2, disable=!length( mklist)},
			], set = @( prop, data, val){
				Table.clear( data) ... deepclone( camvalmap[val]);
				data.cmd <- "cmd_camwork";
				if( "mkid" in data) data.mkid ??= cameramarkers()[0]["val"];
			},
		}];
		switch( cmd.type){
		case 0:
			break;
		case 1:
			a .. { pid="target", lbl="$T.lbl_target", type=LIST, list=who2list, variable=1 };
			a .. { pid="dzoom", lbl="$T.lbl_zoom", type=SCALAR, ui="bar", range=(-10.0,10.0), q=10, variable=1 };
			a .. { pid="dpos", lbl="$T.lbl_focuspos", type=VEC3, range=(-10.0,10.0), q=100, variable=1 };
			a .. { pid="dhpb", lbl="$T.lbl_rotation", type=VEC3, range=(-180,180), variable=1 };
			break;
		case 2:
			if( mklist){
				a .. { pid="mkid", lbl="$T.lbl_marker", type=LIST, list=mklist, variable=1 };
			}else{
				a .. { pid="mkid", lbl="$T.lbl_marker", type=STRING, variable=2 };
			}
			a .. { pid="dzoom", lbl="$T.lbl_zoom", type=SCALAR, ui="bar", range=(-10.0,10.0), q=10, variable=1 };
			break;
		}
		a .. { pid="fade", lbl="$T.lbl_fadetime", type=SCALAR, range=(0,3000), ui="bar", barrange=(0,3000,100), variable=1 }
		a .. { pid="easing", lbl="$T.lbl_easing", type=LIST, list=easinglist, variable=1, hide=@( pl) pl.getParam( "fade")<=0 };
		a .. { pid="wait", lbl="$T.lbl_waitfade", type=BOOL, variable=1, hide=@( pl) pl.getParam( "fade")<=0 };
		if( cmd.type) a .. camrestoreprop;
		return a;
	}
	
	cmdinfo = @( cmd){
		local cmddef = RPGSystem.eventcmd[cmd.cmd], props = fget( cmddef, "props", cmddef, cmd);
		local info = propstr( props, cmd, "type");
		switch( cmd["type"]){
		case 2: info = info .. sprintf( " %S", propstr( props, cmd, "mkid"));
		}
		return {
			info = info,
		}
	}

	exec = @( runner, cmd){
		runner.setCamerawork( cmd);
	}
}

//	cmd_cammot : カメラにモーションを設定
//	※現在のカメラワークに対してのモーション設定。カメラワークが切り替わったらモーションも切り替わる。
//	※モーションは追加されていき、消えることは無い。何十個と追加されると多少重くなる可能性はあるが、カメラワークを切り替えれば全てリセットされる。
//	
eventcmd .. {
	category = 5
	key = "cmd_cammot"
	name = "$T.cmd_cammot"
	icon = "\uefeb"
	color = color5
	
	defval = { type=1, zoom=0, pos=(0,0,0), hpb=(0,0,0), playtype=0, time=3000, easing=0 }

	props = @( cmd){
		local a = [];
		local a = [{ pid="type", lbl="$T.lbl_type", type=LIST, refresh=true, list=[
				{ lbl="$T.lbl_reset", val=0, },
				{ lbl="$T.cammot_focus", val=1, },
				{ lbl="$T.cammot_eye", val=2, },
			], set = @( prop, data, val){
				data.type = val;
				if( val==0) data.playtype = 0;
			},
		}];
		a .. { pid="time", lbl="$T.lbl_time", type=SCALAR, range=(1,30000), q=1, ui="bar" };
		if( cmd.type != 0){
			a .. { pid="zoom", lbl="$T.lbl_zoom", type=SCALAR, ui="bar", range=(-10.0,10.0), q=10 };
			a .. { pid="pos", lbl="$T.lbl_position", type=VEC3, range=(-10.0,10.0), q=100 };
			a .. { pid="hpb", lbl="$T.lbl_rotation", type=VEC3, range=(-360,360), };
			a .. { pid="playtype", lbl="$T.lbl_playtype", type=LIST, list=[
				{ lbl="$T.lbl_normal", val=0, }
				{ lbl="$T.lbl_reverse", val=1, }
				{ lbl="$T.lbl_repeat", val=2, }
			]};
			a .. { pid="easing", lbl="$T.lbl_easing", type=LIST, list=easinglist, }
		};
		return a;
	}

	cmdinfo = @( cmd){
		local cmddef = RPGSystem.eventcmd[cmd.cmd], props = fget( cmddef, "props", cmddef, cmd);
		local info = propstr( props, cmd, "type");
		return {
			info = info,
		}
	}
	
	exec = @( runner, cmd){
		runner.addCameraMotion( cmd);
	}
}

//	cmd_actiontool : マニュアルアクション実行コマンド。移動、エモーション、サウンド、エフェクト等をスケジュールできる。
//	専用のエディタが必要なぐらい大規模になりそう。。。
//	アクションエディットダイアログみたいな
//	
eventcmd .. {
	category = 5
	key = "cmd_actiontool"
	name = "$T.cmd_actiontool"
	icon = "\ue912"
	color = color5
	
	defval = { event={actions=[],loop=false,wait=true,basepos=0,stack=0}, player={ actions=[],loop=false,wait=true,basepos=2},  }

	exec = @( runner, cmd){
		runner.startAction( cmd);
	}
	
	edit = @( cv, cmd){
		//	マップエディターのカスタムイベントの編集画面上でのみ実行可能。。。
		local e = ::skstudio.editor;
		local envdef = {
			bw = e.bw, event = e.modaledit.data, evid = e.tool.selgz.id, //	pageの情報はいらんかなー
			eventmap = e.data.event,	//	
		};
		return ManualActionDialog.run( envdef, cmd);
	}

	exec = @( runner, cmd){
		runner.playManualAction( cmd);
	}
}

