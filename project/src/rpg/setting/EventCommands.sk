//	cmd_voice : ボイス
//	
eventcmd .. {
	category = 5
	key = "cmd_voice"
	name = "$T.cmd_voice"
	icon = "\ue029"
	color = color5
	
	props = @(){
		local a = [];
		a .. { pid="ch", lbl="$T.lbl_channel", type=SCALAR, range=(0,15), ui="bar", variable=1 }
		a .. { pid="voiceid", lbl="$T.lbl_voiceactor", type=RESID, restype="voice", variable=1, refresh=1 },
		a .. { pid="voicekey", lbl="$T.lbl_voicekey", type=LIST, variable=1,
			list = @( pl){
				local vaid = pl.getParam( "voiceid");
				local va = ::conf._resource.voice[vaid];
				if( !va){
					return [{ lbl="$T.lbl_none", val=0, }];
				}else{
					local tb = {};
					foreach( lang in ::sakana.languagelist){
						foreach( v in va[lang.code]["list"]){
							local k = v.key;
							if( tb[k]) tb[k].lbl = tb[k].lbl..(lang.icon);
							else tb[k] <- { lbl=k.." "..lang.icon, val=k, }
						}
					}
					local a = Table.map( tb, @( v, i) v).sort( @( v) v.val);
					return a;
				}
			},
			set = @( prop, data, val){
				::soundmanager.checkctx();
				data[prop.pid] = val;
				local sp = ::getVoicePlayable( data["voiceid"], val);
				if( sp) sp.play();
			}
		};
		a .. { pid="vol", lbl="$T.lbl_gain", type=SCALAR, range=(0,200), ui="bar", variable=true }
		a .. { pid="play", lbl="", type=CUSTOMBUTTON, cnt="cnt5.ui", tostring="PLAY", icon="\ue745", ui="1", 
			edit=@( pl){
				::soundmanager.checkctx();
				local vaid = proplist.getParam( "voiceid"), vkey = proplist.getParam( "voicekey");
				local sp = ::getVoicePlayable( vaid, vkey);
				if( sp) sp.play();
			}
		};
		return a;
	}
	
	cmdinfo = @( cmd){
		local cmddef = RPGSystem.eventcmd[cmd.cmd];	//	this jan
		local props = fget( this, "props", this, cmd);
		local ai = propstr( props, cmd, "voiceid");
		local ki = propstr( props, cmd, "voicekey");
		local info = `$ai - $ki`;
		return {
			info = info,
		}
	}
	
	defval = { voiceid="VA000", voicekey="BTL_BEGIN1", vol=100, pan=0, ch=0 }
	
	exec = @( runner, cmd){
		runner.playVoice( cmd);
	}
}

//	cmd_light : ライト点灯
//	
eventcmd .. {
	category = 5
	key = "cmd_light"
	name = "$T.cmd_light"
	icon = "\uf02a"
	color = color5
	
	props = @( cmd){
		local a = [
			{ pid="who", lbl="$T.lbl_who", type=LIST, list=[
				{ lbl="$T.lbl_camera", val=0 }
				{ lbl="$T.who_player", val=1 }
				{ lbl="$T.who_event", val=2 }
			], variable=1, varbits=1|2|4|8 },
			{ pid="op", lbl="$T.lbl_op", refresh=1, type=LIST, list=[{ lbl="ON", val=0, }, { lbl="OFF", val=1, }, ]},
			{ pid="fadetime", lbl="$T.lbl_fadetime", type=SCALAR, range=(0,3000), q=1, ui="bar", barrange=(0,3000,100), variable=1 }
		];
		if( !cmd["op"]){
			a ... [
				{ pid="G1", lbl="", type=HEADER, cnt="header0.ui"},
				{ pid="lcol", lbl="$T.lbl_color", type=RGBA, defval=0xffffcc66, variable=1, }
				{ pid="lr", lbl="$T.lbl_size", type=SCALAR, range=(0.1,99.9), q=10, defval=10.0, variable=1, }
				{ pid="lpos", lbl="$T.lbl_position", type=VEC3, range=(-8.0,8.0), q=100, defval=(0.0,0.0,0.0), variable=1, }
				{ pid="lhpb", lbl="$T.lbl_direction", type=VEC2, range=(-180,180), defval=(0,0), variable=1, }
				{ pid="lspot", lbl="$T.lbl_litspot", type=VEC2, range=((0,180),(0,100)), defval=(180,10), ui="r", rlbl0="#", variable=1, }
				{ pid="flicker", lbl="$T.lbl_filcker", type=LIST, list=::lightflickerlist, defval=0, variable=1, }
			];
		}
		return a;
	}
	
	cmdinfo = @( cmd){
		local props = fget( this, "props", this, cmd);
		local wi = propstr( props, cmd, "who");
		local oi = propstr( props, cmd, "op");
		local info = `$wi ⇒ $oi`;
		return {
			info = info,
		}
	}
	
	defval = { who=0, op=0, fadetime=0, lcol=0xffffcc66, lpos=[0,0,0], lhpb=[0,0], lspot=(180,10), flicker=0 }
	
	exec = @( runner, cmd){
		runner.setLight( cmd);
	}
}

