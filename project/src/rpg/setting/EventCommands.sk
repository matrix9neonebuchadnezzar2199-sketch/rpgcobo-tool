	key = "cmd_inputui"
	name = "$T.cmd_inputui"
	icon = "\ue323"
	color = color3
	
	props = [
		{ pid="typeset", lbl="$T.cmd_inputui_typeset", type=VARIABLE, varbits=1|2|4, constbits=0, nullable=1 },
		{ pid="nameset", lbl="$T.cmd_inputui_nameset", type=VARIABLE, varbits=1|2|4, constbits=0, nullable=1 },
		{ pid="valset", lbl="$T.cmd_inputui_valset", type=VARIABLE, varbits=1|2|4, constbits=0, nullable=1 },
	]
	defval = { typeset="W", nameset="X", valset=null }
	
	cmdinfo = @( cmd){
		local cmddef = RPGSystem.eventcmd[cmd.cmd], props = fget( cmddef, "props", cmddef, cmd);
		local info = "";
		if( cmd["typeset"]) info = info .. sprintf( "$T.lbl_type => %S", propstr( props, cmd, "typeset"));
		if( cmd["nameset"]) info = info .. sprintf( " $T.lbl_name => %S", propstr( props, cmd, "nameset"));
		return {
			info = info,
		}
	}

	exec = @( runner, cmd){
		runner.inputUI( cmd);
	}
}

