		{ pid="cmdtgt", lbl="$T.cmdtgt", type=LIST, list=hpmptgtlist, variable=1, }		//	対象範囲。個人、パーティ、全て
		{ pid="charaid", lbl="$T.side_dbview_player", type=DATAID, datatype="player", variable=1, hide=@( pl) pl.getParam( "cmdtgt")!=TGT_PARTY_SINGLE }	//	↑で個人の場合の対象プレイヤー。データIDもしくはワーク、イベント、グローバル変数
		{ pid="op", lbl="$T.lbl_op", type=LIST, list=[
			{lbl="＋",val=0},
			{lbl="ー",val=1},
			{lbl="$T.lbl_clearall",val=2}
		],},
		{
			pid = "condbits"
			lbl = "$T.side_dbview_cond"
			type = CHECKBITS,
			list = @( pl) datalist( "cond")
			variable = 1,
			hide=@( pl) pl.getParam( "op")>=2
		},
		{ pid="ignoredead", lbl="$T.lbl_ignoredead", type=BOOL, variable=true },
		{ pid="showpop", lbl="$T.lbl_showpop", type=BOOL, variable=true },
	]
	
	defval = { cmdtgt=TGT_PARTY_ALL, charaid="P000", op=0, condbits=1, ignoredead=true, showpop=false, }
	
	cmdinfo = @( cmd){
		local cmddef = RPGSystem.eventcmd[cmd.cmd];
		local pi = cmd.cmdtgt==8 ? (conf.player[cmd.charaid]["name"]||cmd.charaid) : propstr( cmddef.props, cmd, "cmdtgt");
		local oi = propstr( cmddef.props, cmd, "op");
		local ji = condbitsstr( cmd.condbits);// propstr( cmddef.props, cmd, "condbits");
		local info = sprintf( "%S  %S %S", pi, oi, cmd.op>=2?"":ji);
		return {
			info = info,
		}
	}
	
	exec = @( runner, cmd){
		runner.condOp( cmd);
	}
}


//	cmd_charainfo : キャラ情報取得
//	
eventcmd .. {
	category = 2
	key = "cmd_charainfo"
	name = "キャラ情報取得"
	icon = "\ue851"
	color = color2

	props = @( cmd){
		local a = [
			{ pid="charaid", lbl="$T.side_dbview_player", type=DATAID, datatype=["player","enemy"], variable=1, },
			{ pid="key", lbl="$T.lbl_info", type=LIST, list=@() RPGSystem.charainfodef._list.map( @(v) +{ lbl=v.lbl, val=v.key}), refresh=1,
				set = @( prop, data, val){
					local cidef = RPGSystem.charainfodef[val];
					data.key <- val;
					if( cidef["props"]) setDefaultProperties( cidef.props, data);
				},
			},
		];
		local cidef = RPGSystem.charainfodef[cmd["key"]];
		if( cidef["props"]) a ... cidef.props;
		a .. { pid="retvar", lbl="$T.cmd_macro_retvar", type=VARIABLE, varbits=1|2|4, constbits=0, };
		return a;
	}
	
	defval = { charaid="P000", key="dead", retvar="W", }
	
	cmdinfo = @( cmd){
		local cmddef = RPGSystem.eventcmd[cmd.cmd], props = fget( cmddef, "props", cmddef, cmd);
		local cidef = RPGSystem.charainfodef[cmd["key"]];
		local pi = propstr( props, cmd, "charaid");
		local ii = propstr( props, cmd, "key");
		local ci = cidef["info"] && cidef.info( cmd);
		local info = sprintf( "%S.%S ⇒ %S", pi, ci||ii,cmd.retvar);
		return {
			info = info,
		}
	}
	
	exec = @( runner, cmd){
		return runner.getCharaInfo( cmd);
	}
}


///////////////////////////////////////////////////////////////////////////////////
//	画面表示・入力処理

//	cmd_showmsg : メッセージを表示する。
//	※このコマンドは単にcmd_showuiの中のメッセージ表示を抜き出して分かりやすいように配置しただけのもの。
//	
eventcmd .. {
	category = 3
	key = "cmd_showmsg"
	name = "$T.cmd_showmsg"
	icon = "\ue0b7"
	color = color3

	width = 600
	
	props = @( cmd){
		local a = [];
		a .. { pid="key", lbl="$T.lbl_ui", type=LIST, refresh=true, list=@() RPGSystem.ui._list.map( @( v){	//	"message"タイプの登録uiキー
				return v["type"]=="message" ? { lbl=v.lbl, val=v.key } : undefined;
			}), set = @( prop, data, val){
				Table.clear( data);		//	全てのデータを一度さっぱりと消去
				data.cmd <- "cmd_showmsg";	//	消えちゃいけないデータもある。。。
				data[prop.pid] <- val;
				local defval = deepclone( fget( RPGSystem.ui[val], "defval"));	//	デフォルトデータ
				data ... defval;
			}
		};
		local uidef = RPGSystem.ui[cmd["key"]];
		local props = fget( uidef, "props", uidef, cmd).filter( @( v) v.pid!="op");		//	opは常に表示
		a ... props;
		return a;
	}
	
	defval = { key = "message_talk", text = "*message*", name = "", uiclose = 2, }

	cmdinfo = @( cmd){
		local info = ::RPGSystem.ui[cmd.key].lbl;
		if( cmd["name"]) info = info.." - "..cmd.name;
		return {
			info = info,
			extra = cmd["_var"]["text"]? varstr( cmd._var.text) : cmd.text,
		}
	}
	
	exec = @( runner, cmd){
		runner.showMessage( cmd);
	}
}

//	cmd_choices : 選択肢を表示してその数だけ分岐を入れる
//	
eventcmd .. {
	category = 3
	key = "cmd_choices"
	name = "$T.cmd_choices"
	icon = "\ue9bd"
	color = color3
	
	props = @( cmd){
		local a = [
			{
				pid="num", lbl=tmpl( T.tmpl_num_v, {v="$T.lbl_choices"}), type=SCALAR, range=(1,8), refresh=1,
				get = @( prop, data) length( data.cmdblocks),
				set = @( prop, data, val){
					data.cmdblocks.resize( val);
					foreach( i,v in data.cmdblocks){
						if( !v) data.cmdblocks[i] = [];
					}
					return val;
				}
			}
		];
		foreach( i, v in cmd.cmdblocks){
			a .. { pid="text"..i, lbl="${T.lbl_choice}"..i, type=STRING, };
		}
		a .. { pid="backenable", lbl="$T.lbl_backenable", type=BOOL, };
		return a;
	}
	
	defval = {
		text0 = "$T.yes"
		text1 = "$T.no"
		backenable = false
		cmdblocks = [[],[]]
	}	//	エディターで辞書解決してしまうので$TでOK
	
	cmdinfo = @( cmd){
		local t = {topblkname = sprintf( "%d: %S", 1, cmd.text0)};
		if( length( cmd.cmdblocks)>1){
			t.blknames <- [];
			for( local l = 1; l < length( cmd.cmdblocks); l ++){
				t.blknames .. sprintf( "%d: %S", l+1, cmd["text"..l]);
			}
		}
		return t;
	};

	//	選択肢配列をswitch文コードに変換する。
	parsecode = @( cmd){
		//	switch( ~~~)の部分
		push( "switch( showChoices( locals[%S])){" % newlocal( cmd)).lf();
		foreach( i, cmdblock in cmd.cmdblocks){
			push( "case %S:" % i);
			parseblock( cmdblock);
			lf().push( "break;").lf();
		}
		push( "}").lf();
	}
}

local picactionlist = [
	{ lbl="$T.lbl_show", val=0, }	//	表示
	{ lbl="$T.lbl_delete", val=1, }	//	消去
];

//	cmd_shopwpic : ピクチャ表示操作
//	
eventcmd .. {
	category = 3
	key = "cmd_showpic"
	name = "$T.cmd_showpic"
	icon = "\ue416"
	color = color3
	
	props = @( cmd){
		local pc = ::conf._resource.event_pic[cmd["picid"]] || ::conf._resource.enemy_pic[cmd["picid"]];
		local a = [
			{ pid="idx", lbl="$T.lbl_picture $T.lbl_index", type=SCALAR, range=[0,99], variable=1 },
			{ pid="op", lbl="$T.lbl_operation", type=LIST, list=picactionlist, refresh=1 },
		];
		if( cmd.op==0){
			a ... [
				{ 
					pid="picid", lbl="$T.side_res_event_pic", type=RESID, restype=["event_pic","enemy_pic"], nullable=1, variable=1, refresh=1,
					set = @( prop, data, val){
						data[prop.pid] <- val; data.aniid <- null;
					}
				},
				{ pid="aniid", lbl="$T.lbl_anime", type=LIST, variable=1,
					list = [ {lbl="$T.lbl_none", val=null, }, ...pc["animap"]?.map( @( v) ({ lbl=v.id, val=v.id}))], 
					hide = !length( pc["animap"]),
				},
				{ pid="pos", lbl="$T.lbl_position", type=VEC2, range=[-1280,2560], variable=1 },
				{ pid="scale", lbl="$T.lbl_scale", type=SCALAR, range=[0,1000], ui="bar", barrange=(0,400,10), variable=1 },
				{ pid="rot", lbl="$T.lbl_rotation", type=SCALAR, range=[-3600,3600], ui="bar", barrange=(-360,360,5), variable=1 },
				{ pid="col", lbl="$T.lbl_color", type=RGBA, defval=0xffffffff, variable=1, }
			];
		}
		a .. { pid="fade", lbl="$T.lbl_fadetime", type=SCALAR, range=(0,3000), ui="bar", barrange=(0,3000,100), variable=1 }
		if( cmd.op==0) a .. { pid="easing", lbl="$T.lbl_easing", type=LIST, list=easinglist, variable=1, hide=@( pl) pl.getParam( "fade")<=0 };
		a .. { pid="wait", lbl="$T.lbl_waitfade", type=BOOL, variable=1, hide=@( pl) pl.getParam( "fade")<=0 };
		return a;
	}
	
	defval = {
		idx=0, picid="PC000", pos=[640,360], scale=100, rot=0, op=0, fade=0, wait=true, easing=0, aniid=null
	}
	
	cmdinfo = @( cmd){
		local cmddef = RPGSystem.eventcmd[cmd.cmd], props = fget( cmddef, "props", cmddef, cmd);
		local op = propstr( props, cmd, "op"), info;
		local w = cmd["wait"] ? "⌛" : "";
		if( !cmd["op"]){
			local pic = ::conf._resource.event_pic[cmd.picid];
			info = sprintf( "%S [%d]  %S   %S", op, cmd.idx, cmd.picid, w);
		}else{
			info = sprintf( "%S [%d]  %S", op, cmd.idx, w);
		}
		return {
			info = info,
		}
	}
	
	exec = @( runner, cmd){
		runner.showPicture( cmd);
	}

	edit = @( cv, cmd){
		local props = clone fget( cv.cmddef, "props", cv.cmddef, cv.cmd);
		if( !length( props)) return;
		local cmddef = ::RPGSystem.eventcmd[cv.cmd.cmd];
		local newcmd = PicPropertyEditPopupV.run( cv, cmddef, cv.cmd);
		return newcmd;
	}
}

//	cmd_showui : UI表示操作。色々なUIを汎用的に表示する
//	
eventcmd .. {
	category = 3
	key = "cmd_showui"
	name = "$T.cmd_showui"
	icon = "\ue1bd"
	color = color3
	
	props = @( cmd){
		local a = [];
		a .. {
			lbl="$T.lbl_ui", pid="key", refresh=1, type=LIST, cnt = "cnt8.ui"
			list=@(){
				return RPGSystem.ui._list.map( @( v, i) v["hide"]?undefined : { lbl=v.lbl, val=v.key, icon=v["icon"]});
			},
			set = @( prop, data, val){
				Table.clear( data);		//	全てのデータを一度さっぱりと消去
				data.cmd <- "cmd_showui";	//	消えちゃいけないデータもある。。。
				data[prop.pid] <- val;
				local defval = deepclone( fget( RPGSystem.ui[val], "defval"));	//	デフォルトデータ
				data ... defval;
			}
			refresh=true,	//	set時にプロパティリストをリフレッシュ
		}
		local uidef = RPGSystem.ui[cmd["key"]];
		local props = fget( uidef, "props", uidef, cmd);
		a ... props;
		return a;
	}
	
	defval = {
		key = "info_top"
		text = "*INFO..."
		time = 2000
	}
	
	cmdinfo = @( cmd){
		local uidef = RPGSystem.ui[cmd.key];
		local info = uidef["lbl"] || "???";
		if( "op" in cmd){
			local props = fget( uidef, "props", uidef, cmd);
			info = sprintf( "%S → %S", info, propstr( props, cmd, "op"));
		}
		return {
			info = info,
		}
	}
	
	exec = @( runner, cmd){
		runner.showUI( cmd);
	}
}

local customui_oplist = [
	{ lbl="$T.uiop_show", val="show", }
	{ lbl="$T.uiop_hide", val="kill", }
	{ lbl="$T.uiop_action", val="action", }
	{ lbl="$T.uiop_value", val="value", }
];

local customui_layerlist = [
	{ lbl="info $T.lbl_layer", val="info", }
	{ lbl="menu $T.lbl_layer", val="menu", }
	{ lbl="message $T.lbl_layer", val="message", }
];

local customui_defmap = {
	"show" = { pos = { x=640, y=360 }, uipath = "", layer = "menu", action = "show", wait = true },
	"kill" = { action = "hide", wait = true },
	"action" = { action = "action", wait = true },
	"value" = { target = "", valtype = 0, val = "TEXT"},
}

//	cmd_customui : カスタムUI操作
//	op : 表示、消去、値設定、アクション、
//	
eventcmd .. {
	category = 3
	key = "cmd_customui"
	name = "$T.cmd_customui"
	icon = "\ue1bd"
	color = color3
	
	props = @( cmd){
		local a = [
			{ pid="idx", lbl="$T.lbl_ui $T.lbl_index", type=SCALAR, range=[0,99], variable=1 },
			{ pid="op", lbl="$T.lbl_op", type=LIST, refresh = 1, list = customui_oplist,
				set = @( prop, data, val){
					local idx = data["idx"];
					Table.clear( data) ... customui_defmap[val];
					data.cmd <- "cmd_customui"; data.idx <- idx; data.op <- val;
				}
			},
		];
		switch( cmd["op"]){
		case "show":
			a .. { pid="uipath", lbl="$T.lbl_uipath", type=PATH, variable=true }
			a .. { pid="layer", lbl="$T.lbl_layer", type=LIST, variable=true, list=customui_layerlist }
			a .. { pid="pos", lbl="$T.lbl_position", type=UIPOSITION, variable=true }
			a .. { pid="action", lbl="$T.lbl_action", type=STRING, variable=1 }
			a .. { pid="wait", lbl="$T.lbl_waitaction", type=BOOL, variable=1 }
			break;
		case "kill":
			a .. { pid="action", lbl="$T.lbl_action", type=STRING, variable=1 }
			a .. { pid="wait", lbl="$T.lbl_waitaction", type=BOOL, variable=1 }
			break;
		case "action":
			a .. { pid="action", lbl="$T.lbl_action", type=STRING, variable=1 }
			a .. { pid="wait", lbl="$T.lbl_waitaction", type=BOOL, variable=1 }
			break;
		case "value":
			a .. { lbl="$T.lbl_viewname", pid="target", type=STRING, variable=1, };
			a .. {
				lbl="$T.lbl_type", pid="valtype", refresh=1, type=LIST,
				list = [{lbl="$T.lbl_text", val=0, }, {lbl="$T.lbl_imgpath", val=1, }, {lbl="$T.lbl_etc", val=2, }],
				set = @( prop, data, val){
					data.valtype = val;
					delete data["text"]; delete data["path"]; delete data["rvar"];
					local maps = #[{text="TEXT"},{path="/resource/event_pic/"},{rvar="\tW"}];
					data ... maps[val];
				}
			};
			switch( cmd["valtype"]){
			case 0: a .. { lbl="$T.lbl_text", pid="text", type=MESSAGE, }; break;
			case 1: a .. { lbl="$T.lbl_imgpath", pid="path", type=PATH, }; break;
			case 2: a .. { lbl="$T.lbl_var", pid="rvar", type=VARIABLE, varbits=1|2|4|8|16, constbits=8 }; break;
			}
			break;
		}
		return a;
	}
	
	defval = { idx = 0, op = "show", ...customui_defmap.show }
	
	cmdinfo = @( cmd){
		local cmddef = RPGSystem.eventcmd[cmd.cmd], props = fget( cmddef, "props", cmddef, cmd);
		local idx = propstr( props, cmd, "idx");
		local op = propstr( props, cmd, "op");
		local info = sprintf( "[%S] %S", idx, op);
		local w = cmd["wait"] ? "⌛" : "";
		switch( cmd["op"]){
		case "show": info = info .. sprintf( " %S %S", cmd["uipath"], w); break;
		case "value": info = info .. sprintf( " %S ⇐ %S", cmd["target"], cmd["text"] || cmd["path"] || propstr( props, cmd, "rvar")); break;
		case "action": info = info .. sprintf( " %S %S", cmd["action"], w); break;
		}
		return {
			info = info,
		}
	}
	
	exec = @( runner, cmd){
		runner.customUI( cmd);
	}
}

//	UIイベントの入力。入力を待つために1フレームのウェイトが入る。
//	ただし、キューにイベントが複数溜まっている場合は吐き出しきるまでsuspendは行われない。
//	
