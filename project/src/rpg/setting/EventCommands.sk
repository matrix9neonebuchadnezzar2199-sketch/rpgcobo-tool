//	cmd_settingget : 設定の取得
eventcmd .. {
	category = 1
	key = "cmd_settingget"
	name = "$T.cmd_settingget"
	icon = "\uf05e"
	color = color1
	
	props = [
		{ lbl="$T.lbl_settingitem", pid="pid", type=LIST, list=@() RPGSystem.settingprops.map( @( v){
			if( v["proptype"]!="status") return undefined;
			return { lbl=v.lbl, val=v.pid };
		}) .. "-" ... RPGSystem.stageprops.map( @( v) +{ lbl=v.lbl, val=v.pid})},
		{ pid="retvar", lbl="$T.cmd_macro_retvar", type=VARIABLE, varbits=1|2|4, constbits=0, },
	]
	cmdinfo = @( cmd){
		local props = fget( this, "props", this, cmd);
		local pi = propstr( props, cmd, "pid");
		local info = sprintf( "%S ⇒ %S", pi, cmd.retvar);
		return {
			info = info,
		}
	}

	defval = { pid="menu_item", retvar="W" }

	exec = @( runner, cmd){
		runner.getSetting( cmd);
	}
}


