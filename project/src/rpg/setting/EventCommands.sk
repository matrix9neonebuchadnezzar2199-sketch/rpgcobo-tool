function condbitsstr( bits){
	local a = datalist( "cond");
	local sb = StringBuffer();
	foreach( i, v in a){
		i ??= v["idx"];
		if( bitget( bits, i)){
			local icon = (length(v["icon"]) ? v["icon"]:char( 0xf123+i));
			sb .. icon;
		}
	}
	return string( sb);
}

//	cmd_condop : コンディションの操作
//	
eventcmd .. {
	category = 2
	key = "cmd_condop"
	name = "$T.cmd_condop"
