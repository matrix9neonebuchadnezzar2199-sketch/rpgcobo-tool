import PropertyType;
import RPGPropertyType;
import CommandTargetType;

local eventcmd = RPGSystem.eventcmd;

/////////////////// 共通パラメータ、関数

local color0 = (0x00A3D9ff, 0x73DCFFff)
local color1 = (0xFF9326ff, 0xFFB973ff)
local color2 = (0x00D9D9ff, 0x99FFFFff)
local color3 = (0xCCA4FFff, 0xDFBFFFff)
local color4 = (0xD9D900ff, 0xFFFF99ff)
local color5 = (0x00B285ff, 0x99FFE5ff)
local color6 = (0xFF6D6Dff, 0xFFBFBFff)

//	計算操作
local compoplist = [
	{ lbl="＝", val="=" }
	{ lbl="＋", val="+=" }
	{ lbl="ー", val="-=" }
	{ lbl="×", val="*=" }
	{ lbl="÷", val="/=" }
	{ lbl="％", val="%=" }
]

//	whoの値 : "player", "event", "selchara", "ui", "screen", evid, 
//	使ってない！
// local wholist = [
// 	{ lbl="$T.who_none", val=0 }
// 	{ lbl="$T.who_player", val=1 }
// 	{ lbl="$T.who_event", val=2 }
// 	{ lbl="$T.who_specify", val=3 }
// ]

//	プレイヤー、イベント、選択キャラ(バトル時)
local who2list = [
	{ lbl="$T.who_player", val=1 }
	{ lbl="$T.who_event", val=2 }
]

//	条件プロパティ
local reqsprop = { pid = "reqs", lbl = "$T.lbl_reqs", type = REQUIREMENTS, cnt="cnt6v.ui" }

//	勝敗処理
local losefuncprop = {
	pid = "losefunc", lbl = "$T.losefunc", type = LIST, list = [
		{ lbl="$T.losefunc0", val=0, },
		{ lbl="$T.losefunc1", val=1, },
		{ lbl="$T.losefunc2", val=2, },
	],
}

//	イージング
local easinglist = [
	{ lbl="Linear", val=0, }
	{ lbl="Ease in", val=1, }
	{ lbl="Ease out", val=2, }
	{ lbl="Ease in-out", val=3, }
];

//	ユーティリティ
local defmapid(){
	local mapid = ::skstudio.editor["mapid"];
	if( !mapid){
		for( local l = 1;l < 900;l ++){
			local mid = "M%03d" % l;
			if( ::conf.map[mid]){ mapid = mid; break;}
		}
	}
	return mapid;
}

local proplbl( props, pid){
	return props.find( @( v) v.pid==pid)["lbl"] || "";
}

//	
local propstr( props, cmd, pid){
	if( cmd["_var"][pid]) return varstr( cmd._var[pid]);
	local prop = props.find( @( v) v.pid==pid);
	return getPropertyText( prop, cmd);
}

local geteventlist( cv){
	while( cv){
		if( cv.ref instanceof EventCommandList) return cv.ref;
		cv = cv.parent;
	}
}



////////////////// コマンド定義開始

///////////////////////////////////////////////////////////////////////////////////
//	一般処理

//	cmd_wait : 指定した秒数（スクリプト可）ウェイトを入れる。〇
//	
eventcmd .. {
	category = 0
	key = "cmd_wait"
	name = "$T.cmd_wait"
	icon = "\ue034"	//	e1a2, e0ea
	color = color0

	props = [
		{ pid="time", lbl="$T.lbl_time", type=SCALAR, range=(0,100000), ui="bar", barrange=(0,3000,20), variable=1, },
	]

	// edit = @( cv, cmd){
	// }
	
	cmdinfo = @( cmd)({
		info = varstr( cmd.time),
	})
	
	defval = { time = 1000 }

	exec = @( runner, cmd){
		sleep( cmd.time);
	}
}

//	cmd_ret : この処理を終了し一つ前の処理に戻る。※cmd_retの戻り値はイベントでは使用されない〇
//	
eventcmd .. {
	category = 0
	key = "cmd_ret"
	name = "$T.cmd_ret"
	icon = "\ue9ba"
	color = color0
	
	defval = {}
	
	props = []

	parsecode = @( cmd){
		push( "retval" in cmd ? sprintf( "return (%S);", cmd.retval) : "return;").lf();
	}
}

//	cmd_if : 条件分岐。〇
//	
eventcmd .. {
	category = 0
	key = "cmd_if"
	name = "$T.cmd_if"
	icon = "\ueb26"
	color = color0
	subblocks = true

	props = [
		reqsprop
		{
			pid="else", lbl="$T.cmd_if_else", type=BOOL,
			get = @( prop, data) length( data.cmdblocks)==2,
			set = @( prop, data, val){
				if( val){ if( !data.cmdblocks[1]){data.cmdblocks[1] <- []; }}
				else delete data.cmdblocks[1];
				return val;
			}
		}
	]
	
	defval = { reqs = [{ lvar="A", op="=", rvar=true, }], cmdblocks = [[]] }
	
	cmdinfo = @( cmd)({
		info = eventRequirementText( cmd.reqs),
		blknames = length( cmd.cmdblocks)>1 ? ["$T.cmd_if_else"] : null,
	})

	parsecode = @( cmd){
		push( "if( "); parsereqs( cmd.reqs); push( ")");
		parseblock( cmd.cmdblocks[0]);		//	then
		if( cmd.cmdblocks[1]){		//	else
			push( "else");
			parseblock( cmd.cmdblocks[1]);
		}
		lf();
	}
}

//	cmd_loop : ループ処理。〇
//	ハードループ指定をするとループ時にウェイトを入れない（危険）。ソフトループはsleep(4)が入り、60fpsだと4ループ。
eventcmd .. {
	category = 0
	key = "cmd_loop"
	name = "$T.cmd_loop"
	icon = "\ue9d6"
	color = color0
	subblocks = true
	
	props = [reqsprop]

	defval = { reqs = [{ lvar="A", op="=", rvar=true, }], cmdblocks = [[]] }
	
	cmdinfo = @( cmd)({
		info = eventRequirementText( cmd.reqs),
	})

	parsecode = @( cmd){
		push( "while( "); parsereqs( cmd.reqs); push( "){").indent( 1).lf();
		parseblock( cmd.cmdblocks[0], false);
		push( "sleep( 4);").lf();		//	ソフトループ
		indent( -1).push( "}").lf();
	}
}

//	cmd_script : 任意のスクリプト実行。〇
//	
eventcmd .. {
	category = 0
	key = "cmd_script"
	name = "$T.cmd_script"
	icon = "\ueb8e"
	color = color0
	
	props = [
		{ pid="code", lbl="$T.lbl_script", type=SCRIPT, multiline=8, cnt="cnt6v.ui" }
	]

	cmdinfo = @( cmd){
		local c = cmd.code, i = c.indexOf( "\n");
		return { info = i<0 ? c : c.substring( 0, i)};
	}

	defval = { desc = "SCRIPT", code = "" }

	//	parsecodeで
	exec = @( runner, cmd){
		local fn = ::compilescript( cmd.code);
		~( fn, runner);	//	RPGEventRunnerをthisにして実行
	}
}

//	cmd_macro : マクロ実行。〇
//	
eventcmd .. {
	category = 0
	key = "cmd_macro"
	name = "$T.cmd_macro"
	icon = "\ueb8e"
	color = color0
	
	props = [
		{ pid="macroid", lbl="$T.lbl_macro", type=DATAID, datatype = ["macro"] }
		{ pid="retvar", lbl="$T.cmd_macro_retvar", type=VARIABLE, varbits=1|2, constbits=0, nullable=1 },
	]

	cmdinfo = @( cmd){
		local cmddef = RPGSystem.eventcmd[cmd.cmd];
		local info = sprintf( "%S:%S", cmd.macroid, ::conf.macro[cmd.macroid]["name"]||"???");
		if( cmd.retvar) info = info .. " ⇒ " .. propstr( cmddef.props, cmd, "retvar");
		return {
			info = info,
		}
	}

	defval = { macroid = "X000", retvar = null }

	exec = @( runner, cmd){
		runner.callMacro( cmd);
	}
}

//	cmd_iterate : 反復処理
//	配列変数、バトル時プレイヤー一覧、バトル時エネミー一覧、イベント一覧、
//	
eventcmd .. {
	category = 0
	key = "cmd_iterate"
	name = "$T.cmd_iterate"
	icon = "\ue240"
	color = color0
	subblocks = true
	
	props = [
		{ pid="itervar", lbl="$T.cmd_iterate_itervar", type=VARIABLE, varbits=31, constbits=0, },
		{ pid="valset", lbl="$T.cmd_iterate_valset", type=VARIABLE, varbits=1|2|4, constbits=0, nullable=1 },
		{ pid="keyset", lbl="$T.cmd_iterate_keyset", type=VARIABLE, varbits=1|2|4, constbits=0, nullable=1 },
		{ pid="skipnull", lbl="$T.cmd_iterate_skipnull", type=BOOL, },
	];

	defval = { itervar="A", valset="W", keyset=null, cmdblocks = [[]], skipnull=true }
	
	cmdinfo = @( cmd){
		local cmddef = RPGSystem.eventcmd[cmd.cmd], props = fget( cmddef, "props", cmddef, cmd);
		local info = sprintf( "%S => ", propstr( props, cmd, "itervar"));
		if( cmd["valset"]) info = info .. sprintf( " $T.lbl_value: %S", propstr( props, cmd, "valset"));
		if( cmd["keyset"]) info = info .. sprintf( " $T.lbl_key: %S", propstr( props, cmd, "keyset"));
		return {
			info = info,
		}
	}

	parsecode = @( cmd){
		push( "foreach( i, v in ::getvar( \"%S\", this)){" % cmd.itervar).indent( 1).lf();
		if( cmd["skipnull"]) push( "if( v==null||v==undefined) continue;").lf();
		if( cmd["valset"]) push( "%S = v;" % cmd.valset).lf();
		if( cmd["keyset"]) push( "%S = i;" % cmd.keyset).lf();
		parseblock( cmd.cmdblocks[0], false);
		indent( -1).push( "}").lf();
	}
}

//	cmd_label : この場所にジャンプできるラベルを配置する〇
//	
eventcmd .. {
	category = 0
	key = "cmd_label"
	name = "$T.cmd_label"
	icon = "\ue937"
	color = (0xeeeeeeff,0xeeeeeeff)

	props = [
		{ pid="label", lbl="$T.lbl_name" type=STRING }
	]

	cmdinfo = @( cmd)({
		info = cmd.label,
	})

	defval = { label="LABEL" }

	parsecode = @( cmd){
		addLabel( cmd.label);
		push( "%S:" % cmd.label).lf();
	}
}

local collectlabels( cmds, a){
	foreach( cmd in cmds){
		if( cmd.cmd == "cmd_label") a .. cmd.label;
		if( cmd["cmdblocks"]){
			foreach( cb in cmd.cmdblocks){
				collectlabels( cb, a);
			}
		}
	}
	return a;
}

//	cmd_jump : ラベルで指定した場所に処理をジャンプする〇
//	
eventcmd .. {
	category = 0
	key = "cmd_jump"
	name = "$T.cmd_jump"
	icon = "\ue01f"
	color = color0

	props = [
		// reqsprop,
		{ pid="label", lbl="$T.cmd_label" type=LIST, list=@( pl){
			//	※編集中のコマンドリストが取れないとラベルのリストは作れない。。。
			local e = ::skstudio.editor;
			local cmdlist = e.findChild( "cmdlist");
			if( !cmdlist) return #[];
			return collectlabels( cmdlist.ref.rootblkview.cmdblock, ["_START_"]).map( @(v)({ lbl=v, val=v, }));
		}, }
	]

	cmdinfo = @( cmd){
		local info = cmd.label;
		// if( length( cmd["reqs"])) info = sprintf( "(%S)? %S", eventRequirementText( cmd.reqs), info);
		return { info = info, }
	}

	defval = { label="_START_" }

	parsecode = @( cmd){
		push( "goto %S;" % cmd.label).lf();
	}
}

//	cmd_pagejump : 指定したページに処理をジャンプする
//	※存在しないページにジャンプは無視される。
//	※ワーク変数は現在のものを引きつぐ。
//	※ページはイベント実行中は固定される。イベント後に再度ページ選択処理が起きたタイミングで変化する。
//	※マクロでは使用不能。命令は無視される。
eventcmd .. {
	category = 0
	key = "cmd_pagejump"
	name = "$T.cmd_pagejump"
	icon = "\ue01f"
	color = color0

	props = [
		{ pid="page", lbl="$T.cmd_page" type=LIST, list=@( pl){
			local e = pl.ref, pa = e.data.page;	//	CustomEventEditor
			local n = Math.max( 8, length( pa));
			local a = [];
			for( local l = 0;l < n;l ++){
				local p = pa[l];
				a .. { icon=char(0xf124+l), lbl=p?(length(p["memo"])?p.memo:"ページ"..(l+1)):"---", val=l};
			}
			return a;
		}, }
	]

	cmdinfo = @( cmd){
		local info = "$T.page "..(cmd.page+1);
		return { info = info, }
	}

	defval = { page=0 }

	exec = @( runner, cmd){
		runner.pageJump( cmd);
	}
}

//	cmd_getmain : 並列イベントを一時的にメインイベントに昇格させる
//	※他のイベントがメインイベントの場合、メニューが開かれている場合は昇格できない。
//	　成功・失敗はWに入る？
eventcmd .. {
	category = 0
	key = "cmd_getmain"
	name = "$T.cmd_getmain"
	icon = "\uf0fb"
	color = color0
	
	props = [
		{ pid="op", lbl="$T.lbl_operation" type=BOOL, },
		{ pid="time", lbl="$T.lbl_timeout", type=SCALAR, range=(0,100000), ui="bar", barrange=(0,3000,20), hide=@(pl) !pl.getParam( "op") },
		{ pid="retvar", lbl="$T.cmd_getmain_retvar", type=VARIABLE, varbits=1|2, constbits=0, nullable=0, hide=@(pl) !pl.getParam( "op") },
	]

	defval = { op=true, time=1000, retvar="Z" }
	
	cmdinfo = @( cmd){
		local info = sprintf( "%S", cmd["op"]?"ON":"OFF");
		return {info=info};
	}

	exec = @( runner, cmd){
		runner.getToMainEvent( cmd);
	}
}

//	cmd_comment : コメントを挿入する。処理は全く行われない〇
//	
eventcmd .. {
	category = 0
	key = "cmd_comment"
	name = "$T.cmd_comment"
	icon = "\ue88f"
	color = (0xccccccff,0xbbbbbbff)
	
	props = [
		{ pid="rem", lbl="$T.lbl_comment" type=STRING, multiline=4, cnt="cnt6v.ui" }	//	翻訳対象外
	]

	defval = { rem="comment..." }
	
	cmdinfo = @( cmd)({
		extra = cmd["rem"],
	})

	parsecode = @( cmd){
		push( "/* "); push( rem); push( " */").lf();
	}
}

///////////////////////////////////////////////////////////////////////////////////
//	変数処理

//	cmd_compute : 計算を行い結果を変数に格納〇
//	
eventcmd .. {
	category = 1
	key = "cmd_compute"
	name = "$T.cmd_compute"
	icon = "\uea5f"
	color = color1

	props = [
		{ pid="lvar", lbl="$T.lbl_lvar", type=VARIABLE, varbits=1|2|4, constbits=0 }		//	代入可能な左辺値＝ワーク、イベント、グローバル
		{ pid="op",   lbl="$T.lbl_arithop", type=LIST, list=compoplist }		//	
		{ pid="rvar", lbl="$T.lbl_rvar", type=VARIABLE, varbits=31, constbits=15, datatype="all" }		//	全て
	]

	defval = { lvar="W", op="=", rvar=0 }

	cmdinfo = @( cmd){
		local cmddef = RPGSystem.eventcmd[cmd.cmd];
		return {
			info = sprintf( "%S %S %S", propstr( cmddef.props, cmd, "lvar"), propstr( cmddef.props, cmd, "op"), propstr( cmddef.props, cmd, "rvar")),
		}
	}
	
	parsecode = @( cmd){
		push( sprintf( "%S %S ::getvar( %S, this);", cmd.lvar, cmd.op, encodeJSON( cmd.rvar))).lf();
	}
}

//	cmd_arrayop : 配列の操作〇
//	
eventcmd .. {
	category = 1
	key = "cmd_arrayop"
	name = "$T.cmd_arrayop"
	icon = "\uead1"
	color = color1

	width = 600

	props = @( cmd){
		local a = [];
		a .. { pid="avar", lbl="$T.lbl_targetvar", type=VARIABLE, varbits=1|2|4, constbits=0 }		//	代入可能な左辺値＝ワーク、イベント、グローバル
		a .. { pid="op",   lbl="$T.lbl_arithop", refresh=1, type=LIST, list=[
			{ lbl="$T.lbl_create", val="new", },
			{ lbl="$T.lbl_get", val="get", },
			{ lbl="$T.lbl_add", val="add", },
			{ lbl="$T.lbl_insert", val="ins", },
			{ lbl="$T.lbl_update", val="set", },
			{ lbl="$T.lbl_remove", val="rem", },
			{ lbl="$T.lbl_combine", val="com", },
			{ lbl="$T.lbl_getlength", val="len", },
		]};
		if( !(#("new","add","len")).contains( cmd.op)){
			a .. { pid="idx", lbl="$T.lbl_index", type=SCALAR, range=(0,1000), variable=1, }
		}
		if( (#("add","ins","set")).contains( cmd.op) ){
			a .. { pid="rvar", lbl="$T.lbl_rvar", type=VARIABLE, varbits=31, constbits=15, datatype="all" }		//	全て
		}
		if( (#("get","len")).contains( cmd.op) ){
			a .. { pid="tvar", lbl="$T.cmd_macro_retvar", type=VARIABLE, varbits=1|2|4, constbits=0 }
		}
		if( cmd.op == "com"){
			a .. { pid="rvar", lbl="$T.lbl_rvar", type=VARIABLE, varbits=31, constbits=8 }
		}
		return a;
	}

	defval = { avar="W", op="new", idx=0, tvar="X", rvar=true }
	
	cmdinfo = @( cmd){
		local cmddef = RPGSystem.eventcmd[cmd.cmd], props = fget( cmddef, "props", cmddef, cmd);
		local var = propstr( props, cmd, "avar");
		local idx = propstr( props, cmd, "idx");
		local op = propstr( props, cmd, "op");
		local rvar = propstr( props, cmd, "rvar");
		local tvar = propstr( props, cmd, "tvar");
		local info = sprintf( "%S%S %S %S%S", var, idx!=null?("[%S]"%idx):"" , op, rvar||"", tvar?" =>"..tvar : "");
		return {
			info = info,
		}
	}

	exec = @( runner, cmd){
		try{
			switch( cmd.op){
			case "new": runner[cmd.avar] = []; break;
			case "get": runner[cmd.tvar] = cmd.avar[cmd.idx]; break;
			case "add": runner[cmd.avar] .. ::getvar( cmd.rvar, runner); break;
			case "ins": runner[cmd.avar].insert( cmd.idx, ::getvar( cmd.rvar, runner)); break;
			case "set": runner[cmd.avar].replace( cmd.idx, ::getvar( cmd.rvar, runner)); break;
			case "rem": runner[cmd.avar].remove( cmd.idx); break;
			case "len": runner[cmd.tvar] = length( cmd.avar); break;
			}
		}catch( ex){
			throw ex;
		}
	}
}

//	cmd_tableop : テーブルの操作
//	
eventcmd .. {
	category = 1
	key = "cmd_tableop"
	name = "$T.cmd_tableop"
	icon = "\uead3"
	color = color1

	props = @( cmd){
		local a = [];
		a .. { pid="avar", lbl="$T.lbl_targetvar", type=VARIABLE, varbits=1|2|4, constbits=0 }		//	代入可能な左辺値＝ワーク、イベント、グローバル
		a .. { pid="op",   lbl="$T.lbl_arithop", refresh=1, type=LIST, list=[
			{ lbl="$T.lbl_create", val="new", },
			{ lbl="$T.lbl_get", val="get", },
			{ lbl="$T.lbl_insert", val="ins", },
			{ lbl="$T.lbl_remove", val="rem", },
		]};
		if( cmd.op != "new"){
			a .. { pid="key", lbl="$T.lbl_key", type=STRING, variable=1, }
		}
		if( cmd.op == "ins"){
			a .. { pid="rvar", lbl="$T.lbl_rvar", type=VARIABLE, varbits=31, constbits=15, datatype="all" }		//	全て
		}
		if( cmd.op == "get" ){
			a .. { pid="tvar", lbl="$T.cmd_macro_retvar", type=VARIABLE, varbits=1|2|4, constbits=0 }
		}
		return a;
	}

	defval = { avar="W", op="new", key="key", tvar="X", rvar=true }
	
	cmdinfo = @( cmd){
		local cmddef =  RPGSystem.eventcmd[cmd.cmd], info = "";
		local props = fget( cmddef, "props", cmddef, cmd);
		switch( cmd.op){
		case "new": info = sprintf( "%S = {}", propstr( props, cmd, "avar")); break;
		case "get": info = sprintf( "%S = %S[%S]", propstr( props, cmd, "tvar"), propstr( props, cmd, "avar"),  propstr( props, cmd, "key")); break;
		case "ins": info = sprintf( "%S[%S] = %S", propstr( props, cmd, "avar"), propstr( props, cmd, "key"),  propstr( props, cmd, "rvar")); break;
		case "rem": info = sprintf( "delete %S[%S]", propstr( props, cmd, "avar"), propstr( props, cmd, "key")); break;
		}
		return { info = info };
	}

	exec = @( runner, cmd){
		try{
			switch( cmd.op){
			case "new": runner[cmd.avar] = {}; break;
			case "get": runner[cmd.tvar] = cmd.avar[cmd.key]; break;
			case "ins": runner[cmd.avar][cmd.key] <- ::getvar( cmd.rvar, this); break;
			case "rem": delete runner[cmd.avar][cmd.key]; break;
			}
		}catch( ex){
			throw ex;
		}
	}
}

//	
local settingprops( cmd, props, defmap){
	local prop = clone props.find( @( v) v.pid==cmd.pid);
	prop.pid = "val";
	return [
		{
			lbl="$T.lbl_settingitem", pid="pid", refresh=1, type=LIST,
			list = @(){
				return props.map( @( v) ({ lbl=v.lbl, val=v.pid }));
			},
			set = @( prop, data, val){
				data[prop.pid] <- val;
				local v = defmap[val];
				if( !v){
					local d = {}, vprop = props.find( @( v) v.pid==val);
					setDefaultProperties( [vprop], d);
					v = d[vprop.pid];
				}
				data.val ??= deepclone( v);	//	新しいpidのグローバル設定のデフォルト値を入れる
			}
			refresh=true,	//	set時にプロパティリストをリフレッシュ
		},
		prop
	];
}

local settinginfo( cmd, props){
	local prop = clone props.find( @( v) v.pid==cmd.pid);
	local lbl = fget( prop, "lbl") ?? cmd.pid;
	prop.pid = "val";
	local val = getPropertyText( prop, cmd);
	return {
		info = sprintf( "%S = %S", lbl, encodeESC( string( val)));
	}
}

