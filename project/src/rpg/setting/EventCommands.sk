	props = [
		{ pid="who", lbl="$T.lbl_who", type=LIST, list=who2list, variable=true, refresh=true, }
		{ pid="pos", lbl="$T.lbl_position", type=VEC2, range=(-128,128), q=10, variable=1, },
		{ pid="movetype", lbl="$T.movetype", type=LIST, list=[
			{ lbl="$T.movetype_walk", val="walk", }
			{ lbl="$T.movetype_dash", val="dash", }
			{ lbl="$T.movetype_jump", val="jump", }
			{ lbl="$T.movetype_warp", val="warp", }
		], },	//	walk, dash, jump, warp
		{ pid="movespd", lbl="$T.lbl_movespd", type=SCALAR, range = (0,10), q=10, ui="bar", variable=1, },
		{ pid="playani", lbl="$T.lbl_playani", type=BOOL, variable=1, },
		{ pid="wait", lbl="$T.lbl_waitaction", type=BOOL, variable=1 },
	]
	
	cmdinfo = @( cmd){
		local cmddef = RPGSystem.eventcmd[cmd.cmd], props = fget( cmddef, "props", cmddef, cmd);
		local who = propstr( props, cmd, "who");
		local pos = sprintf( "[%d %d]", cmd.pos[0]||0, cmd.pos[1]||0);
		local w = cmd["wait"] ? "⌛" : "";
		local info = sprintf( "%S %S %S\n", who, pos, w);
		return { info = info, }
	}
	
	defval = { who=2, pos=[0,0], movespd=3, playani=true, wait=true, movetype="walk" }
	
	exec = @( runner, cmd){
		runner.moveChara( cmd);
	}
}


