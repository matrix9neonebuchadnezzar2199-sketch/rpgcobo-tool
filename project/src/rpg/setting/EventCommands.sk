///////////////////////////////////////////////////////////////////////////////////
//	操作・演出処理

//	cmd_anime : アニメーションの再生
//	
eventcmd .. {
	category = 5
	key = "cmd_anime"
	name = "$T.cmd_anime"
	icon = "\ueae9"
	color = color5
	
	props = [
		{ pid="who", lbl="$T.lbl_who", type=LIST, list=who2list, variable=true, refresh=true, varbits=1|2|4|8 }
		{ pid="ani", lbl="$T.lbl_anime", type=ANIME_INLINE, variable=true, cnt="cnt6v.ui", 
			mdlid = @( pl){
				if( pl.getParam( "who") == 2){
					local ce = ::skstudio.editor["modaledit"];
					if( ce){
						return ce.data.mdlid;
					}
				}
				return "CV000";
			}
		}
	]

	edit = @( cv, cmd){
		if( cmd.who == 2){	//	このイベントのモデルに差し替え
			local ecmd = geteventlist( cv)["ref"]["cmd"];
			if( ecmd["mdlid"]){
				cmd = deepclone( cmd);
				cmd.ani.mdlid = ecmd.mdlid;
			}
		}
		return PropertyEditPopupV.run( cv, this, cmd);
	}

	cmdinfo = @( cmd){
		local cmddef = RPGSystem.eventcmd[cmd.cmd];
		local w = propstr( cmddef.props, cmd, "who");
		local a = propstr( cmddef.props, cmd, "ani");
		return {
			info = sprintf( "%S - %S", w, a);
		}
	}
	
	defval = { who = 1, ani = {mdlid="CV000", id="stand", spd=1.0, part=0} }

	exec = @( runner, cmd){
		runner.startAnime( cmd);
	}
}

local whoefxlist = [
	...who2list,
	{ lbl="$T.coord_marker", val=3 },
	{ lbl="$T.coord_screen", val=4 },
	{ lbl="$T.coord_world", val=5 },
];

//	cmd_efx : エフェクトの発生
//	プレイヤー、イベント、選択キャラ、スクリーン座標、ワールド座標
eventcmd .. {
	category = 5
	key = "cmd_efx"
	name = "$T.cmd_efx"
	icon = "\uef55"
	color = color5
	
	props = [
		{ pid="who", lbl="$T.lbl_who", type=LIST, list=whoefxlist, refresh=true, variable=1 }
		{ pid="pos", lbl="$T.lbl_position", type=VEC3, range=(-1000,1000), q=100, variable=1 }
		{ pid="efxid", lbl="$T.lbl_effect", type=RESID_PREVIEW, restype="efx", cnt="cnt6.ui", variable=1 }
		{ pid="wait", lbl="$T.lbl_waitaction", type=BOOL, variable=1 }
	]

	cmdinfo = @( cmd){
		local cmddef = RPGSystem.eventcmd[cmd.cmd];
		local ws = propstr( cmddef.props, cmd, "who");
		local es = propstr( cmddef.props, cmd, "efxid");
		local w = cmd["wait"] ? "⌛" : "";
		local info = sprintf( "%S %S %S", ws, es, w);
		return {
			info = info,
		}
	}
	
	defval = { who = 1, efxid="FX000", pos=[0.0,0.0,0.0], wait=true }

	exec = @( runner, cmd){
		runner.showEffect( cmd);
	}
}

