	{ lbl="$T.cmdtgt8", val=TGT_PARTY_SINGLE, }
	{ lbl="$T.cmdtgt11", val=TGT_PARTY_ALL, }
];

local hpmppidlist = [
	{ lbl="$T.HP", val="HP", }
	{ lbl="$T.MP", val="MP", }
	{ lbl="$T.TP", val="TP", }
];

local hpmpprop = {
	pid = "op"
	lbl = "$T.lbl_op"
	type = LIST
	list = [
		{ lbl="＝", fmt="＝ %S", val=0},
		{ lbl="＝(％)", fmt="＝ %S％", val=1},
		{ lbl="＋", fmt="＋ %S", val=2},
		{ lbl="＋(％)", fmt="＋ %S％", val=3},
	],
};


//	cmd_hpmp : HP,MP操作。バトル中の場合、敵も対象にできる(その場合variableから指定)。
//	・HP,MP,TP
//	・＝直値、＝％、＋直値、＋％
//	・数値
eventcmd .. {
	category = 2
	key = "cmd_hpmp"
	name = "$T.cmd_hpmp"
	icon = "\ue91f"
	color = color2

	props = [
		{ pid="cmdtgt", lbl="$T.cmdtgt", type=LIST, list=hpmptgtlist, variable=1, }		//	対象範囲。個人、パーティ、全て
		{ pid="charaid", lbl="$T.side_dbview_player", type=DATAID, datatype="player", variable=1, hide=@( pl) pl.getParam( "cmdtgt")!=TGT_PARTY_SINGLE }	//	↑で個人の場合の対象プレイヤー。データIDもしくはワーク、イベント、グローバル変数
		{ pid="pid", lbl="HP $T.lbl_op", type=LIST, list=hpmppidlist, }
		hpmpprop
		{ pid="val", lbl="$T.lbl_var", type=VARIABLE, varbits=1|2|4|8|16, constbits=1|8 },
		{ pid="hp1", lbl="$T.lbl_hp1", type=BOOL, variable=1, hide=@( pl) pl.getParam( "pid")!="HP"}
	]

	defval = { cmdtgt=TGT_PARTY_ALL, charaid="P000", pid="HP", op=1, val=100, hp1=true }

	cmdinfo = @( cmd){
		local cmddef = RPGSystem.eventcmd[cmd.cmd];
		local pi = cmd.cmdtgt==TGT_PARTY_SINGLE ? (conf.player[cmd.charaid]["name"]||cmd.charaid) : propstr( cmddef.props, cmd, "cmdtgt");
		local pid = propstr( cmddef.props, cmd, "pid");
		local val = propstr( cmddef.props, cmd, "val");
		local opval = hpmpprop.list[cmd.op].fmt % val;
		local info = sprintf( "%S  %S %S", pi, pid, opval);
		return {
			info = info,
		}
	}
	
	exec = @( runner, cmd){
		runner.changeHPMP( cmd);
	}
}

