}


//	defskillid : デフォルトスキル(スコアプロパティ)。プレイヤーの場合はエディタ入力無し。
//	
playerprops .. {
	proptype = "static"
	pid = "defskillid"
	lbl = "$T.lbl_defskill"

	type = NOEDITOR
	defval = "S003"
}

//	memo : メモ情報
//	
playerprops .. {
	proptype = "static"
	pid = "memo"
	lbl = "$T.lbl_memo"			//	ツール上での表示名。$T使っちゃってるけどゲームでは使用不能。良いか。
	
	//	プロパティ定義。lvcurveの編集でも参照
	type = STRING
	multiline = 8
};

local findprop( props, pid){
	foreach( p in props) if( p.pid == pid) return p;
}

///////////////////////////////////////////////////////////////////////////////////////
//	エネミー

//	LV : エネミーのLVは特に使われない (スタティックプロパティ)
//	
enemyprops .. {
	proptype = "static"
	pid = "LV"
	lbl = "$T.LV"
	type = SCALAR
	range = (1,999)
	defval = 1
};

//	プレイヤーの戦闘系のプロパティをエネミーにも追加
enemyprops .. { ...findprop( playerprops, "MAXHP"), range=(1,999999), };

// enemyprops .. findprop( playerprops, "MAXMP");	//	MP,TPはエネミーにはいらない
enemyprops .. findprop( playerprops, "PATK");
enemyprops .. findprop( playerprops, "PDEF");
enemyprops .. findprop( playerprops, "MATK");
enemyprops .. findprop( playerprops, "MDEF");
enemyprops .. findprop( playerprops, "AGI");
enemyprops .. findprop( playerprops, "EDR");
enemyprops .. findprop( playerprops, "CDR");
enemyprops .. findprop( playerprops, "PHIT");
enemyprops .. findprop( playerprops, "PEVA");
enemyprops .. findprop( playerprops, "MHIT");
enemyprops .. findprop( playerprops, "MEVA");
enemyprops .. { ...findprop( playerprops, "CRI"), defval=0.0};	//	エネミーは基本クリティカルなし
enemyprops .. findprop( playerprops, "CEVA");
enemyprops .. findprop( playerprops, "TGR");
enemyprops .. findprop( playerprops, "tribebits");

enemyprops .. {
	proptype = "score"
	pid = "defskillid"
	lbl = "$T.lbl_defskill"

	type = DATAID
	datatype = ["skill"]
	defval = "S003"
}

//
enemyprops .. {
	proptype = "static"
	pid = "exp"
	lbl = "$T.EXP"
	type = SCALAR
	range = (0, 1000000)
	defval = 10
};

enemyprops .. {
	proptype = "static"
	pid = "jxp"
	lbl = "$T.JXP"
	type = SCALAR
	range = (0, 1000000)
	defval = 1
};

enemyprops .. {
	proptype = "static"
	pid = "money"
	lbl = "$T.money"
	type = SCALAR
	range = (0, 1000000)
	defval = 10
};

local dropprop = {
	proptype = "static"
	pid = "item"
	lbl = "$T.lbl_dropitem"
	type = PROPERTYLIST
	propdef={
		name="$T.lbl_dropitem", 
		props = [
			{ pid="itemid", lbl="$T.lbl_item", type=DATAID, datatype=["item","weapon","armor","store","point"], nullable=true},
			{ pid="rate", lbl="$T.lbl_item", type=SCALAR, range=[0.0,100.0], q=100},
			{ pid="issteal", lbl="$T.lbl_issteal", type=BOOL, },
		],
		tostring = @( v){
			if( !v.itemid) return "$T.lbl_notset";
			return sprintf( "%S %S:%S    %.1f％", v.issteal?"\uf321":"\uf255", v.itemid, ::rpgdata[v.itemid]["name"]||"???", v.rate);
		}
	},
	defval={ itemid=null, rate=50.0, issteal=false},
}

for( local l = 0;l < 4;l ++){
	enemyprops .. { ...dropprop, pid="item"..l, lbl="${T.lbl_dropitem}"..l };
}




enemyprops .. findprop( playerprops, "memo");
