};

//	CEVA : クリティカル回避率 (スコアプロパティ)。0.0~100.0+
//	※実際は回避側命中率。回避率は1.0-PEVA
//
playerprops .. {
	proptype = "score"
	pid = "CEVA"
	lbl = "${T.CEVA}"

	type = NOEDITOR
	skipdefset = true
