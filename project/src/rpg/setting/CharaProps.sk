};

//	tribebits : 種族ビット。
//	
playerprops .. {
	proptype = "score"
	pid = "tribebits"
	lbl = "${T.tribebits}"
	
	type = NOEDITOR
	skipdefset = true
	defval = 0
}

//	STL : 盗み力。盗み確率を上げられるような感じ
//	
playerprops .. {
	proptype = "score"
