////////////////////////////////////////////////////////////////////////////////
//	
//	基本のステータスオプション定義。
//	
//	オプションのカテゴリは
//	0: 能力強化／弱化
//	1: 相手への効果
//	2: 自分への効果
//	3: その他
//	

import PropertyType;
import RPGPropertyType;
import SkillFlag;

local valtypes = (
	{ val:"base", lbl:"$T.val_base" },
	{ val:"baserate", lbl:"$T.val_baserate" },
	{ val:"supply", lbl:"$T.val_supply" },
	{ val:"totalrate", lbl:"$T.val_totalrate" },
);

//	値変更の変更させるタイプ
local valtypeprop = {
	pid = "valtype",
	lbl = "$T.lbl_type",
	type = LIST,
	list = valtypes,
	defval = "supply",
};

//	値変更の値
local valprop = {
	pid = "val",
	lbl = "$T.lbl_amount",
	type = SCALAR,
	range = (-9999,9999),
	defval = 5,
};

local formbitsprop = {
	pid = "formbits",
	lbl = "$T.type_dmgform"
	type = CHECKBITS,
	list = @() typelist( "dmgform"),
	defval = @() (1<<length( ::conf.type.dmgform))-1
};

local elembitsprop = {
	pid = "elembits",
	lbl = "$T.type_elem"
	type = CHECKBITS,
	list = @() typelist( "elem"),
	defval = 0
};

local efxprop = {
	pid = "efx",
	lbl = "$T.lbl_effect"
	type = RESID,
	restype = ["efx"],
	nullable = true,
	defval = null,
};

local sndprop = { pid="snd", lbl="$T.lbl_sound", type=RESID, restype=["snd"], defval=null, nullable=true, };

local userateprop = {
	pid = "rate",
	lbl = "$T.lbl_userate"
	type = VARIABLE,
	constbits=2|8, varbits=0,
	defval = 1.0
};

local successrateprop = {
	pid = "successrate",
	lbl = "$T.lbl_successrate"		//	ステータスを比較して成功率を変化させるためにスクリプトも有効
	type = VARIABLE,
	constbits=2|8, varbits=0,
	defval = 1.0
};

local dmgrateprop = {
	pid = "dmgrate",
	lbl = "$T.lbl_dmgrate"
	type = VARIABLE,
	constbits=2|8, varbits=0,
	defval = 1.0
};

local dmgvalprop = {
	pid = "dmgval",
	lbl = "$T.lbl_dmgval"
	type = VARIABLE,
	constbits=2|8, varbits=0,
	defval = 1
};

local orderprop = {
	pid = "order",
	lbl = "$T.lbl_order"
	type = SCALAR,
	range = (-100, 100)
	defval = 0
};

local relativeprop = {
	pid = "relative"
	lbl = "$T.lbl_reldmg"
	type = BOOL,
	defval = true,
};

local dmgtypeprop = {
	pid = "dmgtype"
	lbl = "$T.lbl_param"
	type = LIST
	list = [
		{lbl="$T.dmgtype1",val=1},{lbl="$T.dmgtype2",val=2},{lbl="$T.dmgtype3",val=3},
		{lbl="$T.dmgtype4",val=4},{lbl="$T.dmgtype5",val=5},{lbl="$T.dmgtype6",val=6},
	]
	defval = 1
};

local totalrateprop = {
	pid = "totalrate",
	lbl = "$T.lbl_dmggainrate"
	type = VARIABLE,
	constbits=2|8, varbits=0,
	defval = 10
};

local hitactprop = {
	pid = "hitact",
	lbl = "$T.lbl_hitact",
	type = PROPERTYLIST,
	
	propdef={
		name="$T.lbl_hitact", 
		props = [
			{ pid="hitani", lbl="$T.lbl_anime", type=ANIME_POPUP, nullable=true, },
			{ pid="hitefx", lbl="$T.lbl_effect", type=RESID, restype="efx", nullable=true, },
			{ pid="hitsnd", lbl="$T.lbl_sound", type=RESID, restype=["snd"], nullable=true, },
		],
		tostring = @( v) ((v["hitani"]||v["hitefx"]||v["hitsnd"]) ? sprintf( "%S %S %S", v["hitani"]["id"]||"", v["hitefx"]||"", v["hitsnd"]||"") : "$T.lbl_notset"),
	}

	defval = { hitani=null, hitefx=null, hitsnd=null, }
};

//	スコアパラメータの一覧取得
local statlistfunc(){
	local a = [];
	foreach( p in ::RPGSystem.playerprops){
		if( p.proptype=="score" && typeof( p.defval)<=SS_FLOAT) a .. { lbl:`$p.pid: ${p.lbl}`, val:p.pid };
	}
	return a;
}

local condlistfunc(){
	return dataList( ::conf.cond);	//	{ lbl=name, icon=icon, val=dataid }
}

local icon_param = "\uf02e"
local icon_guard = "\uef56"
local icon_attack = "\uef55"
local icon_skill = "\uea0b"
local icon_learn = "\ue80c"
local icon_seal = "\ue14b"
local icon_flag = "\ue7af"
local icon_walk = "\ue91d"
local icon_timer = "\ue425"
local icon_etc = "\ueb8e"


local iconlblstr( v){
	return v ? `${v["icon"]||""}${v["lbl"]||v["name"]}` : "$T.none";
}

local spdmgstr( v, lbl=null){
	return (lbl||"$T.spatk") .. (typeof( v)<=1 ? ("%+d"%v) : varstr( v));
}

local absorrelstr( v, rel){
	local s = varstr( v);
	return rel ? ("%+d％"%v) : ("%+d"%v);
}

//	
local overridectx( dmg, tb){
	foreach( i, v in tb) if( v!=null && v!=undefined) dmg.ovctx[i] <- v;
}

local elemsstr( elembits){
	local sb = StringBuffer();
	foreach( i,e in ::conf.type.elem){
		if( elembits & (1<<i)){ sb .. e.icon; }
	}
	return string( sb);
}


//	発動回数でコンディション解除。※BattleCommand無いとイベント追加できないな～
local countrem( self, cmd, v){
	if( !v) return;
	local cond = self.hasCondition( v.condid);
	if( cond){
		local c = ++cond.count;
		if( c >= v.val){
			cmd.addEvent( { chr=self, id="remcond", condid=v.condid});
		}
	}
}

////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////
//	
//	装備オプション定義
//	

RPGSystem.option .. {
	category = -1,
	key = "opt_equip",
	name = "so-bi",
	icon = icon_param,
	info = null,
	modifyscore = @( opd, pid, cval){
		if( opd[pid]){ cval.supply += opd[pid]; }
	},
};

////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////
//	
//	能力付与系オプション定義
//	

::valtypeinfomap <- {
	"base" : "%S (%+d)",
	"baserate" : "%S (%+d％)",
	"supply" : "%S %+d",
	"totalrate" : "%S %+d％",
}

local valtypescale = { base=1, supply=1, baserate=0.01, totalrate=0.01, }

//	スコアパラメータの値を上げ下げする。〇
RPGSystem.option .. {
	category = 0,
	key = "opt_status",
	name = "$T.opt_status",
	icon = icon_param,
	ownable = true,
	info = @(){
		local prop = ::RPGSystem.playerprops.find( @( v) v.pid==propid);
		return valtypeinfomap[valtype] % (prop["lbl"],val);
	},
	props = [
		{
			pid = "propid",				//	RPGChara[propid]を変化
			lbl = "$T.lbl_property",	//	
			type = LIST,
			list = statlistfunc,		//	functionを入れてもよし
			defval = "PATK",			//	物理攻撃
		},
		valtypeprop,
		valprop,
	],
	modifyscore = @( opd, pid, cval){
		if( pid==opd.propid){ cval[opd.valtype] += opd.val * valtypescale[opd.valtype]; }
	},
};

//	種族を設定する。〇
RPGSystem.option .. {
	category = 0,
	key = "opt_tribe",
	name = "$T.opt_tribe",
	icon = icon_param,
	ownable = true,
	info = @(){	//	this==opd
		local sb = StringBuffer();
		foreach( i,e in ::conf.type.tribe){
			if( this["tribe"] & (1<<i)) sb .. e.icon;
		}
		return string( sb);
	},
	props = [
		{
			pid = "tribe",
			lbl = "$T.lbl_tribe"
			type = CHECKBITS,
			list = @() typelist( "tribe"),
			defval = 0,
		},
	],
	modifyscore = @( opd, pid, cval){
		local val = opd[pid];
		if( val){ cval.base |= val; }
	},
};

//	特定の状態耐性を上下する。〇
RPGSystem.option .. {
	category = 0,
	key = "opt_conddef",
	name = "$T.opt_conddef",
	icon = icon_guard,
	ownable = true,
	info = @(){	//	this==opd
		local sb = StringBuffer();
		foreach( i,e in ::conf.type.resistg){
			local v = this["CDR."..i];
			if( v) sb .. sprintf("%S%+d ", e.icon, v);
		}
		return string( sb);
	},
	props = @(){
		return ::conf.type.resistg.map( 
		@( e, i){
			return {
				pid = "CDR."..i,
				lbl = e.icon..e.name,
				type = SCALAR
				range = (-100,100),
				defval = 0,
				ui="bar"
			}
		}
	)},
	modifyscore = @( opd, pid, cval){
		local val = opd[pid];
		if( val){ cval.supply += val; }
	},
};

//	属性耐性を上下する。〇
RPGSystem.option .. {
	category = 0,
	key = "opt_elemdef",
	name = "$T.opt_elemdef",
	icon = icon_guard,
	ownable = true,
	info = @(){	//	this==opd
		local sb = StringBuffer();
		foreach( i,e in ::conf.type.elem){
			local v = this["EDR."..i];
			if( v) sb .. sprintf("%S%+d ", e.icon, v);
		}
		return string( sb);
	},
	props = @(){
		return ::conf.type.elem.map( 
		@( e, i){
			return {
				pid = "EDR."..i,
				lbl = e.icon..e.name,
				type = SCALAR
				range = (-100,100),
				defval = 0,
				ui="bar"
			}
		}
	)},
	modifyscore = @( opd, pid, cval){
		local val = opd[pid];
		if( val){ cval.supply += val; }
	},
};

//	スキル習得。〇
//	※このオプションはフック関数は無い。RPGPlayer.updateScoreMapで集計される
//	※※※permanentはなんかちょっと考え方が変。整理が必要
//	permanentにしたい場合	キャラレベル、スキルショップ、
//	したくない場合			装備、コンディション、
//	どちらの場合もある		ジョブレベル、アイテム使用、
//	↑キャラレベルの場合はpermanentとはいえownoptionsに入れなくていい。
//	アイテム使用の場合は、ownoptionsに入れる場合はマクロで、その他はコンディション付与で良い。
//	となると、ジョブの編集時に、キャラのownoptionsに入れるかジョブ装着時のみの効果かを入れればよい。
//	
RPGSystem.option .. {
	category = 0,
	key = "opt_getskill",
	name = "$T.opt_getskill",
	icon = icon_learn,
	ownable = true,
	info = @(){	//	this==opd
		local data = rpgdata[skillid];
		return data["name"] || "???";
	}
	props = [
		{
			pid = "skillid"
			lbl = "$T.lbl_skill"
			type = DATAID
			datatype=["skill"]
			defval = "S000"
		}
	],
	//	no hooks
};

//	ジョブ習得。〇
//	※このオプションはフック関数は無い。RPGPlayer.updateScoreMapで集計される
//	これで習得したジョブは、ジョブ画面や転職UI?などで装着可能になる。
RPGSystem.option .. {
	category = 0,
	key = "opt_getjob",
	name = "$T.opt_getjob",
	icon = icon_learn,
	ownable = true,
	info = @(){	//	this==opd
		local data = rpgdata[jobid];
		return data["name"] || "???";
	},
	props = [
		{
			pid = "jobid"
			lbl = "$T.side_dbview_job"
			type = DATAID
			datatype=["job"]
			defval = "J000"
		}
	],
	//	no hooks
};

//	バトルコマンド設定。〇
//	※このオプションはフック関数は無い。RPGPlayer.updateScoreMapで集計される
//	指定したバトルコマンドを、指定したスロットに設定する。
//	スロットは、0-7を直値か、空いてるところ、置き換える、
//	処理順のコントロールが必要。先に空いてるスロット、次にスロット置き換え、最後にコマンド置き換え。
RPGSystem.option .. {
	category = 0,
	key = "opt_battlecmd",
	name = "$T.opt_battlecmd",
	icon = icon_learn,
	ownable = true,
	info = @(){	//	this==opd
		local k = battlecmd;
		local ma = RPGProperties.battlecmdlist();
		local bc = MenuBehavior._finditem( ma, @( v) k==v["val"]);
		if( slot == 100){
			local k = replace;
			local pc = MenuBehavior._finditem( ma, @( v) k==v["val"]);
			return  iconlblstr( pc) .. " ⇒ " .. iconlblstr( bc);
		}else{
			return iconlblstr( bc);
		}
	}
	order = @( opd) 10	//	置き換え順番指定出来たほうが良いかも？
	props = [
		{
			pid = "battlecmd"
			lbl = "$T.type_battlecmd"
			type = LIST,
			list = RPGProperties.battlecmdlist,
			defval = "attack"
		},
		{
			pid = "slot"
			lbl = "$T.lbl_slot"
			type = LIST,
			list = [
				{ lbl="$T.type_emptyslot", val=-1, },
				{ lbl="${T.lbl_slot}0", val=0, },
				{ lbl="${T.lbl_slot}1", val=1, },
				{ lbl="${T.lbl_slot}2", val=2, },
				{ lbl="${T.lbl_slot}3", val=3, },
				{ lbl="${T.lbl_slot}4", val=4, },
				{ lbl="${T.lbl_slot}5", val=5, },
				{ lbl="${T.lbl_slot}6", val=6, },
				{ lbl="${T.lbl_slot}7", val=7, },
				{ lbl="$T.lbl_replacecmd", val=100, },
			]
			defval = 0
		},
		{
			pid = "replace"
			lbl = "$T.lbl_cmdtoreplace"
			type = LIST,
			list = RPGProperties.battlecmdlist,
			defval = "attack"
			hide=@( pl) pl.getParam( "slot")!=100
		},
	],
	//	no hooks
};

//	属性特効〇
//	
RPGSystem.option .. {
	category = 0,
	key = "opt_elemsp",
	name = "$T.opt_elemsp",
	icon = icon_attack,
	ownable = true,
	info = @(){	//	this==opd
		local sb = StringBuffer();
		sb .. spdmgstr( totalrate) .. ":";
		foreach( i,e in ::conf.type.elem){
			if( elembits & (1<<i)){
				sb .. sprintf("%S", e.icon);
			}
		}
		return string( sb);
	}
	props = [
		formbitsprop,
		elembitsprop,
		totalrateprop,
	],
	action = @( opd, id, dmg, self){
		if( id=="attack" && dmg.src == self){
			local elembits = dmg.skill["elembits"] || 0;
			local formbits = 1 << (dmg.skill["dmgform"] ?? 32);
			if( (elembits & opd.elembits) && (formbits & opd.formbits)){
				dmg.cval.totalrate += ::getvar( opd.totalrate, opd) * 0.01;
			}
		}
	},
}

//	種族特攻〇
//	
RPGSystem.option .. {
	category = 0,
	key = "opt_tribesp",
	name = "$T.opt_tribesp",
	icon = icon_attack,
	ownable = true,
	info = @(){	//	this==opd
		local sb = StringBuffer();
		sb .. spdmgstr( totalrate) .. ":";
		foreach( i,t in ::conf.type.tribe){
			if( (1<<i)&tribebits) sb .. t["icon"];
		}
		return string( sb);
	},
	props = [
		{
			pid = "tribebits",
			lbl = "$T.lbl_tribe"
			type = CHECKBITS,
			list = @() typelist( "tribe"),
			defval = 1,
		},
		formbitsprop,
		elembitsprop,
		totalrateprop,
	],
	action = @( opd, id, dmg, self){
		if( id=="attack" && dmg.src == self){
			local tribebits = dmg.dst["tribebits"] || 0;
			local elembits = dmg.skill["elembits"] || 0;
			local formbits = 1 << (dmg.skill["dmgform"] ?? 32);
			if( (tribebits & opd.tribebits) && (elembits & opd.elembits) && (formbits & opd.formbits)){
				dmg.cval.totalrate += ::getvar( opd.totalrate, opd) * 0.01;
			}
		}
	},
}

//	武器特効〇
//	
RPGSystem.option .. {
	category = 0,
	key = "opt_weaponsp",
	name = "$T.opt_weaponsp",
	icon = icon_attack,
	ownable = true,
	info = @(){	//	this==opd
		local sb = StringBuffer();
		sb .. spdmgstr( totalrate) .. ":";
		foreach( i,e in ::conf.type.eqtype){
			if( spbits & (1<<i)){
				sb .. sprintf("%S", e.icon);
			}
		}
		return string( sb);
	},
	props = [
		{
			pid = "spbits",
			lbl = "$T.weapon"
			type = CHECKBITS,
			list = @() ::conf.type.eqtype.filter( @( v, i) isWeapon( i))
			defval = 1
		},
		formbitsprop,
		elembitsprop,
		totalrateprop,
	],
	action = @( opd, id, dmg, self){
		if( id=="attack" && dmg.src == self){
			local w = dmg.src.getWeapon()["data"];
			local bits = 1 << (w["eqtype"] || 0);	//	1<<装備中の武器タイプ。何も装備していない場合は1となる
			local elembits = dmg.skill["elembits"] || 0;
			local formbits = 1 << (dmg.skill["dmgform"] ?? 32);
			if( (bits & opd.spbits) && (elembits & opd.elembits) && (formbits & opd.formbits)){
				dmg.cval.totalrate += ::getvar( opd.totalrate, opd) * 0.01;
			}
		}
	},
}

//	被ダメージ率〇
//	
RPGSystem.option .. {
	category = 0,
	key = "opt_defrate",
	name = "$T.opt_defrate",
	icon = icon_attack,
	ownable = true,
	info = @(){	//	this==opd
		return spdmgstr( totalrate, "$T.spdef");
	}
	props = [
		formbitsprop,
		elembitsprop,
		totalrateprop,
	],
	action = @( opd, id, dmg, self){
		if( id=="defend" && dmg.dst == self){
			local elembits = dmg.skill["elembits"] || 0;
			local formbits = 1 << (dmg.skill["dmgform"] ?? 32);
			if( (!opd.elembits || (elembits & opd.elembits)) && (formbits & opd.formbits)){
				dmg.cval.totalrate += getvar( opd.totalrate, opd)*0.01;
			}
		}
	},
}

