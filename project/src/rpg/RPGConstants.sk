const ON = true;
const OFF = false;
const FLOORANGLE = 0.68;

//	ゲームごとになるべく変化の無いように。。。
enum CollisionGroupID
{
	//	collision group/mask
	G_VIEW			= 0x7F;

	G_CHARA			= 0x100;
	G_OBJECT		= 0x200;
	G_EVENT			= 0x400;	//	実体のない衝突判定はこれを
	G_STAGE			= 0x800;
	G_WATER			= 0x1000;
	
	G_GIZMO			= 0x8000;	//	ツール用。
}

enum ControlID
{
	//	control chara
	CTRL_STOP			= 1;
	CTRL_MOVE			= 2;
	CTRL_DASH			= 3;
	CTRL_JUMP			= 4;
	CTRL_SEARCH			= 5;
	CTRL_MENU			= 6;
	
	//	control camera
	CAM_ROTATE			= 100;
	CAM_ROLL			= 102;
	CAM_ZOOM			= 103;
	CAM_TARGET			= 104;
	CAM_RESET			= 107;
	CAM_POV             = 108;
}

