enum AnimationPart
{
	ST_EN = 0,
	ST_MD = 1,
	MD_EN = 2,
	EN_ST = 3,
	ST = 4,
	MD = 5,
	EN = 6,
}


import PropertyType;
import RPGPropertyType;
import AnimationPart;

//	一般的に使われるプロパティの定義。ツール使用ではあるが、ゲーム内からも参照される。lblはツールでしか見られない。
//	
::RPGProperties <-
{
	nameprop = {
		pid="name", lbl="$T.lbl_name", type=STRING, defval="",
	}
	nameiconprop = {
		pid = "nameicon"
		lbl = "$T.lbl_name"
		type = NAME_ICON
		defval = ["",""]
		get = @( prop, data) [data.name,data["icon"]]
		set = @( prop, data, val)( data.name<-val[0], data.icon<-val[1])
	},
	descprop = {
		pid="desc", lbl="$T.lbl_desc", type=STRING, multiline=5, defval="",
	},
	memoprop = {
		pid = "memo"
		lbl = "$T.lbl_memo"
		type = STRING
		multiline = 6
	},
	uivisiblelist = [
		{ lbl="$T.uivisible0", val = 0, },
		{ lbl="$T.uivisible1", val = 1, },
		{ lbl="$T.uivisible2", val = 2, },
		{ lbl="$T.uivisible3", val = 3, },
	]
	uicloselist = [
		{ lbl="$T.uiclose0", val = 0, },
		{ lbl="$T.uiclose1", val = 1, },
		{ lbl="$T.uiclose2", val = 2, },
	]
	animepartlist = [
		{ lbl="$T.animepart0", val = ST_EN, },
		{ lbl="$T.animepart1", val = ST_MD, },
		{ lbl="$T.animepart2", val = MD_EN, },
		{ lbl="$T.animepart3", val = EN_ST, },
		{ lbl="$T.animepart4", val = ST, },
		{ lbl="$T.animepart5", val = MD, },
		{ lbl="$T.animepart6", val = EN, },
	]

	function battlecmdlist(){
		local a = [{ lbl="$T.lbl_none", }, ];
		foreach( v in ::RPGSystem.battlecmd._list){
			a .. { lbl=(v["toolname"]||v.name), submenu=fget( v, "submenu"), val=v.key};
		}
		return a;
	}
}

::SystemSoundMap <- {
	"ui_move" = "SE000"
};
