RPGSystem.moveaction .. {
	key = "actiontool"
	name = "$T.cmd_actiontool"
	icon = "\ue912"
	desc = ""
	cls = ManualPlayAction
	props = [
		{ pid="manuaction", lbl="", type=CUSTOMBUTTON, defval={ event={actions=[],loop=true,basepos=0,stack=0}},
			tostring = @() ~(compiletemplate_c( T.tmpl_open_v), {v="$T.cmd_actiontool"}),
			edit = @( val){
				local e = ::skstudio.editor;
				local envdef = {
					bw = e.bw, event = e.tool.selgz.data, evid = e.tool.selgz.id
					eventmap = null, single = true,
				};
				return ManualActionDialog.run( envdef, val);
			}
		},
	]
}
