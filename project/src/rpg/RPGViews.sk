import VirtualKeyCode;
import ModifiersMask;
import SKViewPropertyID;
import PropertyType;
import RPGPropertyType;
import MoveScreenFlags;
import GamepadButtonCode;

local v_0 = Vector3D(), v_1 = Vector3D(), v_2 = Vector3D(), v_3 = Vector3D(), m_0 = Matrix();
local r2_0 = Rect2D(), r2_1 = Rect2D(), r3_1 = Rect3D();

//	RPG用に追加実装が必要なUI部品
//	マルチカラムリスト ... 
//	3Dプレビュー ... キャラやアイテムなんかのプレビュー用表示。setValueでmdlを与えられる。※SK3DViewに直接newslotしちゃう！
//	3Dターゲット選択 ... GPUIボタン、敵は名前ラベル表示、味方はステータスリストをフォーカス。さらに3Dモデルにアウトラインを表示
//	バルーン ... エモーション的なバルーン。3Dモデルの頭上に付く。距離によってサイズが変わる。※これパーティクルの方が良いか
//	調べるヒント ... 調べるが可能な際にプレイヤーの下に表示。
//	ダメージポップ ... ダメージや回復の数値。3Dモデルの中心から放射状にランダムな位置から表示。
//	バーチャルパッド ... 移動パッド、A,Bボタン、メニュー、オート。オートは戦闘時のみ表示。
//	丸いinnerpick ... 当たり判定が〇型になってるSKGroupView。バーチャルパッドで使う
//	小マップ ... 



//	SK3DViewにキャラのプレビュー表示を加える
//	※モンスター図鑑なんかに対応するためにRPGPlayer, RPGEnemy両方ありにするかなー
//	
class CharaPreview extends SK3DView
{
	icontype = "chrprev";
	rp3d = null;			//	RPG3DObject

	rsetid = "pbr_draft";
	
	constructor( s = null, r = null){
		super( s, r);
		// renderer.bgpass.enabled = false;
		setParam( CAMERADATA, SK3DCameraData());
		//	ツール時は分かりやすいようにデフォルトキャラ表示を行う。
		if( ::["SKStudio"]){
			setModelData({ mdlid="CV000"});
		}
		renderer.setEnvironment( ::RenderSettings.getEnvironment( rsetid));
	}

	//	data : モデルデータが入ったテーブルなら何でも良し。mdlid, mdl
	function setModelData( data){
		if( rp3d) scn.removeObject( rp3d);
		rp3d = RPG3DObject.create3DObject( data);
		rp3d.setDir( Math.PI);
		scn.addObject( rp3d);
		return rp3d;
	}

	//	p : RPGPlayer コンディションの表示も行う。
	function setRPGPlayer( p){
		setModelData( p.data);
		rp3d.rpgobj = p;
		rp3d.anime2( {id="stand"});
	}

	function updateScene( dt){
		super.updateScene( dt);
		local cam = renderer.camera;
	}

	function setValue( a, b=undefined){
		if( b==undefined){
			if( a instanceof RPGPlayer){
				return setRPGPlayer( a);
			}
			if( a["data"]["mdlid"] || a["data"]["mdl"]){
				return setModelData( a.data);
			}
		}
		return super.setValue( a, b);
	}
	
	function hitSkill( skill){
		local act = skill["hitact"];
		// local func = @(){
		// 	efx( hitefx);
		// 	snd( hitsnd);
		// }
		rp3d.effect( act["hitefx"]);
	}
}

//	イベントピクチャ表示用。
//	
/*
	"PC000":{
		"animap":[],
		"aniuv":[1,1],
		"cntpos":[0.5,0.5],
		"pic":"/resource/event_pic/rpgcobo-icon.webp",
		"scale":1.0,
		"blend":5
	},
*/
class EventPicView extends SKView
{
	static icontype = "evpic";
	static picidprop = { pid=6678, lbl="$T.side_res_event_pic", type=RESID, restype=["event_pic"], nullable=true, };
	static animprop = { pid=6679, type=LIST, list=[], };
	
	picid = null;				//	PC000
	picdata = null;
	sp = null;
	spcolor = 0xffffffff;	//	

	//	アニメーションフレーム
	aniu = 1; aniv = 1;
	aniid = null;

	first = true;
	cmdfunc = null;				//	モーション用コマンド
	
	constructor(){
		setPicID( null);
		enabled = false;
	}

	function setValue( a, b=undefined){
		if( b==undefined){
			setPicID( a);
		}
	}

	function setPicID( pi){
		picid = pi;
		local pc = picdata = ::conf._resource.event_pic[pi] || ::conf._resource.enemy_pic[pi] || ::conf._resource.event_pic["PC000"];
		local tex = ::getTexture( pc["pic"]||pc["pic3d"], 16);
		if( pc["aniuv"]){
			aniu = Math.max( 1, pc.aniuv[0]);
			aniv = Math.max( 1, pc.aniuv[1]);
		}
		local w = tex.width / aniu, h = tex.height / aniv;
		sp = Sprite( tex);
		sp.setSubBounds( Rect2D( 0, 0, w, h));
		sp.bnd.set( 0, 0, w, h);
		sp.blend = pc["blend"] ?? SK_PMAMIX;
		sp.bnd.scale( pc.scale, pc.scale);
		bnd.set( -(w*pc.cntpos[0])|0, -(h*pc.cntpos[0])|0, w, h).scale( pc.scale, pc.scale);
		matdirty = true;
		aniid = null;
		removeUpdateFunc( @( o) o.getName() == "picanifunc");	//	実行中のアニメは中断。。。
		repaint();
	}

	function setPicAnime( ai){
		local pa = picdata["animap"]?.find( @( v) v.id==ai);
		if( pa){
			removeUpdateFunc( @( o) o.getName() == "picanifunc");	//	実行中のアニメは中断。。。
			aniid = ai;
			local ani = Animation();
			local st = pa["st"]||0, en = pa["en"]??st, spd = pa["spd"]??1.0, lp = pa["loop"];
			ani.set( st, en, spd, lp);
			local udiv = aniu, vdiv = aniv, sp = sp, self = this;
			local picanifunc( dt){
				ani.update( dt);
				local fi = int( ani.frametime), us = 1.0 / udiv, vs = 1.0 / vdiv;
				sp.uvmat0.set( us,0,0,0, 0,vs,0,0, 0,0,1,0, (fi%udiv)*us,(fi/udiv)*vs,0,1);
				self.repaint();
				return ani.animating;
			}
			addUpdateFunc( picanifunc);
		}
	}

	//	イベントコマンドからのオペレーション
	function operate( cmd){
		if( cmd.op == 0) operateShow( cmd); else operateHide( cmd);
	}

	function operateShow( cmd){
		local self = this;
		local p0 = clone pos, p1 = Vector3D( cmd.pos[0], cmd.pos[1], 0.0);
		local s0 = clone scale, s1 = Vector3D( cmd.scale * 0.01);
		local r0 = clone rot, r1 = Vector3D( 0, 0, cmd.rot * Math.DTOR);
		local c0 = spcolor, c1 = cmd["col"]|0;
		local fade = cmd.fade+0.0;
		if( first){
			first = false;
			pos( p0( p1));
			scale( s0( s1));
			rot( r0( r1));
			setColor( c0=0);	//	for fade
		}
		if( cmd["picid"] && picid != cmd.picid){
			setPicID( cmd.picid);
			if( cmd["aniid"]) setPicAnime( cmd["aniid"]);
		}else{
			if( cmd["aniid"] && cmd["aniid"] != aniid) setPicAnime( cmd["aniid"]);;
		}
		removeUpdateFunc( @( o) o.getName() == "picmotfunc");	//	実行中のアクションは中断。。。
		local tptr = ptr( 0);
		local picmotfunc( dt){
			local t = (tptr << (~tptr + dt));
			local w = Math.saturate( t / fade);
			p0.lerp( p1, w, self.pos);
			s0.lerp( s1, w, self.scale);
			r0.lerp( r1, w, self.rot);
			self.matdirty = true;
			self.setColor( Math.lerpcolor( c0, c1, w));
			return w < 1.0;
		}
		if( fade>0.0) addUpdateFunc( picmotfunc);
		else picmotfunc( 10000);
	}

	function operateHide( cmd){
		local self = this;
		local c0 = spcolor, c1 = 0;
		local fade = cmd.fade+0.0;
		removeUpdateFunc( @( o) o.getName() == "picmotfunc");	//	実行中のアクションは中断。。。
		if( !fade) return removeFromParent();
		local tptr = ptr( 0);
		local picmotfunc( dt){
			local t = (tptr << (~tptr + dt));
			local w = Math.saturate( t / fade);
			self.setColor( Math.lerpcolor( c0, c1, w));
			if( w >= 1.0) self.removeFromParent();
			return w < 1.0;
		}
		addUpdateFunc( picmotfunc);
	}

	function render(){
		skDrawSprite( sp);
	}


	function getColor(){
		return spcolor;
	}
	
	function setColor( c){
		spcolor = c;
		sp.color0 = (sp.blend==SK_PMAMIX) ? Math.lerpcolor( spcolor&0xff, spcolor, (spcolor&0xff)/255.0) : spcolor;
	}
	
	function getProperties(){
		return #[
		( SKVP[VISIBLE]),
		picidprop,
		( SKVP[POSITION]),
		( SKVP[SCALE]),
		( SKVP[ROTATION]),
		( SKVP[STRETCHALIGN]),
		( SKVP[IMAGECOLOR]),
		( SKVP[ENABLED]),
		]
	}
	
	function getParam( pid){
		switch( pid){
		case IMAGE : return imageref;
		case IMAGECOLOR : return spcolor;
		case IMAGEBLEND : return sp.blend;
		case IMAGESTRETCH : 
			local s = sp.streach;
			return s?[s.x|0,s.y|0,s.w|0,s.h|0,sp.punch?1:0]:null;
		case IMAGEALIGN: return imagealign;
		}
		return super.getParam( pid);
	}
	
	function setParam( pid, p0, p1=null, w=0.0){
		switch( pid){
		case IMAGECOLOR :
			spcolor = Math.lerpcolor( p0, p1, w);
			sp.color0 = (sp.blend==SK_PMAMIX) ? Math.lerpcolor( spcolor&0xff, spcolor, (spcolor&0xff)/255.0) : spcolor;
			repaint();
			break;
		default:
			super.setParam( pid, p0, p1, w);
		}
	}
}

//	::loadSKView( path, RPG3DPopupView)のように作る。
//	SK3DViewにaddChildされる。
//	スケール、回転の調整が可能。また、カメラ範囲に入るように移動調整も可能。ただ、裏に回られると無理。
//	バトル中は常にaddされた状態。
//	
//	選択には、主ターゲットと副ターゲットがある。GPUIの選択は主ターゲット状態で、スキル範囲に収まっている場合は副ターゲット状態。
//	リストと3DターゲットそれぞれbindValueで基本的には問題なく表現できるはず。
//	※ターゲットUIはloadSKView( uipath, RPG3DPopupView)として生成する？そうするとプロパティはどう入れるべきか
//	　フォーカス時の挙動、GPUI選択可能か、sk3dに追従するか、
//	↑メタデータにjsonテキストで入れておいてやるとか。。。？ターゲット、バルーン、ダメージ、調べるぐらいだし。あと勝利時にexpゲージ、levelup表示もか
//	
class RPG3DPopupView extends SKLibView
{
	rp3d = null;			//	アタッチされているRPG3DObject。
	tpos = 2;				//	getEffectPositionの値。デフォルトでは2(bottom)

	function setTarget( s){
		rp3d = ref = s;
	}

	//	
	function setTargetPoint( tp){
		tpos = tp;
	}

	//	rp3dを完全に囲うようにposとstretch。posは左上揃え。
	//	※アクション中の激しい動きでピッキングできないのはいけないのでbaseposの場所に配置される。ボクセルもピクチャーも同様。
	function updateFunc( dt){
		if( !rp3d) return true;
		local cam = parent.renderer.camera;	//	parent -> SK3DView
		local p = v_0( rp3d.getEffectPosition( tpos)).transform( rp3d.mat);
		local w = p.transform( cam.viewmat).transformw( cam.prjmat);
		pos( p.x, p.y, 0.0).scale( 0.5/w, -0.5/w, 1.0).add( 0.5, 0.5, 0.0).scale( parent.bnd.w, parent.bnd.h, 1.0);
		matdirty = true;
		layerflags |= 1;
		repaint();
		return true;
	}
}


//	GPUIのカーソル選択が可能なターゲット選択View。
//	ピッキングはrpg3dから取れる画像に対して行う。
//	↑の場合、b3Bodyのビルボード化が必要。
//	
//	GPUIの矩形重なり問題はgetCursorBoundsで対応すれば問題は起きないはず。
//	
class RPG3DTargetView extends SKLibView
{
	rp3d = null;			//	アタッチされているRPG3DObject。
	selected = 0;

	constructor(){
		local t = GPUI3DTarget();
		t.setGPUIView( this);
	}

	function setTarget( s){
		rp3d = ref = s;
	}

	//	rp3dを完全に囲うようにposとstretch。posは左上揃え。
	//	※アクション中の激しい動きでピッキングできないのはいけないのでbaseposの場所に配置される。ボクセルもピクチャーも同様。
	function updateFunc( dt){
		local r = rp3d.projectBounds();
		if( r){
			stretchSize( r.w|0, r.h|0);
			pos( r.x|0, r.y|0, 0.0);
			matdirty = true;
			layerflags |= 1;
		}else{
			layerflags &= ~1;	//	ターゲットがカメラの裏に回ったら表示不能
		}
		repaint();
		return true;
	}
	
	//	bndはビルボードの場合ごく薄い
	function projectBounds( b, mat, vmat, pmat){
		local sa = #(
			Vector3D(-1,-1,-1), Vector3D( 1,-1,-1), Vector3D(-1, 1,-1), Vector3D( 1, 1,-1), 
			Vector3D(-1,-1, 1), Vector3D( 1,-1, 1), Vector3D(-1, 1, 1), Vector3D( 1, 1, 1), 
		);
		local r = #Rect2D(), v = #Vector3D();
		r.set( 10000, 10000, -20000, -20000);
		foreach( s in sa){
			v.set( b.r, b.s, b.t).scale( s).add( b.x, b.y, b.z);
			local w = v.transform( mat).transform( vmat).transformw( pmat);
			if( w <= 0.0) continue;		//	カメラ手前。。。
			local s = 1.0 / w * 0.5;
			v.scale( s, -s, s).add( 0.5);
			r.expand( r2_1.set( v.x,v.y,0,0));
		}
		return r;
	}
	
	//	SKView.pickで矩形内部でピック可能かをチェックする。
	//	※真中辺りはGPUIのマウスチェックがスカらないようにtrue返すようにする
	function innerpick( lx, ly){
		local img = rp3d.getPickingImage();
		if( img){	//	imgがある場合は画像のピクセルを取得。
			local u = lx / bnd.w, v = ly / bnd.h;
			local c = img.texture2d( u, v);
			return (c>>>24) > 63;	//	ABGRになってる
		}else{
			return true;	//	imgが無い場合（キャラなど）は常にOK。もしくはgbndにレイテストでもする？
		}
	}
}


//	
class RPG3DTargetView.GPUI3DTarget extends GPUITarget
{
	entered = false;

	function setGPUIView( v){
		super.setGPUIView( v);
		view.addEventListener( MOUSE_EVENT, mouseevent);
		view.addEventListener( GPUI_EVENT, gpuievent);
	}

	//	カーソル被りを防ぐために最小サイズ
	function getCursorBounds(){
		local v = view;
		return r2_0.set( v.bnd.w*0.5-12, v.bnd.h*0.5-12, 24, 24).transform( v.mat);
	}
	
	function gpuievent( e){
		switch( e.id){
		case GPUI_PRESSED:
			if( e.keycode == BTN_A){
				view.action( "clicked");
				view.postActionEvent( view.rp3d, 1, e.modifiers);	//	actioncmdにはrp3dを入れる？rp3d.rpgobj?
			}
			break;
		case GPUI_SELECTED:
			if( !entered){
				entered = true;
				view.action( "entered");
			}
			break;
		case GPUI_DESELECTED:
			if( entered && view.enabled){	//	!enabledの時はbackupCursor状態
				entered = false;
				view.action( "exited");
			}
			break;
		}
	}

	function mouseevent( e){
		e.computeLocal( view.parent.getInvMatrix());	//	parent座標系で？
		switch( e.id){
		case MOUSE_ENTERED:	//	主選択(2)をオン
			local b = view.contains( e.src);
			if( !entered && b){
				entered = b;
				view.action( "entered");
				if( cursmovable) ::gpui.setGPUITarget( this);
			}
			break;
		case MOUSE_EXITED:	//	主選択(2)をオフ
			local b = view.contains( e.dst);
			if( entered && !b){
				entered = b;
				view.action( "exited");
			}
			break;
		//	※GPUIButtonのアイテムと同様の動作にする！！！
		case MOUSE_PRESSED:	//	アクションイベント
			view.action( "clicked");
			view.postActionEvent( view.rp3d, 1, e.modifiers);	//	actioncmdにはrp3dを入れる？rp3d.rpgobj?
			break;
		case MOUSE_RELEASED:
			break;
		}
	}
}


//	マルチカラムに対応。選択の移動はGPUIのカーソルで行われる
//	アニメ再生も、行ごとにディレイして再生などを可能に
//	
class RPGListView extends GPUIListView
{
	icontype = "rpglist";
	colnum = 1;			//	カラム数。c0,c1,c2,...と続く。カラムがボタンになってると選択可能に。
	items = null;		//	展開されるアイテムリスト。
	
	function setRowPath( p){
		super.setRowPath( p);
		if( rowedata){
			for( local l = 0;;l ++){	//	※最低でもc0は無いといけない
				local vd = rowedata.findChild( "c"..l);
				if( !vd){ colnum = l; break; }
			}
		}
	}

	//	リスト項目をセットする。functionの値はバインド状態になる
	function setListItems( a){
		local rownum = (length( a)+colnum-1) / colnum;
		setRowCount( rownum);
		local num = rownum * colnum;
		for( local l = 0;l < num;l ++){
			local v = a[l];
			local c = rows[l/colnum].children[l%colnum];	//.findChild( "c"..(l%colnum));
			c.ref = v;
			c.findChild( "body")?.setVisible( !!v);		//	アイテムが存在しなくてもカーソルは移る
			if( v["_name"]) c.name = v._name;			//	_nameで名前を付けられる。この機能はリストのみ。
			else c.name = name..l;	//	自分の名前+idx
			if( v) c.bindValues( v);
			else c.bindValues( #{lbl="", rlbl="", icon=""});	//	とりあえずクリアしておきたい。。
		}
		// gpui._moveto( 0.0, 0.0, 0);
	}

	function setValue( a, b=undefined){
		if( b==undefined){
			if( a instanceof ::ptr){
				setSKViewValue( a);
			}else
			if( typeof( a) == SS_ARRAY){
				setListItems( a);
				local v = ::gpui.gpuitarget["view"];
				if( contains( v)){	//	選択表示を更新するためGPUI_SELECTEDをpost
					::rootview.postEvent( Event().setGPUIEvent( v, GPUI_SELECTED, 0));
				}
			}
		}else{
			return super.setValue( a, b);
		}
	}
	
	function getItemView( i){
		foreach( r in rows){
			for( local l = 0;l < colnum;l ++){
				local c = r.findChild( "c"..l);
				if( c.ref == i) return c;
			}
		}
		return null;
	}

	function focusItem( i){
		local v = getItemView( i);
		if( v){
			gpui.scrollViewToVisible( v, 0);
			if( v.gpui) ::gpui.moveCursorTo( v.gpui);
		}
	}
	
	function scrollItemToVisible( i){
		local v = getItemView( i);
		if( v) gpui.scrollViewToVisible( v, 0);
	}

	function getProperties(){
		return #[
			( SKVP[VISIBLE]),
			( SKVP[ORIENT]),
			( SKVP[SIZE_STATIC]),
			( SKVP[POSITION]),
			( SKVP[STRETCHALIGN]),
			( SKVP[ROWPATH]),
			( SKVP[BARPATH]),
			( SKVP[ENVPATH]),
			( SKVP[INSET]),
			( SKVP[LISTALIGN]),
			( SKVP[ROWSTRETCH]),
			( SKVP[LOOPCURS]),
			( SKVP[ENABLED]),
			( SKVP[BUFFER]),
			( SKVP[BUFFERCOLOR]),
			( SKVP[PREVIEROWWNUM]),
		];
	}
}

//	ウィジェットに追加。見た目は無し。
//	
class SKCircleHitGroupView extends SKGroupView
{
	static noexportcls = false;
	
	icontype = "circle";

	function innerpick( lx, ly){
		lx = lx / bnd.w * 2.0 - 1.0;	//	lx,lyをそれぞれ-1~1にマップ
		ly = ly / bnd.h * 2.0 - 1.0;
		return lx*lx+ly*ly <= 1.0;
	}
}

