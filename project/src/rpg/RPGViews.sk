//	Windows用。
//	
class RPGTitleLayer
{
	view = null;	//	rpgroot/titlelayer

	mx0 = 0;
	my0 = 0;
	winmoving = false;

	constructor( v){
		view = v;
		v.addEventListener( ACTION_EVENT, actionevent);
		local bar = v.findChild( "titlebar");
		bar.addEventListener( MOUSE_EVENT, barevent);
	}

	function actionevent( e){
		switch( e.src["name"]){
		case "btn_winmax":
			toggleMaximize();
			break;
		case "btn_winclose":
		{
			local e = Event();
			e.id = QUIT_REQUESTED;
			e.src = ::rootview;
			::rootview.postEvent( e);
			break;
		}
		}
	}

	function barevent( e){
		switch( e.id){
		case MOUSE_ENTERED:
			view.action( "show");
			break;
		case MOUSE_EXITED:
			view.action( "hide");
			break;
		case MOUSE_PRESSED:
			mx0 = e.x; my0 = e.y;
			if( e.count == 2){
				toggleMaximize();
			}else{
				if( !isMaximized()) winmoving = true;
			}
			break;
		case MOUSE_DRAGGED:
			if( winmoving){
				local mx = e.x, my = e.y;
				if( mx != mx0 || my != my0){
					skMoveScreen( { flags=MOVESCREEN_DELTA, x = mx-mx0, y = my-my0 });
				}
			}
			break;
		case MOUSE_RELEASED:
		case MOUSE_CANCELLED:
			winmoving = false;
			break;
		}
	}

	function isMaximized(){
		return view.findChild( "btn_winmax").isSelected();
	}

	function toggleMaximize(){
		local btn = view.findChild( "btn_winmax");
		local sel = btn.isSelected();
		skMoveScreen( { flags=sel?MOVESCREEN_RESTORE:MOVESCREEN_MAXIMIZE});
		btn.setSelected( !sel);
	}
}

//	指定したSKViewをバーチャルパッド化する。Gamepadとして動作する。サブクラスでは無いけど互換。
//	※中のボタン類はGPUIButtonではない。マウスイベントを取ってbuttonmask,axis0~を直接操作する。
//	::virtualpadにこのインスタンスを設定することでGPUIはバーチャルパッドの接続を検知。ただし、
//	ゲームパッドが接続されていたらそちらを優先する。
//	
class VirtualPad
{
	view = null;
	axis_l = null;
	btn_a = null;
	btn_b = null;
	btn_x = null;
	btn_start = null;
	btn_auto = null;

	//	Gamepad fields
	id = "aaaa:bbbb";
	type = 9;			//	9=GAMEPAD_VIRTUAL
	buttonmask = 0;
	connected = true;
	axis0 = 0.0;
	axis1 = 0.0;
	axis2 = 0.0;
	axis3 = 0.0;
	axis4 = 0.0;
	axis5 = 0.0;

	visible = true;

	mapping = null;			//	マッピング設定は入らない

	constructor( v){
		view = v;
		setupAxis( axis_l = view.findChild( "vpad_stick"));
		setupButton( btn_a = view.findChild( "vpad_a"), BTN_A);
		setupButton( btn_b = view.findChild( "vpad_b"), BTN_B);
		setupButton( btn_x = view.findChild( "vpad_x"), BTN_X);
		setupButton( btn_start = view.findChild( "vpad_menu"), BTN_START);
		setupButton( btn_auto = view.findChild( "vpad_auto"), BTN_X);
	}

	function setVisible( b){
		if( visible = b) view.layerflags |= 1; else view.layerflags &= ~1;
		view.parent.repaint();
	}

	function poll( dt){}	//	何もしないで良い
	
	function setupButton( v, btnid){
		local bit = 1<<btnid;
		v.multitouch = true;
		local self = this;
		local mfunc( e){
			switch( e.id){
			case MOUSE_PRESSED:
				v.anime( 1.0, 100.0);
				self.buttonmask |= bit;
				e.consume();
				break;
			case MOUSE_RELEASED:
			case MOUSE_CANCELLED:
				self.buttonmask &= ~bit;
				v.anime( 0.0, 100.0);
				e.consume();
				break;
			}
		}
		v.addEventListener( MOUSE_EVENT, mfunc);
	}

	function setupAxis( v){
		v.multitouch = true;
		local self = this;
		local changeaxis( e){
			e.computeLocal( v.getInvMatrix());
			local ax =   (e.lx / v.bnd.w)*2.0-1.0;
			local ay = -((e.ly / v.bnd.h)*2.0-1.0);
			local a = Math.sqrt( ax*ax + ay*ay);
			if( a >= 0.1){
				self.axis0 = ax/a; self.axis1 = ay/a;
				local r8 = (Math.mod2( Math.atan2( ax, ay)+Math.PI2/16.0, 0.0, Math.PI2) / Math.PI2 * 8.0) & 7;
				v.anime( 1.0 + r8);
			}else{
				self.axis0 = self.axis1 = 0.0;
				v.anime( 10.0);
			}
		}
		local mfunc( e){
			switch( e.id){
			case MOUSE_PRESSED:
			case MOUSE_DRAGGED:
				changeaxis( e);
				break;
			case MOUSE_RELEASED:
			case MOUSE_CANCELLED:
				self.axis0 = self.axis1 = 0.0;
				v.anime( 0.0);
				break;
			}
		}
		v.addEventListener( MOUSE_EVENT, mfunc);
	}
}
