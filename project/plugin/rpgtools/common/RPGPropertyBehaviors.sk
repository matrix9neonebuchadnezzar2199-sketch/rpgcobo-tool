import VirtualKeyCode;
import ModifiersMask;
import PropertyType;
import RPGPropertyType;
import VarType;
import BlockFlagID;
import CollisionGroupID;

local srcdir = dirname( callee().getSourceName());

class PropertyBehaviors.NameIcon extends PropertyBehaviors.String
{
	static proptype = NAME_ICON;
	static uipath = srcdir .. "/ui/prop_nameicon.ui"
	
	iconbtn = null;			//	GPUIButton
	iconstr = null;			//	string : アイコンの絵文字コード

	function init(){
		super.init();
		iconbtn = view.findChild( "iconbtn");
	}

	function getParam(){
		return (edit.getText(), iconstr);
	}
	
	function setParam( v){
		super.setParam( v[0]);
		iconstr = v[1];
		iconbtn.setValue( "icon", v[1]);
	}

	function paramevent( e){
		switch( e.src["name"]){
		case "iconbtn":
			local ic = IconSelectPopup.run( e, iconstr, prop["icontype"]);
			if( ic){
				iconstr = ic;
				iconbtn.setValue( "icon", ic);
				postActionEvent( true);
			}
			break;
		}
		super.paramevent( e);
	}
}

class PropertyBehaviors.ListScalar extends PropertyBehavior
{
	static proptype = LIST_SCALAR;
	static uipath = srcdir .. "/ui/prop_listscalar.ui"
	
	menu = null;	//	MenuBehavior
	val0 = null;	//	NumInputBehavior : viewの形状でどのbehavior使うか変えないと、、、
	trgid = ACTION_PERFORMED;	//	int : 変更を確定するイベントID

	function init(){
		local strlist = fget( prop, "list", prop, proplist);
		local itemlist = strlist.map( @( v, i) typeof( v)==SS_TABLE ? v : { lbl=v, val=i });
		menu = MenuBehavior( view.findChild( "listmenu"), itemlist);
		//
		val0 = createNumInputBehavior( view.findChild( "val0"));
		local r = prop["range"]||#(0,100), q = prop["q"]||1;
		val0.setRange( r[0], r[1], q)
	}

	function getParam(){
		local i = menu.menuitems.indexOf( menu.selitem);
		return (menu.menuitems[i<0?0:i].val, val0.getValue());
	}
	
	function setParam( v){
		foreach( mi in menu.menuitems){
			if( mi.val == v[0]){ menu.selectItem( mi); break; }
		}
		val0.setValue( v[1]||0);
	}
	
	function paramevent( e){
		if( e.src==menu.view){
			postActionEvent( true);
		}else
		if( e.id==trgid && e.src==val0.view){
			postActionEvent( true);	//	同じidに対する操作は常にまとめる？
		}
	}
}

local getData( dataid){
	local datatype = ::RPGData.getDataType( dataid);
	if( datatype){
		return ::conf[datatype][dataid];
	}
}

local setDataIDParam( view, dataid, num){
	view.findChild( "L").setVisible( num <= 1);
	view.setValue( "num", num>1 ? "+ "..num : "");
	if( !length( dataid)){
		view.setValue( "lbl", "未設定");
		view.setValue( "icon", "\ue15b");
		return;
	}
	local datatype = ::RPGData.getDataType( dataid);
	if( datatype){
		local r = ::conf[datatype][dataid];
		if( r){
			view.setValue( "lbl", sprintf( "%S: %S", dataid, lang( r.name)));
			view.setValue( "icon", r["icon"] || ConfigResource.dbiconmap[datatype]);
			return;
		}
	}
	view.setValue( "lbl", sprintf( "%S: $T.lbl_invalidid", dataid));
	view.setValue( "icon", "\ue000");
}

local showDataIDMenu( e, dataid){
	if( !dataid) return;
	local menudata = [
		{ id="edit", lbl=~(compiletemplate_c( T.tmpl_edit_v), {v=dataid}), icon="\ue745" },
	];
	switch( MenuPopup.run( menudata)["id"]){
	case "edit":
		local datatype = ::RPGData.getDataType( dataid);
		local path = "/.x/%S/%S" % (datatype, dataid);
		::skstudio.openEditor( path);
		break;
	}
}

local showResIDMenu( e, resid){
	if( !resid) return;
	local menudata = [
		{ id="edit", lbl=~(compiletemplate_c( T.tmpl_edit_v), {v=resid}), icon="\ue745" },
	];
	switch( MenuPopup.run( menudata)["id"]){
	case "edit":
		local restype = ::RPGResource.getResourceType( resid);
		local path = "/.x/%S" % restype;
		::skstudio.openEditor( path, resid);
		break;
	}
}


class PropertyBehaviors.DataID extends PropertyBehavior
{
	static proptype = DATAID;
	static uipath = srcdir .. "/ui/prop_dataid.ui"
	
	menu = null;
	dataid = null;
	num = 1;

	function init(){
		menu = view.findChild( "listmenu");
	}

	function getParam(){
		return num > 1 ? sprintf( "%S,%d", dataid, num) : dataid;
	}
	
	function setParam( v){
		local i = v ? v.indexOf( ',') : -1;
		num = 1;
		dataid = i<0 ? v : v.substring( 0, i);
		if( prop["inputnum"] && i >= 0) num = int( v.substring( i+1));
		setDataIDParam( menu, dataid, num);
	}
	
	function paramevent( e){
		if( e.src["name"]=="listmenu"){
			if( e.isMouseDown( BUTTON1_MASK)){
				local ret = DataSelectPopup.run( e, prop, getParam());
				if( ret){
					setParam( ret=="rem" ? null : ret);
					postActionEvent( true);
				}
			}else
			if( e.isMouseDown( BUTTON2_MASK)){
				showDataIDMenu( e, dataid);
			}
		}
	}
}

class PropertyBehaviors.DataIDs extends PropertyBehavior
{
	static proptype = DATAIDS;
	static uipath = srcdir .. "/ui/prop_dataids.ui"
	
	menulist = null;
	plist = null;

	datalist = null;

	function init(){
		menulist = view.findChild( "LIST");
		plist = fget( prop, "datalist", prop, proplist);
		menulist.setRowCount( length( plist));
		foreach( i, v in plist){
			local r = menulist.rows[i];
			r.setValue( "head", v["head"] || string( i+1));
			r.findChild( "listmenu").ref = (i,v);
		}
		local d = cnt.computeSizeDelta();
		if( d.x != 0.0 || d.y != 0.0){
			cnt.stretchSize( view.bnd.w+d.x, view.bnd.h+d.y);
			cnt.revalidate();
		}
	}

	function getParam(){
		return datalist;
	}
	
	function setParam( v){
		datalist = clone v;
		foreach( i,p in plist){
			local r = menulist.rows[i];
			if( r){
				local v = datalist[i];
				setDataIDParam( r, v, 1);
			}
		}
	}
	
	function paramevent( e){
		if( e.src["name"]=="listmenu"){	//	リスト選択
			if( e.isMouseDown( BUTTON1_MASK)){
				local ret = DataSelectPopup.run( e, e.src.ref[1]);
				if( ret){
					local i = e.src.ref[0];
					local a = clone datalist;
					if( length( a) < i+1) a.resize( i+1);
					a[i] = ret=="rem" ? null : ret;
					setParam( a);
					postActionEvent( true);
				}
			}else
			if( e.isMouseDown( BUTTON2_MASK)){
				local i = e.src.ref[0];
				showDataIDMenu( e, datalist[i]);
			}
		}
	}
}

class PropertyBehaviors.ResourceID extends PropertyBehavior
{
	static proptype = RESID;
	static uipath = srcdir .. "/ui/prop_dataid.ui"
	
	menu = null;
	resid = null;
	
	function init(){
		menu = view.findChild( "listmenu");
	}

	function getParam(){
		return resid;
	}
	
	function setParam( v){
		resid = v;
		if( !length( v)){
			menu.setValue( "lbl", "$T.lbl_notset");
			menu.setValue( "icon", "\ue15b");
			return;
		}
		foreach( ri, res in ::conf._resource){
			local r = res[v];
			if( r){	//	リソースの名前とIDとアイコンを設定
				menu.setValue( "lbl", sprintf( "%S: %S", resid, lang( r.name)));
				menu.setValue( "icon", GameResourceResource.resiconmap[ri]);
				return;
			}
		}
		menu.setValue( "lbl", sprintf( "%S: ----", v));
		menu.setValue( "icon", "\ue000");
	}
	
	function paramevent( e){
		if( e.src["name"]=="listmenu"){	//	リスト選択
			local ret = ResourceSelectDialog.run( e, prop, resid);
			if( ret){
				setParam( ret=="rem" ? null : ret);
				postActionEvent( true);
			}
		}
	}
}


class PropertyBehaviors.ResourceIDPreview extends PropertyBehavior
{
	static proptype = RESID_PREVIEW;
	static uipath = srcdir .. "/ui/prop_resid_pv.ui"
	
	resid = null;
	preview = null;		//	ResourcePreviewCanvas : モデルのプレビュー

	static function getUIPath( prop){
		if( prop["size"]=="big") return srcdir .. "/ui/prop_resid_pvbig.ui";
		return uipath;
	}

	function init(){
		local selbtn = view.findChild( "selbtn");
		preview = ResourcePreviewCanvas( selbtn, true);
		selbtn.gpui.enablerclick = false;
		// selbtn.addEventListener( MOUSE_EVENT, rclkevent);
	}

	function getParam(){
		return resid;
	}
	
	function setParam( v){
		resid = v;
		if( !length( v)){
			view.setValue( "idlbl", "$T.lbl_notset");
			preview.setResourceData( v, null);
			return;
		}
		foreach( ri, res in ::conf._resource){
			local r = res[v];
			if( r){	//	リソースの名前とIDとアイコンを設定
				view.setValue( "idlbl", sprintf( "%S: %S", resid, lang( r.name)));
				preview.setResourceData( v, r);
				return;
			}
		}
		view.setValue( "idlbl", sprintf( "%S: ----", v));
		preview.setResourceData( v, null);
	}
	
	function paramevent( e){
		if( e.src["name"]=="selbtn"){
			if( e.isMouseDown( BUTTON1_MASK)){
				local ret = ResourceSelectDialog.run( e, prop, resid);
				if( ret){
					setParam( ret=="rem" ? null : ret);
					postActionEvent( true);
				}
			}else
			if( e.isMouseDown( BUTTON2_MASK)){
				local i = e.src.ref[0];
				showResIDMenu( e, resid);
			}
		}
	}

	// function rclkevent( e){
	// 	if( e.id==MOUSE_RELEASED && e.isMouseDown( BUTTON2_MASK) && e.isClicked()){
	// 		local i = e.src.ref[0];
	// 		showResIDMenu( e, resid);
	// 	}
	// }
}


class PropertyBehaviors.ExpCurve extends PropertyBehavior
{
	static proptype = EXPCURVE;
	static uipath = srcdir .. "/ui/prop_dataid.ui"
	
	menu = null;
	curv = null;

	function init(){
		menu = view.findChild( "listmenu");
		curv = clone prop.defval;
		menu.setValue( "icon", "");
	}
	
	function getParam(){
		return curv;
	}
	
	function setParam( v){
		curv = v;
		menu.setValue( "lbl", encodeJSON( v));
	}
	
	function paramevent( e){
		if( e.src["name"]=="listmenu"){	//	リスト選択
			local maxlv = proplist.getParam( "MAXLV") || 99;
			local ret = ExpCurvePopup.run( e, curv, maxlv);
			if( ret && ret<>curv){
				setParam( ret);
				postActionEvent( true);
			}
		}
	}
}

class PropertyBehaviors.ExpCurve.ExpCurvePopup extends Popup
{
	static UIPATH = srcdir .. "/ui/expcurvpopup.ui";

	modalclose = 2;
	maxlv = 99;

	baseval = null;
	gainval = null;
	explist = null;		//	GPUIListView

	constructor( v, c, mlv=99){
		super( v);
		maxlv = mlv;
		baseval = ::createNumInputBehavior( v.findChild( "baseval"));
		gainval = ::createNumInputBehavior( v.findChild( "gainval"));
		baseval.setRange( 10, 100, 1);
		gainval.setRange( 1, 100, 1);
		explist = v.findChild( "LIST");
		baseval.setValue( c[0]);
		gainval.setValue( c[1]);
		setCurves();
		baseval.view.addEventListener( ITEM_EVENT, valevent);
		gainval.view.addEventListener( ITEM_EVENT, valevent);
	}

	function setCurves(){
		local et = (baseval.getValue(), gainval.getValue());
		explist.setRowCount( maxlv);
		local prevexp =0;
		for( local l = 1; l <= maxlv;l ++){
			local r = explist.rows[l-1];
			local exp = ::RPGSystem.getExpByLV( l+1, et);
			setnum( r.findChild( "lv"), l, 3);
			setnum( r.findChild( "next"), exp-prevexp, 11);
			setnum( r.findChild( "total"), prevexp, 15);
			prevexp = exp;
			r.repaint();
		}
	}

	function setnum( lbl, v, d){
		local n = commaNum( v);
		local x = "___,___,___,___,___".substring( 19-d, 19-length( n));
		local a0 = clone lbl.fontattr, a1 = lbl.fontattr;
		local tb = lbl.textbox;
		a0.color = 0x77777777;
		tb.setText( x..n);
		tb.setAttribute( a0);
		lbl.resetattr = false;
		tb.setAttribute( a1, length( x));
	}

	function commaNum( i){	//	int
		local sb = #StringBuffer(); sb.clear();
		while( i >= 1000){
			sb[0] <- ",%03d" % (i%1000); i /= 1000;
		}
		sb[0] <- string( i);
		return string( sb);
	}

	function valevent( e){
		setCurves();
	}

	static function run( e, curv, maxlv){
		local p = this( ::loadSKView( UIPATH), curv, maxlv);
		p.show( null, e.src);
		return p.ret ? (p.baseval.getValue(), p.gainval.getValue()) : null;
	}
}

class PropertyBehaviors.Graphic extends PropertyBehavior
{
	static proptype = GRAPHIC;
	static uipath = srcdir .. "/ui/prop_dataid.ui"
	
	menu = null;
	respath = null;

	function init(){
		menu = view.findChild( "listmenu");
		menu.setValue( "icon", "\ue15b");
		menu.setValue( "lbl", "$T.lbl_notset");
	}

	function getParam(){
		return respath;
	}
	
	function setParam( v){
		respath = v;
		local lbl = v? v.substring( v.lastIndexOf( "/")+1) : "$T.lbl_notset";
		menu.setValue( "lbl", lbl);
		local r = ::getResource( respath);
		if( r){
			menu.setValue( "icon", skstudio.getResourceIcon( r));
		}else{
			menu.setValue( "icon", "\ue15b");
		}
	}
	
	function paramevent( e){
		if( e.src["name"]=="listmenu"){	//	リスト選択
			local ret = ResourceFileSelectDialog.run( prop);
			if( ret){
				setParam( ret);
				postActionEvent( true);
			}
		}
	}
}

class PropertyBehaviors.VoxelParts extends PropertyBehavior
{
	static proptype = VOXEL_PARTS;
	static uipath = srcdir .. "/ui/prop_voxparts.ui"
	
	menu = null;
	
	voxpath = null;			//	usevcnameの場合は名前のみ
	partsid = null;			//	

	function init(){
		menu = view.findChild( "listmenu");
	}
	
	function getParam(){
		return (voxpath && partsid) ? (voxpath, partsid) : null;
	}
	
	function setParam( v){
		local vc = prop["usevcname"] ? VoxelContainer.getGlobal( v[0]) :  ::getResourceContent( v[0]);
		if( vc){
			voxpath = v[0];
			local a = [], sel = null;
			for( local l = 0, vp; vp = vc.partsAt( l); l++){
				if( vp.parent) continue;
				if( vp.name.startsWith( "_")) continue;
				local mi = { lbl=vp.name, val=vp.name};
				a .. mi;
				if( vp.name==v[1]) sel = mi;
			}
			partsid = v[1];
		}else{
			voxpath = partsid = null;
		}
		if( voxpath && partsid){
			menu.setValue( "lbl", voxpath.substring( voxpath.lastIndexOf( "/")+1).." - "..partsid);
			menu.setValue( "icon", "\ue871");
		}else{
			menu.setValue( "lbl", "$T.lbl_notset");
			menu.setValue( "icon", "\ue15b");
		}
	}
	
	function paramevent( e){
		if( e.src["name"]=="listmenu"){	//	リスト選択
			local ret = ResourceFileSelectDialog.run( prop);
			if( ret){
				if( prop["usevcname"]){
					ret[0] = ret[0].substring( ret[0].lastIndexOf( "/")+1, ret[0].lastIndexOf( "."));
				}
				setParam( ret);
				postActionEvent( true);
			}
		}
	}
}

class PropertyBehaviors.VoxPalette extends PropertyBehavior
{
	static proptype = PALETTEMAP;
	static uipath = srcdir .. "/ui/prop_pal.ui"
	
	palview = null;		//	SKImageView
	palimg = null;		//	RGBAImage( 16, n)
	palmod = null;		//	[i,col,...]
	baseh = 1.0;
	selbb = null;		//	ByteBuffer( 256)
	selbb0 = null;
	ix0 = 0;
	iy0 = 0;
	selmode = 0;

	static menuitems = [
		{ lbl="$T.lbl_editall_mtl", id="mtl" },
		"*",
		{ lbl="$T.lbl_copy_pal", id="copyimg", icon="\ue14d" },
		{ lbl="$T.lbl_paste_pal", id="pasteimg", icon="\ue14f" },
		"*",
		{ lbl="$T.lbl_reset_pal", id="reset", icon="\uf053" },
	];

	static ctxmenuitems = [
		{ lbl="$T.lbl_hsv", id="hsv" },
		{ lbl="$T.lbl_material", id="mtl" },
		"*",
		{ lbl="$T.menu_edit_copy", id="copy", icon="\ue14d" },
		{ lbl="$T.menu_edit_paste", id="paste", icon="\ue14f" },
		"*",
		{ lbl="$T.lbl_reset_col", id="reset", icon="\uf053" },
	]

	function init(){
		palview = view.findChild( "pal");
		palview.addEventListener( MOUSE_EVENT, palevent);
		baseh = cnt.bnd.h;
		selbb = ByteBuffer( 256);
		selbb.size = 256;
		selbb.fill( 0);
		selbb0 = ByteBuffer( 256);
		selbb0.size = 256;
	}
	
	function getParam(){
		return palmod;
	}
	
	function setParam( v){
		palmod = clone v;
		setImage( v);
	}

	function setImage( v){
		local n = length( v);
		palimg = RGBAImage( 16, Math.max( 1, (n/2+15)/16), 0);
		for( local l = 0; l < n; l += 2){
			palimg[l/2] = v[l+1] | 0xff000000;
		}
		local paltex = Texture(); paltex.load( palimg);
		paltex.setSamplerState( #SamplerState( SK_CLAMP, SK_CLAMP, SK_POINT, SK_POINT));
		local sp = Sprite( paltex);
		sp.shadersrc = skFXFindTechnique( "rpgtool.palimg").getShaderSource( 0);
		(sp.tex1 = Texture()).create( 256, 1, SK_R8, 0, 0, selbb);
		sp.miscmat = Matrix();
		palview.setSprite( sp);
		local dh = (palimg.height-1) * 16;
		cnt.stretchSize( cnt.bnd.w, baseh + dh);
		cnt.revalidate();
		updateSel();
	}

	function updateSel(){
		local sp = palview.sp, m = sp.miscmat;
		sp.tex1.create( 256, 1, SK_R8, 0, 0, selbb);
		m[0] = 1.0/sp.bnd.w;
		m[1] = 1.0/sp.bnd.h;
		m[2] = 16;
		m[3] = palimg.height;
		palview.repaint();
	}

	function regclear(){
		selbb.fill( 0);
		updateSel();
	}

	//	mode 1:set, 2:add, 3:del
	function regselect( x0, y0, x1, y1, mode=1){
		if( x0>x1){ local t=x0; x0=x1; x1=t; }
		if( y0>y1){ local t=y0; y0=y1; y1=t; }
		x0 = Math.clamp( x0, 0, palimg.width-1);
		x1 = Math.clamp( x1, 0, palimg.width-1);
		y0 = Math.clamp( y0, 0, palimg.height-1);
		y1 = Math.clamp( y1, 0, palimg.height-1);
		local v = 255;
		switch( mode){
		case 1: selbb.fill( 0); break;
		case 3: v = 0;
		case 2: selbb.setBuffer( selbb0); break;
		}
		for( local y=y0; y<=y1; y++){
			for( local x=x0; x<=x1; x++){
				selbb[x+y*16] = v;
			}
		}
		updateSel();
	}
	
	function palevent( e){
		if( !palimg) return;
		e.computeLocal( palview.getInvMatrix());
		local ix = Math.clamp( int(e.lx/palview.bnd.w*palimg.width), 0, palimg.width-1);
		local iy = Math.clamp( int(e.ly/palview.bnd.h*palimg.height), 0, palimg.height-1);
		local i = ix + iy * palimg.width;
		switch( e.id){
		case MOUSE_EXITED:
			palview.tips = null;
			break;
		case MOUSE_MOVED:
			palview.tips = null;
			if( palimg[i]){
				local mi = palmod[i*2+1]>>>24;
				local voxmtl = ::conf._resource.renderset.voxmtls[mi];
				if( voxmtl){
					palview.tips = sprintf( "#%06X\n%d:%S", palmod[i*2+1]&0xffffff, mi, ::lang( voxmtl.name));
				}
			}
			break;
		case MOUSE_PRESSED:
			if( e.isMouseDown( BUTTON2_MASK)){
				if( palimg[i]){
					local ret = MenuPopup.run( ctxmenuitems);
					if( ret){
						ctxMenuSelected( i, e, ret);
					}
				}
				break;
			}
			if( e.isMouseDown( BUTTON3_MASK)){
				if( selbb[i]) regclear(); else regselect( 0, 0, palimg.width-1, palimg.height-1);
				break;
			}
			if( e.count == 2){
				if( palimg[i]) editColor( i);
			}
			ix0 = ix; iy0 = iy;
			if( e.isShiftDown()){
				selmode = 2;
			}else
			if( e.isCommandDown()){
				selmode = selbb[i] ? 3 : 2;
			}else{
				selmode = 1;
				regclear();
			}
			selbb0.setBuffer( selbb);
		case MOUSE_DRAGGED:
			if( selmode && e.isMouseDown( BUTTON1_MASK)){
				regselect( ix0, iy0, ix, iy, selmode);
			}
			break;
		}
	}

	//	単色の編集
	function editColor( i){
		local ix = i%palimg.width, iy = i/palimg.width;
		local px = ix*palview.bnd.w / palimg.width;
		local py = (iy+1)*palview.bnd.h / palimg.height;
		local c = palimg[i]||0; c = (c<<24)|((c>>8)&0xff00)|((c<<8)&0xff0000)|0xff;
		local r = ColorPopup.run( Vector3D(px,py,0).transform( palview.mat), c);
		if( r){
			palmod = clone palmod;
			r = (r>>>24)|((r>>8)&0xff00)|((r<<8)&0xff0000);
			palmod[i*2+1] = (palmod[i*2+1]&0xff000000) | r;
			setImage( palmod);
			postActionEvent( true);
		}
	}
	
	function ctxMenuSelected( i, e, mi){
		switch( mi["id"]){
		case "hsv":
		{
			local img0 = clone palimg, img1 = palimg, self = this, n = length( palmod)/2, sb = selbb;
			local hsvpropdef = {
				name = "hsv",
				props = [
					{ pid="hsv", lbl="$T.lbl_hsv", type=VEC3, ui="bar", range=((-180,180),(-100,100),(-100,100)), dynamic=true },
				],
				setprop = @( prop, data, val){
					if( prop.pid != "hsv") return;
					img1.draw( img0, 0, 0);
					local hv = Math.lerp( -Math.PI, Math.PI, val[0]/360.0+0.5);
					local sv = Math.lerp( 0.0, 2.0, val[1]/200.0 + 0.5);
					local vv = Math.lerp( 0.0, 2.0, val[2]/200.0 + 0.5);
					local m = Matrix.fromHSV( hv, sv, vv);
					local v = Vector3D();
					for( local l = 0;l < n;l ++){
						if( !sb[l]) continue;
						local c = img1[l];
						v( c&255, (c>>>8)&255, (c>>>16)&255).scale( 1.0/255.0);
						v.transform( m).saturate().scale( 255.0);
						img1[l] = (v.x) | (v.y<<8) | (v.z<<16) | (c&0xff000000);
					}
					self.palview.sp.tex0.load( img1);
					self.palview.repaint();
				}
			}
			local d0 = #{hsv=[0,0,0]};
			local ret = PropertyEditPopup.run( palview, hsvpropdef, deepclone( d0));
			if( ret && ret<>d0){
				palmod = clone palmod;
				for( local l = 0;l < n;l ++){
					palmod[l*2+1] = (img1[l]&0xffffff) | (palmod[l*2+1]&0xff000000);
				}
				postActionEvent( true);
			}
			break;
		}
		case "mtl":
		{
			local m0 = palmod[i*2+1]>>>24, n = length( palmod)/2;
			local ret = MaterialSelectPopup.run( e, m0);
			if( ret){
				local m = ret[0]<<24;
				palmod = clone palmod;
				for( local l = 0;l < n;l ++){
					if( selbb[l]) palmod[l*2+1] = (palmod[l*2+1]&0x00ffffff) | m;
				}
				postActionEvent( true);
			}
			break;
		}
		case "copy":
			local a = [], n = length( palmod)/2;
			for( local l = 0;l < n;l ++){
				if( selbb[l]) a .. palmod[l*2+1]; else if( length( a)) a .. 0;
			}
			putClipboard( "voxpal", a);
			break;
		case "paste":
			local cbdata = getClipboard( "voxpal");
			if( !cbdata) break;
			local i0 = 0, n = length( palmod)/2;
			for( local l = 0;l < n;l ++) if( selbb[l]) { i0=l; break; }
			foreach( i, v in cbdata){
				local pi = (i+i0) * 2 + 1;
				if( v && palmod[pi]) palmod[pi] = v;
			}
			setImage( palmod);
			postActionEvent( true);
			break;
		case "reset":
			local pal = fget( prop, "inipal", prop, proplist);
			if( pal){
				local m0 = palmod[i*2+1]>>>24;
				palmod = clone palmod;
				palmod[i*2+1] = (pal[i*2+1]&0x00ffffff) | (m0<<24);
				setImage( palmod);
				postActionEvent( true);
			}
			break;
		}
	}

	function menuSelected( e, mi){
		switch( mi["id"]){
		case "mtl":
		{
			local len = length( palmod);
			local ca = [];
			for( local l = 0, n = length( palmod); l < n; l += 2) ca .. palmod[l+1];
			local ret = ColorMaterialSelectPopup.run( e, ca);
			if( ret){
				palmod = clone palmod;
				foreach( i, v in ret){
					palmod[i*2+1] = v;
				}
				setImage( palmod);
				postActionEvent( true);
			}
			break;
		}
		case "copyimg":
			skPutClipboardData( palimg);
			break;
		case "pasteimg":
			if( skCheckClipboardType( ClipboardType.CLIPBOARD_IMAGE)) {
				local img = skGetClipboardData( ClipboardType.CLIPBOARD_IMAGE);
				local len = length( palmod);
				if( img && img.width==16 && img.height>=len/32){
					palmod = clone palmod;
					for( local l = 0;l < len; l += 2){
						local r = img[l/2];
						r = r&0xffffff;// (r>>>24)|((r>>8)&0xff00)|((r<<8)&0xff0000);
						palmod[l+1] = r | (palmod[l+1] & 0xff000000);
					}
					setImage( palmod);
					postActionEvent( true);
				}
			}
			break;
		case "reset":
			local pal = fget( prop, "inipal", prop, proplist);
			if( pal){
				palmod = pal;
				setImage( pal);
				postActionEvent( true);
			}
			break;
		}
	}
}


class PropertyBehaviors.Variable extends PropertyBehavior
{
