class MapTools.tool_crack extends MapTools.tool_fblk
{
	usestat = true;

	constructor( e){
		super( e);
		selblk.setFreeBlockPages( [FB_CRACK]);
		// selblk.setPage( 0);
	}

	//
	function dndevent( e){
		local rot = getCameraRot();// + drot;		//	drotは
		local fblk = listfb();
		switch( e.id){
		case TARGET_DRAG_ENTER:
		case TARGET_DRAG_OVER:
			e.consume();
			local hb;
			hb = fblk && rayTestFB( e, blkflag, fblk, rot);
			if( hb && ((1<<hb.f)&(2|4|8|16))) rot = hb.f-1;
			local fb = fblk && hb && _makefb( fblk, hb);
			if( hb["f"] == 0){ hb.by += fblk.br.y - fb.br.y - 1; }
			placeFBPlace( fb, hb, rot);
			break;
		case TARGET_DRAG_EXIT:
			e.consume();
			placeFBPlace( fblk, null, rot);
			break;
		case TARGET_DROP:
			e.consume();
			local hb;
			hb = fblk && rayTestFB( e, blkflag, fblk, rot);
			if( hb && ((1<<hb.f)&(2|4|8|16))) rot = hb.f-1;
			if( hb){
				local fb = _makefb( fblk, hb);
				if( hb.f == 0){ hb.by += fblk.br.y - fb.br.y - 1; }
				local fbuid = placeFreeBlock( e, hb, fb, rot);
				local fb = editor.bw.getFreeBlock( fbuid);
				placeFBGizmo( fb, -1);
			}
			break;
		}
	}

	function _makefb( fb0, hb){
		local fbt = fb0.conf(), va = fbt.variations[fb0.fbparam&0x3ff];
		local p = (fb0.fbparam&(0x800003ff)) | ((hb.f==0&&!!va["fitfloor"])<<30) | (drot<<28);
		return FreeBlock.create({fbtype:fb0.fbtype, fbparam:p});
	}
}
