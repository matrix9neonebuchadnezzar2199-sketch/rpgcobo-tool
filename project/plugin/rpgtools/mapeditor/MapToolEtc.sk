import VirtualKeyCode;
import ModifiersMask;
import CollisionGroupID;
import BlockFlagID;
import BlockPlacementID;
import FreeBlockCategoryID;
import PenMode;

////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////
//	
//	進入禁止ツール
//	

class MapTools.tool_barrior extends MapTool
{
	penmap = null;

	penid = null;			//	string
	blkflag = BLK_SOLID | BLK_LIQUID;	//	rayTestで使う
	x2chk = null;

	mode = 1;

	bmp3d = null;			//	SK3DBarriorMap : バリア表示
	bmphash = 0;			//	hashが変わるとテクスチャを更新
	
	constructor( e){
		super( e);
		penmap = getPenmap();
		penid = "p01";
		//
		optionview = ::loadSKView( "/plugin/rpgtools/mapeditor/ui/tool_barrior.ui");
		optionview.addEventListener( ACTION_EVENT, optionevent);
		x2chk = optionview.findChild( "x2chk");
		// x2chk.setSelected( true);
		//	
		optionview.findChild( penid).setSelected( true);
		setMode( 1);
		bmp3d = SK3DBarriorMap();
	}

	function setMode( m){
		optionview.findChild( "mode"..mode)?.setSelected( false);
		optionview.findChild( "mode"..m).setSelected( true);
		mode = m;
		local mm = ["$T.penmode_erace","$T.penmode_paint"];
		optionview.findChild( "modelbl").setText( mm[m]);
	}

	function changeActiveTool( t){
		super.changeActiveTool( t);
		if( t == this){
			if( !bmp3d.scn) scn.addObject( bmp3d);
		}else{
			scn.removeObject( bmp3d);
		}
		refresh();
	}

	function refresh(){
		local bmp = editor.bw.bmp;
		local h = (bmp&&!bmp.empty()) ? bmp.hashcode() : 0;
		if( h != bmphash){
			bmp3d.setBitmap( bmp);
			bmphash = h;
		}
	}

	function optionevent( e){
		e.consume();
		switch( e.src["name"]){
		case "mode0": case "mode1": case "mode2": case "mode3": case "mode4":
			local m = e.src.name[4]-'0';
			if( m != mode){
				setMode( m);
			}
			break;
		default:
			if( e.src["name"] in penmap){
				local pid = e.src["name"];
				if( pid != penid){
					optionview.findChild( penid).setSelected( false);
					optionview.findChild( pid).setSelected( true);
					penid = pid;
				}
			}
			break;
		}
	}

	function getpens(){
		return penmap[penid];
	}

	function rayTestX( e, blkflag){
		local hb = rayTest( e, blkflag);
		if( hb["f"] != 0) hb = null;
		if( hb && x2chk.isSelected()){ hb.bx = (hb.bx)|1; hb.bz = (hb.bz)|1; }
		return hb;
	}
	
	//	
	function canvasevent( e){
		switch( e.id){
		case MOUSE_MOVED:
		{
			local hb = rayTestX( e, blkflag);
			placePen( hb, getpens()[0], mode ? PEN_PAINT : PEN_ERACE);
			e.consume();
			break;
		}
		case MOUSE_PRESSED:
		{
			local hb = rayTestX( e, blkflag);
			if( e.isMouseDown( BUTTON1_MASK)){
				if( hb){
					e.consume();
					return barriorStart( e, hb);
				}
			}
			break;
		}
		case MOUSE_EXITED:
		{
			removeGuide( "pen");
			e.consume();
			break;
		}
		case KEY_PRESSED:
			switch( e.keycode){
			case VK_1: case VK_2: 
				setMode( e.keycode-VK_1);
				break;
			}
			break;
		}
		if( !e.consumed){
			return super.canvasevent( e);
		}
	}

	function barriorStart( e0, hb0){
		local self = this;
		local pens = getpens(), pen = pens[hb0.f];
		local bop = BlockOperation( editor.bw);
		local x2 = x2chk.isSelected();
		local mode = mode;
		//	最初の描画
		bop.barriorSet({ pen:pen, hb:hb0, mode:mode });
		bop.submit( editor);
		refresh();
		//	開始時のtoolfunc
		local fn( e){
			e.consume();
			switch( e.id){
			case MOUSE_DRAGGED:
				local hb, ny = 0;
				hb = self.planeTest( e, hb0);
				if( hb && (e.modifiers&SHIFT_MASK)){
					self.adjustPlane( hb0, hb);
				}
				if( hb){
					if( hb && x2){ hb.bx = (hb.bx)|1; hb.bz = (hb.bz)|1; }
					bop.barriorSet({ pen:pen, hb:hb, mode:mode});
					if( bop.len()){
						bop.merge( editor);
						self.refresh();
					}
				}
				self.placePen( hb, pen, PEN_PAINT);
				break;
			case MOUSE_MOVED:	//	普通はこれ来ない
			case MOUSE_RELEASED:
			case MOUSE_CANCELLED:
				return null;
			case KEY_PRESSED:
				break;
			}
			return fn;
		};
		return fn;
	}
}

class MapTools.tool_barrior.SK3DBarriorMap extends SK3DScreenObject
{
	tex0 = null;

	constructor(){
		m.tec = skFXFindTechnique( "rpgtool.barrior");
		m.blend = SK_MIX;
		visible = false;		//	bmpがセットされたらtrueに
		visible = true;
		local img = RGBAImage( 4, 4, 0);
		tex0 = Texture();
		tex0.load( img);
		m.tex0 = tex0;
		m.tex1 = ::getTexture( "/plugin/rpgtools/pm/barrior.png");
	}
	
	function setBitmap( bmp){
		if( visible=!!bmp){
			local img = bmp.toRGBAImage( RGBAImage( bmp.w, bmp.h));
			local tex = Texture();
			tex.load( img);
			m.tex0 = tex;
		}else{
			m.tex0 = tex0;
		}
		visible = true;
	}

	function render( cam, visiblemask){
		super.render( cam, visiblemask);
	}
}

