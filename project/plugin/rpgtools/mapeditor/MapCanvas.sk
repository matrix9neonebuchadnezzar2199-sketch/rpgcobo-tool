local m_1 = Matrix();

local maprendersetlist(){
	local a = [];
	foreach( v in ::RenderSettings.data){
		if( v.renderpass == 2) a .. { lbl=v.name, id=v.id, icon="\ue430", data=v }	//	deferredのみ
	}
	return a;
}

