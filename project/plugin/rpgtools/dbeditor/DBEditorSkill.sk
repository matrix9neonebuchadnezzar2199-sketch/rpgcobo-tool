////////////////////// 基本プロパティ ///////////////////////

local eqtypeprop = {
	pid = "eqtypebits"
	lbl = "$T.lbl_eqtypebits",
	type = CHECKBITS
	list = @() ::conf.type.eqtype.filter( @( v, i) isWeapon( i)),
	defval = @(){
		local x = 0;
		foreach( i, v in ::conf.type.eqtype) x |= (isWeapon( i)<<i);
		return x;
	}
};

//	お金とか減らすのもなしではないか
local consumeprop = {
	pid = "consume"
	lbl = "$T.skillconsume"
	type = LIST_SCALAR
	list = [
		{ lbl:"$T.skillconsume0", val:0},
		{ lbl:"$T.skillconsume1", val:1},
		{ lbl:"$T.skillconsume2", val:2},
		{ lbl:"$T.skillconsume3", val:3},
		{ lbl:"$T.skillconsume4", val:4},
		{ lbl:"$T.skillconsume5", val:5},
	],
	range = (0,1000)
	defval = [0,1]
};

