import PropertyType;
import SKViewPropertyID;

//
//	LIST/

class SKProperties
{
	props = null;

	constructor(){
		props = {};
	}

	function _get( pid){
		if( !(pid in props)){
			foreach( p in props){
				printf("%S ",p.pid);
			}
			printf("\n");
			throw Exception("prop id " .. pid .. " not found");
		}
		return props[pid];
	}

	function _concat( p){
		if( p.pid in props){
			throw Exception("duplicate PARAMETER ID : "+p.pid);
		}
		props[p.pid] <- p;
	}
};

local blendlist = ["0:OFF","1:MIX","2:PMAMIX","3:ADD","4:MULT","5:MIXADD", "6:MASKMIX", "7:MASKALPHA"];
