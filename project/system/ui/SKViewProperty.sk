function getProperty( prop, data, ctx=null){
	local get = prop["get"];
	return get ? get( prop, data, ctx) : data[prop.pid];
}

function setProperty( prop, data, val, ctx=null){
	local set = prop["set"];
	return set ? set( prop, data, val, ctx) : data[prop.pid]<-val;
}

local _setdefprops( props, data, t, ctx){
	foreach( prop in props){
		if( typeof( prop) == SS_ARRAY){
			_setdefprops (prop, data, t, ctx);
		}else{
			if( prop["skipdefset"]) continue;
			local defval = fget( prop, "defval", prop, ctx);
			if( defval != undefined) setProperty( prop, t, deepclone( defval), ctx);
		}
	}
}

function setDefaultProperties( props, data, ctx=null){
	local t = {};	//	テンポラリのテーブルにデフォルト値を溜めていってdataに含まれていない値を入れていく
	_setdefprops( props, data, t, ctx);
	foreach( i, v in t){
		if( !(i in data)) data[i] <- v;
	}
	return data;
}
