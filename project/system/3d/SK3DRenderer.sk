with Fog
{
	function setData( t){
	}

	function computeParams( cam){
	}
}


class DepthFog extends Fog
{
	fogc = 0x000000ff;		//	フォグカラー
	zoffs   = 0.0;			//	Zオフセット
	klin = 1.0;				//	リニアフォールオフ
	kexp = 0.0;				//	expフォールオフ

	function setData( t){
		fogc = t.fogc;
		zoffs = t.zoffs;
		klin = t.klin;
		kexp = t.kexp;
		computeParams( cam);
	}

	function computeParams( cam){
		setParams( zoffs, klin, kexp, 0.0, (fogc>>>24)/255.0, ((fogc>>>16)&255)/255.0, ((fogc>>>8)&255)/255.0, (fogc&255)/255.0);
	}
	
	function getColor( v){
		return fogc;
	}

	function getFallOffZ(){
		//	z' = z + zoffs;
		//	klin*z' + exp( kexp*z') > 0.99
	}
}

local gs = Vector3D( 0.228912, 0.466611, 0.304478);		//	青強め

class AtmosphereFog extends Fog
{
	+sunvec = gs;				//	Vector3D
	+esun = gs;					//	Vector3D
	+br = gs;					//	Vector3D
	+bm = gs;					//	Vector3D
	g = 0.0;					//	float

	function atovec( v, a){
		v( a[0], a[1], a[2]);
	}
	
	function atovec2( v, a){
		v( Math.max( a[0], 0.001), Math.max( a[1], 0.001), Math.max( a[2], 0.001));
	}
	
	function setData( t){
		atovec( sunvec, t.sunvec);
		atovec( esun, t.esun);
		atovec2( br, t.br);
		atovec2( bm, t.bm);
		g = t.g;
		// computeParams();
	}

	function computeParams( cam){
		local vmat = cam.viewmat;
		local brit = 20.0;
		local bRM = br + bm;
		local ibRMEsun = esun / bRM;
		local bRpi  = br * ibRMEsun * (3.0 / (16.0*Math.PI) * brit);
		local bMpig = bm * ibRMEsun * ((1.0-g)*(1.0-g)/(4.0*Math.PI) * brit);
		local sv = #Vector3D();
		local sunv = esun.dot( gs);
		sv( sunvec).transform0( vmat).normalize();
		setParams(
			  sv.x,   sv.y,   sv.z,  sunv,
			 -bRM.x, -bRM.y, -bRM.z,  0.0,
			 bRpi.x, bRpi.y, bRpi.z,  1.0+g*g,
			 bMpig.x,bMpig.y,bMpig.z,-2.0*g
		);
	}
	
	function getColor( v){
		local brit = 20.0;
		local bRM = br + bm;
		local ibRMEsun = esun / bRM;
		local bRpi  = br * ibRMEsun * (3.0 / (16.0*Math.PI) * brit);
		local bMpig = bm * ibRMEsun * ((1.0-g)*(1.0-g)/(4.0*Math.PI) * brit);
		//
		local costh = v.dot( sunvec);
		local c = bRpi*( 1.0+costh*costh) + bMpig*Math.pow( (1.0+g*g)+(-2.0*g)*costh,-1.5);
		c.x = Math.saturate( c.x);
		c.y = Math.saturate( c.y);
		c.z = Math.saturate( c.z);
		// c.saturate();
		return ((c.x * 255.0)<<24) | ((c.y * 255.0)<<16) | ((c.z * 255.0)<<8) | 0xff;
	}

	function getFallOffZ(){
		//	local bRM = br + bm;
		//	exp( -bRM * z ) < 0.005; 
		//	-bRM * z < loge( 0.005)
		//	z < loge( 0.005) / -bRM
		local loge = Math.logn( 0.005, 2.71828182845904);
		local bRM = br + bm;
		local ibRM = -Math.max( bRM.x, Math.max( bRM.y, bRM.z));
		// local ibRM = -( bRM.x + bRM.y + bRM.z)/3.0;
		return loge / ibRM;
	}
}

//	PBRで使用可能なフォグ。他のフォグはlegacyレンダリングでのみ使用可能
class PbrFog extends Fog
{
	+color = Vector3D();
	density = 1.0;
	zoffs = 0.0;
	yplane = 0.0;
	yfalloff = 1.0;

	function setData( t){
		local c = t.color;
		color( c>>>24, (c>>>16)&255, (c>>>8)&255).scale( Math.pow( 1.1, (c&255)-128)/255.0);
		density = t.density;
		yplane = t.yplane;
		yfalloff = t.yfalloff;
	}

	function computeParams( cam, ex){
		// .x = density .y = -fallof*(camy-height) .z = density * exp(-fallof*(camy-height))
		local im = cam.viewmat.invert34( #Matrix());
		// printf( "camy? %S \n", im[13]); cam.viewmat.print();
		local foff = -( yfalloff * (im[13] - yplane));
		setParams(
			// density, yplane, density * Math.exp( foff), yfalloff,
			density, -yplane, density * Math.exp( foff), yfalloff,
			color.x*ex, color.y*ex, color.z*ex, zoffs,
			0,0,0,0,
			0,0,0,0
		);
		// printf( "-------\n");	printf( "%S %S %S %S  %S %S %S\n", density, -yplane, density * Math.exp( foff), yfalloff, color.x*ex, color.y*ex, color.z*ex);
	}
}

//////////////////////////////////////////////////////////////////////////////////////
//	
//	SK3DEnvironment
//	

class SK3DEnvironment extends Environment
{
	id = ""
	envlights = null;		//	enviroment lights
	data = null;

	constructor( t=null){
		if( t){
			setData( t);
		}
	}

	function setData( t){
		data = t;
		id = t["id"] || "*";
		//	legacy ambient
		if( t["ambup"]){
			ambup = t.ambup;
			ambdown = t.ambdown;
		}
		//	lights
		if( t["envlights"]){
			envlights = [];
			foreach( i, v in t.envlights){
				envlights .. createLight( v);
			}
		}else{
			envlights = null;
		}
		//	fog
		if( t["fog"]["type"]){
			local f = #[null,DepthFog,AtmosphereFog,PbrFog];
			f = f[t.fog.type]();
			f.type = t.fog.type;
			f.setData( t.fog);
			fog = f;					//	読み込み成功してから代入
		}else{
			fog = null;
		}
	}

	function createLight( data){
		local li = Light();
		li.type = data.type;
		//	vector / position
		if( ("head" in data) && ("pitch" in data)){
			//	TODO : vだけだとバンク角が表現できない！
			local v = Quaternion.fromHPB( data.head*Math.DTOR, data.pitch*Math.DTOR, (data["bank"]||0.0)*Math.DTOR) * Vector3D(0,0,-1);
			li.vx = v.x;
			li.vy = v.y;
			li.vz = v.z;
		}
		if( data["pos"]){
			li.px = data.pos[0];
			li.py = data.pos[1];
			li.pz = data.pos[2];
		}
		li.color = data["color"] || 0xffffffff;
		li.scolor = data["scolor"] || 0xffffffff;
		li.power = ("power" in data) ? data.power/255.0 : 0.8;	//	powerは100ぐらい
		li.pixellight = data["pixellight"]||0;
		li.k1 = data["k1"] || 0.0;
		li.k2 = data["k2"] || 0.0;
		//
		local sh = data["shadow"];
		if( sh["shadowtype"] && sh["shadowdens"]){
			local sm = li.shadow = ShadowMap();
			sm.casnum = sh["shadowtype"] || 0;
			sm.texsize = sh["shadowreso"] || 1024;
			sm.depth = sh["shadowdens"] || 0.0;
			sm.zfar = sh["shadowfar"] || 50.0;
			sm.raylen = sh["shadowray"] || 30.0;
			sm.softness = sh["shadowsoft"] || 0.5;
		}
		return li;
	}
}

class RenderSettings
{
	data = null;

	//	これ置き換えれば独自の読み込み先を指定できる
	static confloader = @(){
		local res = ::getResource( "/rendersets.json");
		if( res){
			return decodeJSON( res.loadData());
		}else{
			return ::getResourceContent( "/system/3d/rendersets.sk") ();
		}
	}

	static confsaver = @( rsets){
		local bb = encodeJSON( res, 1, ByteBuffer());
		local f = FileRef( skGetCodebase() .. "/rendersets.json");
		f.save( bb);
	}

	function checkLoadData(){
		if( data) return;
		data = confloader();
	}
	
	function getRenderSettingData( id){
		foreach( d in data){ if( d.id == id) return d; }
		return null;
	}

	function getEnvironment( id){
		checkLoadData();
		local env = SK3DEnvironment( getRenderSettingData( id));
		return env;
	}

	//	pbrを指定して取得可能
	function getDefaultEnvironment( ispbr=false){
		checkLoadData();
		foreach( v in data){
			local vispbr = (v.renderpass>=1);
			if( ispbr == vispbr) return SK3DEnvironment( v);
		}
		return SK3DEnvironment( data[0]);
	}

	function getDefaultRSetID( ispbr=false){
		checkLoadData();
		foreach( v in data){
			local vispbr = (v.renderpass>=1);
			if( ispbr == vispbr) return v.id;
		}
		return data[0].id;
	}
}

::RenderSettings <- RenderSettings();