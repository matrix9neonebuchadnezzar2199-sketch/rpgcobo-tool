with( skstudio){
	registerMenu( { uid="editor_ui_menu_edit_clipboardimg", parentid="menu_edit", block="*2", lbl="$T.editor_ui_menu_edit_clipboardimg", where=["editor_ui"],
		disable = @() !skCheckClipboardType( ClipboardType.CLIPBOARD_IMAGE),
	});
	registerMenu( { parentid="menu_edit", separator="*ui_edit0", block="*2", where=["editor_ui"]});
	registerMenu( { uid="editor_ui_menu_edit_group", parentid="menu_edit", block="*2", lbl="$T.editor_ui_menu_edit_group", defkey="^G", where=["editor_ui"]});
	registerMenu( { uid="editor_ui_menu_edit_ungroup", parentid="menu_edit", block="*2", lbl="$T.editor_ui_menu_edit_ungroup", defkey="^_G", where=["editor_ui"]});
	registerMenu( { uid="editor_ui_menu_edit_order", parentid="menu_edit", block="*2", lbl="$T.editor_ui_menu_edit_order", where=["editor_ui"],
		submenu = [
			{ uid="editor_ui_menu_edit_order_upmost", lbl="$T.editor_ui_menu_edit_order_upmost", icon="\ue25a", defkey="^_Up"},
			{ uid="editor_ui_menu_edit_order_up", lbl="$T.editor_ui_menu_edit_order_up", icon="\ue5d8", defkey="^Up"},
			{ uid="editor_ui_menu_edit_order_down", lbl="$T.editor_ui_menu_edit_order_down", icon="\ue5db", defkey="^Down"},
			{ uid="editor_ui_menu_edit_order_downmost", lbl="$T.editor_ui_menu_edit_order_downmost", icon="\ue258", defkey="^_Down"},
		]
	});
	registerMenu( { uid="editor_ui_menu_edit_to", parentid="menu_edit", block="*2", lbl="$T.editor_ui_menu_edit_to", where=["editor_ui"],
		submenu = [
			{ uid="editor_ui_menu_edit_to_button", lbl="$T.editor_ui_menu_edit_to_button"},
			{ uid="editor_ui_menu_edit_to_textedit", lbl="$T.editor_ui_menu_edit_to_textedit"},
			{ uid="editor_ui_menu_edit_to_multiimage", lbl="$T.editor_ui_menu_edit_to_multiimage"},
		]
	});
	registerMenu( { parentid="menu_edit", separator="*ui_edit1", block="*2", where=["editor_ui"]});
	registerMenu( { uid="editor_ui_menu_edit_uitest", parentid="menu_edit", block="*2", lbl="$T.editor_ui_menu_edit_uitest", defkey="^R", where=["editor_ui"]});

	
	registerEditor( {
		uid = "editor_ui",
		matches = @( path){ return path.endsWith( ".ui"); }
		createEditor = UIEditor.createEditor,
		createPreview = UIEditor.createPreview,
		
		newfile = {
			icon = FileIcons.ui,
			name = "$T.filetype_ui",
			ext = ".ui",
			func = UIEditor.newFile
		}
	});
}
