// 	},
// }

class PreferenceDialog extends UndoableDialog
{
	DIALOGUIPATH = "/skstudio/ui/dialog/prefdialog.ui"
	
	op = null;				//	
	typetabs = null;		//	TabsBehavior
	proplist = null;		//	PropertyListBehavior
	props = null;
	inidata = null;
	data = null;
	applyg = null;

	static function run( ctg=null){
		local p = PreferenceDialog( DIALOGUIPATH, ctg);
		p.show( null);
	}

	constructor( v, inictg){
		super( v);
		setCategory( inictg);
		typetabs.selectTab( @( v) v.id==inictg);
	}
	
	function init( v){
		applyg = v.findChild( "applyg");
		super.init( v);
		op = OperationStack();
		typetabs = TabsBehavior( v.findChild( "typetabs"), [{ lbl="$T.act_setting_all", id=null,}, ...preferencetypes]);
		typetabs.listview.addEventListener( ACTION_EVENT, typeevent);
		proplist = PropertyListBehavior( v.findChild( "proplist"), null, "cntp.ui");
		proplist.listview.addEventListener( ACTION_EVENT, propevent);
		proplist.listview.addEventListener( ITEM_EVENT, propevent);
		proplist.ref = this;
		props = [];
		data = {};
		foreach( i, t in preferencetypes){
			local a = preferenceprops.filter( @( v) v.ctg==t.id);
			if( length( a)){
				props .. { pid="H"..t.id, lbl=t.lbl, type=HEADER, ctg=t.id};
				props ... a;
				foreach( prop in a){
					data[prop.pid] <- fget( prop, "getpref") ?? ::workspace[prop.pid] ?? fget( prop, "defval");
				}
			}
		}
		inidata = deepclone( data);
	}

	function updateUndoable(){
		super.updateUndoable();
		applyg.anime( isChanged() ? 0 : -1);
	}

	function refresh(){
		proplist.setParameters( data);
	}

	function isChanged(){
		return inidata<>data;
	}

	function setCategory( ctg){
		local ctgprops = !ctg ? props : props.filter( @( v) v.ctg==ctg);
		proplist.bindProperties( ctgprops);
		refresh();
	}

	function typeevent( e){
		if( e.id == ACTION_PERFORMED){
			setCategory( typetabs.tabitems[e.actioncmd].id);
		}
	}

	function propevent( e){
		local cmd = e.actioncmd;
		if( cmd["cmd"] == "prop"){
			local prop = cmd.prop;
			local data = this.data;
			local val = cmd.val;
			local trk = null;
			local oldval = ::getProperty( prop, data);
			//	
			local self = this;
			local redo = [@(){ ::setProperty( prop, data, val); }];
			local undo = [@(){ ::setProperty( prop, data, oldval); }];
			submitOp( redo, undo, trk);
		}
	}

	function actionevent( e){
		switch( e.src["name"]){
		case "btn_apply":
			if( props.find( @( v) v["needreload"] && inidata[v.pid]<>data[v.pid])){
				if( !Dialogs.confirm( {msg="$T.confirm_setting_reload"})) return;
				doApply();
				::skstudio._savews();
				::skstudio.menuRelaunch( null);
				return;
			}else{
				doApply();
				::skstudio._savews();
				close();
			}
			break;
		}
		super.actionevent( e);
	}
	
	function doApply(){
		foreach( prop in props){
			local pid = prop.pid;
			if( !(inidata[pid]<>data[pid])) continue;
			if( prop["applypref"]){
				prop.applypref( prop, data[pid]);
			}else{
				::workspace[prop.pid] <- data[pid];
			}
		}
	}
}



