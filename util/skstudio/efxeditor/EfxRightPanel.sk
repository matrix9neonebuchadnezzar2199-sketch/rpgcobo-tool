import VirtualKeyCode;
import ModifiersMask;
import PropertyType;
import SKViewPropertyID;

function getPtcTecs(){
	local a = [];
	local efxs = skFXGetEffects();
	local icons = #( ("\ue430", 0xffff00ff), ("\ue2bd", 0x999999ff));
	foreach( efx in efxs){
		local efxname = efx.name;
		foreach( i,tec in efx){
			// printf( "tec.name %S    %S\n", tec.name, tec.tag);
			if( !tec.tag || !tec.tag.contains( "particle")){
				continue;
			}
			local ispbr = tec.tag.contains( "pbr");
			local icon = icons[ispbr?0:1];
			a .. { lbl=tec.name, val=tec.name, tec=tec, icon=icon};
		}
	}
	return a;
}

//	ヘッダ
