	{ classid="ptcmod_vel", lbl="Velocity", icon="\uf102", type=3310,  def={ classid="ptcmod_vel", vel = 1.0, vel_spr = 0.0, }, menu=modctxmenudata },
	{ classid="ptcmod_acc", lbl="Accel", icon="\uf102", type=3311,  def={ classid="ptcmod_acc", coord = 0, axisid = 1, acc = 0.1, acc_spr = 0.0, }, menu=modctxmenudata },
	{ classid="ptcmod_offs", lbl="Offset", icon="\uf102", type=3320,  def={ classid="ptcmod_offs", x=0.0, y=0.0, z=0.0, }, menu=modctxmenudata },
	{ classid="ptcmod_color", lbl="Color", icon="\uf102", type=3312,  def={ classid="ptcmod_color", color = [0xffffffff, 0x00000080], }, menu=modctxmenudata },
	{ classid="ptcmod_scale", lbl="Scale", icon="\uf102", type=3313,  def={ classid="ptcmod_scale", xyz = 7, scale = [1.0, 0.1], }, menu=modctxmenudata },
	{ classid="ptcmod_rot", lbl="Rotate", icon="\uf102", type=3314,  def={ classid="ptcmod_rot", axisid = 2, scale = 3.1416, rot = [-1.0, 1.0], }, menu=modctxmenudata },
