	{ classid="ptcmod_uv2", lbl="UVScroll", icon="\uf102", type=3318,  def={ classid="ptcmod_uv2", uv = 1, scale=1.0, scroll=[0.0,1.0], }, menu=modctxmenudata },
	{ classid="ptcmod_rnd", lbl="Randomize", icon="\uf102", type=3319,  def={ classid="ptcmod_rnd", h = 0.0, p = 0.0, b = 0.0, scale = 0.0, color = 0, }, menu=modctxmenudata },
