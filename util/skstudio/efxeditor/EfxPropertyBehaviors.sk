import VirtualKeyCode;
import ModifiersMask;

class PropertyBehaviors.NumSeed extends PropertyBehavior
{
	static proptype = 3300;
	static uipath = "/skstudio/ui/efxeditor/prop_numseed.ui"
	
	numval = null;
	seedval = null;

	function init(){
		numval = createNumInputBehavior( view.findChild( "val0"));
		numval.setRange( 1, 1000, 1);
		seedval = createNumInputBehavior( view.findChild( "val1"));
		seedval.setRange( 0, 99999, 1);
	}

	function getParam(){
		return (numval.getValue(), seedval.getValue());
	}
	
	function setParam( v){
		numval.setValue( v[0]);
		seedval.setValue( v[1]);
	}

	function paramevent( e){
		if( e.id == VALUE_CHANGED) return;
		if( e.src["name"] == "rndbtn"){
			local rnd = Random();
			local v = rnd.nexti( 0, 100000);
			seedval.setValue( v);
		}
		postActionEvent( true);
	}
}

class PropertyBehaviors.ScalarSpread extends PropertyBehavior
{
	static proptype = 3301;
	static uipath = "/skstudio/ui/efxeditor/prop_scalar_spr.ui"
	
	val = null;
	spr = null;
	linebtn = null;

	function init(){
		val = createNumInputBehavior( view.findChild( "val0"));
		val.setRange( 0, 10000, 1);
		spr = createNumInputBehavior( view.findChild( "val1"));
		spr.setRange( 0, 10000, 1);
		linebtn = view.findChild( "linebtn");
	}

	function getParam(){
		return (val.getValue(), spr.getValue(), linebtn.isSelected());
	}
	
	function setParam( v){
		val.setValue( v[0]);
		spr.setValue( v[1]);
		linebtn.setSelected( !!v[2]);
	}

	function paramevent( e){
		if( e.id == VALUE_CHANGED) return;
		postActionEvent( true);
	}
}

class PropertyBehaviors.Vec3Spread extends PropertyBehavior
{
	static proptype = 3302;
	static uipath = "/skstudio/ui/efxeditor/prop_vec3_spr.ui"

	vals = null;	//	[6]
	lines = null;	//	[3]
	
	function init(){
		vals = [];
		local r = prop["range"]||#(0,100), q = prop["q"]||1;
		for( local l = 0;l < 6;l ++){
			local v = createNumInputBehavior( view.findChild( "val"..l));
			v.setRange( r[0], r[1], q);
			vals .. v;
		}
		lines = [];
		for( local l = 0;l < 3;l ++){
			lines .. view.findChild( "linebtn"..l);
		}
	}

	function getParam(){
		local a = tuple( 7);
		for( local l = 0;l < 6;l ++){
			a[l] = vals[l].getValue();
		}
		a[6] = (lines[0].isSelected()<<0) | (lines[1].isSelected()<<1) | (lines[2].isSelected()<<2);
		return a;
	}
	
	function setParam( v){
		for( local l = 0;l < 6;l ++){
			vals[l].setValue( v[l]);
		}
		lines[0].setSelected( !!(v[6]&1));
		lines[1].setSelected( !!(v[6]&2));
		lines[2].setSelected( !!(v[6]&4));
	}

	function paramevent( e){
		if( e.id == VALUE_CHANGED) return;
		postActionEvent( true);
	}
}

