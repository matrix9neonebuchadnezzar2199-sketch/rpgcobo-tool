class PropertyBehaviors.EfxModUV2 extends PropertyBehavior
{
	static proptype = 3318;
	static cntui = "cnt2.ui";
	static uipath = "/skstudio/ui/efxeditor/mod_uv2.ui"
	
	curv = null;		//	EfxCurveEditView
	uchk = null;
	vchk = null;
	scaleval = null;

	function init(){
		curv = EfxCurveEditView();
		local curvp = view.findChild( "curvp");
		curv = EfxCurveEditView();
		curv.setRect( 0, 0, curvp.bnd.w, curvp.bnd.h);
		curvp.addChild( curv);
		uchk = view.findChild( "uchk");
		vchk = view.findChild( "vchk");
		scaleval = createNumInputBehavior( view.findChild( "scaleval"));
		scaleval.setRange( 1.0, 8.0, 0.1);
	}
	
	function getParam(){
		return {
			uv = (uchk.isSelected()?1:0) | (vchk.isSelected()?2:0),
			scale = scaleval.getValue(),
			scroll = curv.getCurves( -1.0, 1.0),
		}
	}
	
	function setParam( v){
		curv.setCurves( v.scroll, -1.0, 1.0);
		setAxis( v.uv);
		scaleval.setValue( v.scale);
	}
	
	function setAxis( ax){
		uchk.setSelected( !!(ax&1));
		vchk.setSelected( !!(ax&2));
	}

	function paramevent( e){
		switch( e.src["name"]){
		case "addbtn": 
			if( adddiv( curv.val)){ curv.setCurves( curv.val, 0.0, 1.0); }else return;
			break;
		case "delbtn": 
			if( remdiv( curv.val)){ curv.setCurves( curv.val, 0.0, 1.0); }else return;
			break;
		}
		postActionEvent( true);
	}
}

class PropertyBehaviors.EfxRandomize extends PropertyBehavior
{
	static proptype = 3319;
	static cntui = "cnt2.ui";
	static uipath = "/skstudio/ui/efxeditor/mod_random.ui"

	hpbvals = null;		//	[3]
	scaleval = null;	
	rgbvals = null;		//	[4]

	function init(){
		hpbvals = [
			_numinput( "hpb0", 10.0, 10),
			_numinput( "hpb1", 10.0, 10),
			_numinput( "hpb2", 10.0, 10),
		];
		scaleval = _numinput( "scale", 10.0, 10);
		rgbvals = [
			_numinput( "rgb0", 255, 1),
			_numinput( "rgb1", 255, 1),
			_numinput( "rgb2", 255, 1),
			_numinput( "rgb3", 255, 1),
		]
	}

	function _numinput( n, m, q){
		local v = createNumInputBehavior( view.findChild( n));
		v.setRange( 0, m, q);
		return v;
	}

	function getParam(){
		return {
			h = hpbvals[0].getValue(),
			p = hpbvals[1].getValue(),
			b = hpbvals[2].getValue(),
			scale = scaleval.getValue(),
			color = (rgbvals[0].getValue()<<24) |
					(rgbvals[1].getValue()<<16) |
					(rgbvals[2].getValue()<<8) |
					(rgbvals[3].getValue()),
		}
	}
	
	function setParam( v){
		hpbvals[0].setValue( v.h);
		hpbvals[1].setValue( v.p);
		hpbvals[2].setValue( v.b);
		scaleval.setValue( v.scale);
		local c = v.color;
		rgbvals[0].setValue( c>>24);
		rgbvals[1].setValue( (c>>16)&255);
		rgbvals[2].setValue( (c>>8)&255);
		rgbvals[3].setValue( c&255);
	}

	function paramevent( e){
		local s = e.src.name;
		if( s=="scale" || s.startsWith( "rgb") || s.startsWith( "hpb")){
			postActionEvent( true);
		}
	}
}

class PropertyBehaviors.EfxOffset extends PropertyBehavior
{
	static proptype = 3320;
	static cntui = "cnt2.ui";
	static uipath = "/skstudio/ui/prop/vec3.ui"

	vals = null;		//	[3]

	function init(){
		vals = [
			_numinput( "val0", -10.0, 10.0, 100),
			_numinput( "val1", -10.0, 10.0, 100),
			_numinput( "val2", -10.0, 10.0, 100),
		];
	}

	function _numinput( n, mi, ma, q){
		local v = createNumInputBehavior( view.findChild( n));
		v.setRange( mi, ma, q);
		return v;
	}

	function getParam(){
		return {
			x = vals[0].getValue(),
			y = vals[1].getValue(),
			z = vals[2].getValue(),
		};
	}
	
	function setParam( v){
		vals[0].setValue( v.x);
		vals[1].setValue( v.y);
		vals[2].setValue( v.z);
	}

	function paramevent( e){
		local s = e.src.name;
		postActionEvent( true);
	}
}
